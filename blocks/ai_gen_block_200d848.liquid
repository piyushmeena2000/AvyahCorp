{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_bg_color }};
    padding: {{ block.settings.section_padding_desktop }}px 20px;
  }

  .ai-feature-cards-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-feature-cards-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_spacing }}px;
  }

  .ai-feature-card-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.card_padding_desktop }}px;
    text-align: {{ block.settings.text_alignment }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .ai-feature-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.card_bg_color }};
    opacity: {{ block.settings.card_bg_opacity | divided_by: 100.0 }};
    border-radius: {{ block.settings.border_radius }}px;
    z-index: 0;
    transition: background-color 0.3s ease, opacity 0.3s ease;
  }

  .ai-feature-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-feature-card-{{ ai_gen_id }}:hover::before {
    background-color: #ffffff;
    opacity: 1;
  }

  .ai-feature-card-icon-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: {{ block.settings.icon_size_desktop }}px;
    height: {{ block.settings.icon_size_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    overflow: hidden;
  }

  .ai-feature-card-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: filter 0.3s ease;
  }

  .ai-feature-card-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-card-icon-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
    transition: filter 0.3s ease;
  }

  .ai-feature-card-title-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    font-family: 'Anton', sans-serif;
    font-size: {{ block.settings.title_size_desktop }}px;
    font-weight: 400;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.2;
    transition: color 0.3s ease;
  }

  .ai-feature-card-description-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    font-family: 'Inter', sans-serif;
    font-size: {{ block.settings.description_size_desktop }}px;
    font-weight: 400;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
    opacity: 0.9;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .ai-feature-card-{{ ai_gen_id }}:hover .ai-feature-card-icon-{{ ai_gen_id }} img,
  .ai-feature-card-{{ ai_gen_id }}:hover .ai-feature-card-icon-placeholder-{{ ai_gen_id }} svg {
    filter: brightness(0) saturate(100%) invert(24%) sepia(86%) saturate(2256%) hue-rotate(349deg) brightness(90%) contrast(92%);
  }

  .ai-feature-card-{{ ai_gen_id }}:hover .ai-feature-card-title-{{ ai_gen_id }} {
    color: {{ block.settings.section_bg_color }};
  }

  .ai-feature-card-{{ ai_gen_id }}:hover .ai-feature-card-description-{{ ai_gen_id }} {
    color: {{ block.settings.section_bg_color }};
    opacity: 1;
  }

  @media screen and (max-width: 1199px) {
    .ai-feature-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 767px) {
    .ai-feature-cards-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 16px;
    }

    .ai-feature-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-feature-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_mobile }}px;
    }

    .ai-feature-card-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-feature-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-feature-card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400&display=swap" rel="stylesheet">

<feature-cards-{{ ai_gen_id }} class="ai-feature-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-cards-container-{{ ai_gen_id }}">
    <div class="ai-feature-cards-grid-{{ ai_gen_id }}">
      {% for i in (1..block.settings.number_of_cards) %}
        {% liquid
          assign title_key = 'card_' | append: i | append: '_title'
          assign description_key = 'card_' | append: i | append: '_description'
          assign icon_key = 'card_' | append: i | append: '_icon'
          assign card_title = block.settings[title_key]
          assign card_description = block.settings[description_key]
          assign card_icon = block.settings[icon_key]
        %}
        
        <div class="ai-feature-card-{{ ai_gen_id }}">
          <div class="ai-feature-card-icon-{{ ai_gen_id }}">
            {% if card_icon != blank %}
              <img
                src="{{ card_icon | image_url: width: 200 }}"
                alt="{{ card_title | escape }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-feature-card-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if card_title != blank %}
            <h3 class="ai-feature-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
          {% endif %}
          
          {% if card_description != blank %}
            <p class="ai-feature-card-description-{{ ai_gen_id }}">{{ card_description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</feature-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-feature-card-{{ ai_gen_id }}');
      }
    }

    customElements.define('feature-cards-{{ ai_gen_id }}', FeatureCards{{ ai_gen_id }});
  })();
</script>

