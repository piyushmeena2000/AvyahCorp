{% doc %}
  @prompt
    i want a discover our story section where in the right there is a image and in the left there is a headline saying discover our story then the story below it, fit the image's height 100% in the section, add padding in the left at the header and subheading, change the subheading font to inter and also remove the right padding after the image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-story-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-story-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: stretch;
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0 {{ block.settings.section_padding }}px 20px;
    min-height: 500px;
  }

  .ai-story-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
    justify-content: center;
    padding-left: {{ block.settings.content_padding_left }}px;
  }

  .ai-story-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-story-text-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-story-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
  }

  .ai-story-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-story-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-story-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-story-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-story-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
      min-height: auto;
      padding: {{ block.settings.section_padding }}px 20px;
    }

    .ai-story-content-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_content_order }};
      padding-left: 0;
    }

    .ai-story-image-wrapper-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_image_order }};
      min-height: 300px;
    }

    .ai-story-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-story-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-story-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-container-{{ ai_gen_id }}">
    <div class="ai-story-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-story-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.story_text != blank %}
        <div class="ai-story-text-{{ ai_gen_id }}">{{ block.settings.story_text }}</div>
      {% endif %}
    </div>

    <div class="ai-story-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-story-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-story-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-story-empty-state-{{ ai_gen_id }}">
            Next, add an image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Discover our story",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Discover our story"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story text",
      "default": "<p>We started with a simple mission: to bring premium, healthy snacks to every home across India. Our journey began in a small kitchen, crafting nutritious bars that fuel your day without compromise. Today, we're proud to serve thousands of customers who trust us for quality, taste, and wellness in every bite.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_padding_left",
      "label": "Content left padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Text spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Mobile gap",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "select",
      "id": "mobile_content_order",
      "label": "Content order on mobile",
      "options": [
        {
          "value": "1",
          "label": "First"
        },
        {
          "value": "2",
          "label": "Second"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "mobile_image_order",
      "label": "Image order on mobile",
      "options": [
        {
          "value": "1",
          "label": "First"
        },
        {
          "value": "2",
          "label": "Second"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Discover our story"
    }
  ]
}
{% endschema %}
