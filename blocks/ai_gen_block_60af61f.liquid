{% doc %}
  @prompt
    i want a discover our story section where in the right there is a image and in the left there is a headline saying discover our story then the story below it, fit the image's height 100% in the section, add padding in the left at the header and subheading, change the subheading font to inter and also remove the right padding after the image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* Force parent Shopify section wrappers to stretch full-width without any gaps or borders */
  .shopify-section:has(.ai-story-section-{{ ai_gen_id }}) {
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    box-shadow: none !important;
    max-width: 100% !important;
    width: 100% !important;
  }

  .shopify-section:has(.ai-story-section-{{ ai_gen_id }}) .section {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
    display: block !important;
  }

  .shopify-section:has(.ai-story-section-{{ ai_gen_id }}) .custom-section-content {
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    max-width: 100% !important;
    width: 100% !important;
  }

  .shopify-section:has(.ai-story-section-{{ ai_gen_id }}) .section-content-wrapper {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
    min-height: auto !important;
  }

  .ai-story-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #ffffff;
    padding: 0;
    overflow: hidden;
  }

  .ai-story-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-story-content-{{ ai_gen_id }} {
    background-color: #d52528; /* Normal Crimson Red background */
    display: flex;
    flex-direction: column;
    gap: 24px;
    justify-content: center;
    align-items: center;
    text-align: center; /* Centered text */
    padding: 80px 8%;
    min-height: 600px;
  }

  .ai-story-heading-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 52px;
    color: #ffffff; /* White font color */
    margin: 0;
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    max-width: 500px;
  }

  .ai-story-text-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 17px;
    color: #ffffff; /* White font color */
    line-height: 1.65;
    max-width: 500px;
  }

  .ai-story-text-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-story-text-{{ ai_gen_id }} p:last-child {
    margin: 0;
  }

  .ai-story-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    padding: 60px; /* Elegant padding around the image card */
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .ai-story-image-container-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    max-height: 480px; /* Restrict max height to keep it compact */
    border-radius: 24px; /* Rounded corners */
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15); /* Soft premium shadow */
    aspect-ratio: 1.2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-story-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media screen and (max-width: 749px) {
    .ai-story-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-story-content-{{ ai_gen_id }} {
      padding: 60px 24px;
      order: 2;
      min-height: auto;
    }

    .ai-story-heading-{{ ai_gen_id }} {
      font-size: 36px;
    }

    .ai-story-text-{{ ai_gen_id }} {
      font-size: 15px;
    }

    .ai-story-image-wrapper-{{ ai_gen_id }} {
      padding: 30px 24px;
      height: auto;
      order: 1;
    }

    .ai-story-image-container-{{ ai_gen_id }} {
      max-height: 320px;
    }
  }
{% endstyle %}

<div class="ai-story-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-container-{{ ai_gen_id }}">
    <div class="ai-story-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-story-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.story_text != blank %}
        <div class="ai-story-text-{{ ai_gen_id }}">{{ block.settings.story_text }}</div>
      {% endif %}
    </div>

    <div class="ai-story-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-story-image-container-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-story-image-{{ ai_gen_id }}"
          >
        {% else %}
          <img
            src="{{ 'discover-our-story.webp' | asset_url }}"
            alt="Avyah Founders"
            loading="lazy"
            width="1200"
            height="900"
            class="ai-story-image-{{ ai_gen_id }}"
          >
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Discover our story",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Discover our story"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story text",
      "default": "<p>We started with a simple mission: to bring premium, healthy snacks to every home across India. Our journey began in a small kitchen, crafting nutritious bars that fuel your day without compromise. Today, we're proud to serve thousands of customers who trust us for quality, taste, and wellness in every bite.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_padding_left",
      "label": "Content left padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Text spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Mobile gap",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "select",
      "id": "mobile_content_order",
      "label": "Content order on mobile",
      "options": [
        {
          "value": "1",
          "label": "First"
        },
        {
          "value": "2",
          "label": "Second"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "mobile_image_order",
      "label": "Image order on mobile",
      "options": [
        {
          "value": "1",
          "label": "First"
        },
        {
          "value": "2",
          "label": "Second"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Discover our story"
    }
  ]
}
{% endschema %}
