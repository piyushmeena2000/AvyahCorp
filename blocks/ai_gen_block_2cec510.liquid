<script>
  (function() {
    class ReelCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.ai-reel-track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-reel-card-{{ ai_gen_id }}');
        this.videos = this.querySelectorAll('.ai-reel-video-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-reel-nav-btn-{{ ai_gen_id }}.prev');
        this.nextBtn = this.querySelector('.ai-reel-nav-btn-{{ ai_gen_id }}.next');
        this.fullscreen = this.querySelector('.ai-reel-fullscreen-{{ ai_gen_id }}');
        this.fullscreenVideo = this.querySelector('.ai-reel-fullscreen-video-{{ ai_gen_id }}');
        this.fullscreenClose = this.querySelector('.ai-reel-fullscreen-close-{{ ai_gen_id }}');
        this.fullscreenPrev = this.querySelector('.ai-reel-fullscreen-nav-{{ ai_gen_id }}.prev');
        this.fullscreenNext = this.querySelector('.ai-reel-fullscreen-nav-{{ ai_gen_id }}.next');
        
        this.isDragging = false;
        this.startX = 0;
        this.scrollLeft = 0;
        this.currentIndex = 0;
        this.autoScrollInterval = null;
        this.autoScrollEnabled = this.dataset.autoScroll === 'true';
        this.autoScrollSpeed = parseInt(this.dataset.autoScrollSpeed) || 3000;
        this.observer = null;
      }

      connectedCallback() {
        this.setupDragScroll();
        this.setupNavigation();
        this.setupFullscreen();
        this.setupIntersectionObserver();
        if (this.autoScrollEnabled) {
          this.startAutoScroll();
        }
      }

      disconnectedCallback() {
        this.stopAutoScroll();
        if (this.observer) {
          this.observer.disconnect();
        }
      }

      setupDragScroll() {
        let velocity = 0;
        let lastX = 0;
        let timestamp = 0;

        this.track.addEventListener('mousedown', (e) => {
          this.isDragging = true;
          this.startX = e.pageX - this.track.offsetLeft;
          this.scrollLeft = this.track.scrollLeft;
          this.track.classList.add('dragging');
          this.stopAutoScroll();
          velocity = 0;
          lastX = e.pageX;
          timestamp = Date.now();
        });

        this.track.addEventListener('touchstart', (e) => {
          this.isDragging = true;
          this.startX = e.touches[0].pageX - this.track.offsetLeft;
          this.scrollLeft = this.track.scrollLeft;
          this.stopAutoScroll();
          velocity = 0;
          lastX = e.touches[0].pageX;
          timestamp = Date.now();
        }, { passive: true });

        const handleMove = (pageX) => {
          if (!this.isDragging) return;
          const x = pageX - this.track.offsetLeft;
          const walk = (x - this.startX) * 2;
          this.track.scrollLeft = this.scrollLeft - walk;

          const now = Date.now();
          const dt = now - timestamp;
          if (dt > 0) {
            velocity = (pageX - lastX) / dt;
          }
          lastX = pageX;
          timestamp = now;
        };

        this.track.addEventListener('mousemove', (e) => {
          if (!this.isDragging) return;
          handleMove(e.pageX);
        });

        this.track.addEventListener('touchmove', (e) => {
          if (!this.isDragging) return;
          handleMove(e.touches[0].pageX);
        }, { passive: true });

        const endDrag = () => {
          if (this.isDragging) {
            this.isDragging = false;
            this.track.classList.remove('dragging');
            
            if (Math.abs(velocity) > 0.5) {
              let momentum = velocity * 100;
              const deceleration = 0.95;
              const animate = () => {
                momentum *= deceleration;
                this.track.scrollLeft -= momentum;
                if (Math.abs(momentum) > 0.5) {
                  requestAnimationFrame(animate);
                }
              };
              animate();
            }

            if (this.autoScrollEnabled) {
              setTimeout(() => this.startAutoScroll(), 3000);
            }
          }
        };

        this.track.addEventListener('mouseup', endDrag);
        this.track.addEventListener('mouseleave', endDrag);
        this.track.addEventListener('touchend', endDrag);

        this.track.addEventListener('wheel', (e) => {
          e.preventDefault();
          this.track.scrollLeft += e.deltaY;
          this.stopAutoScroll();
          if (this.autoScrollEnabled) {
            setTimeout(() => this.startAutoScroll(), 3000);
          }
        }, { passive: false });
      }

      setupNavigation() {
        this.prevBtn.addEventListener('click', () => {
          const cardWidth = this.cards[0].offsetWidth;
          const gap = parseInt('{{ block.settings.reel_gap }}');
          this.track.scrollBy({ left: -(cardWidth + gap), behavior: 'smooth' });
          this.stopAutoScroll();
          if (this.autoScrollEnabled) {
            setTimeout(() => this.startAutoScroll(), 3000);
          }
        });

        this.nextBtn.addEventListener('click', () => {
          const cardWidth = this.cards[0].offsetWidth;
          const gap = parseInt('{{ block.settings.reel_gap }}');
          this.track.scrollBy({ left: cardWidth + gap, behavior: 'smooth' });
          this.stopAutoScroll();
          if (this.autoScrollEnabled) {
            setTimeout(() => this.startAutoScroll(), 3000);
          }
        });
      }

      setupFullscreen() {
        this.cards.forEach((card, index) => {
          card.addEventListener('click', () => {
            this.openFullscreen(index);
          });
        });

        this.fullscreenClose.addEventListener('click', () => {
          this.closeFullscreen();
        });

        this.fullscreenPrev.addEventListener('click', () => {
          this.navigateFullscreen(-1);
        });

        this.fullscreenNext.addEventListener('click', () => {
          this.navigateFullscreen(1);
        });

        this.fullscreen.addEventListener('click', (e) => {
          if (e.target === this.fullscreen) {
            this.closeFullscreen();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (!this.fullscreen.classList.contains('active')) return;
          
          if (e.key === 'Escape') {
            this.closeFullscreen();
          } else if (e.key === 'ArrowLeft') {
            this.navigateFullscreen(-1);
          } else if (e.key === 'ArrowRight') {
            this.navigateFullscreen(1);
          }
        });

        let touchStartX = 0;
        this.fullscreen.addEventListener('touchstart', (e) => {
          touchStartX = e.touches[0].clientX;
        }, { passive: true });

        this.fullscreen.addEventListener('touchend', (e) => {
          const touchEndX = e.changedTouches[0].clientX;
          const diff = touchStartX - touchEndX;
          
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.navigateFullscreen(1);
            } else {
              this.navigateFullscreen(-1);
            }
          }
        }, { passive: true });
      }

      openFullscreen(index) {
        this.currentIndex = index;
        const video = this.videos[index];
        this.fullscreenVideo.src = video.src;
        this.fullscreenVideo.poster = video.poster;
        this.fullscreen.classList.add('active');
        this.fullscreenVideo.play();
        document.body.style.overflow = 'hidden';
        this.stopAutoScroll();
      }

      closeFullscreen() {
        this.fullscreen.classList.remove('active');
        this.fullscreenVideo.pause();
        this.fullscreenVideo.src = '';
        document.body.style.overflow = '';
        if (this.autoScrollEnabled) {
          this.startAutoScroll();
        }
      }

      navigateFullscreen(direction) {
        this.currentIndex += direction;
        if (this.currentIndex < 0) {
          this.currentIndex = this.videos.length - 1;
        } else if (this.currentIndex >= this.videos.length) {
          this.currentIndex = 0;
        }
        const video = this.videos[this.currentIndex];
        this.fullscreenVideo.src = video.src;
        this.fullscreenVideo.poster = video.poster;
        this.fullscreenVideo.play();
      }

      setupIntersectionObserver() {
        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const video = entry.target.querySelector('.ai-reel-video-{{ ai_gen_id }}');
            if (entry.isIntersecting) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          });
        }, { threshold: 0.5 });

        this.cards.forEach(card => {
          this.observer.observe(card);
        });
      }

      startAutoScroll() {
        if (!this.autoScrollEnabled) return;
        
        this.autoScrollInterval = setInterval(() => {
          const cardWidth = this.cards[0].offsetWidth;
          const gap = parseInt('{{ block.settings.reel_gap }}');
          const maxScroll = this.track.scrollWidth - this.track.clientWidth;
          
          if (this.track.scrollLeft >= maxScroll - 10) {
            this.track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            this.track.scrollBy({ left: cardWidth + gap, behavior: 'smooth' });
          }
        }, this.autoScrollSpeed);
      }

      stopAutoScroll() {
        if (this.autoScrollInterval) {
          clearInterval(this.autoScrollInterval);
          this.autoScrollInterval = null;
        }
      }
    }

    customElements.define('reel-carousel-{{ ai_gen_id }}', ReelCarousel{{ ai_gen_id }});
  })();
</script>

