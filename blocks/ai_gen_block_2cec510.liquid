          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-reel-track-{{ ai_gen_id }}">
        {% if block.settings.enable_reel_1 and block.settings.video_1 != blank %}
          <div class="ai-reel-card-{{ ai_gen_id }}" data-video-index="0">
            <div class="ai-reel-video-wrapper-{{ ai_gen_id }}">
              <video
