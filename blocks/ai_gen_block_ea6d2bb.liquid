{% doc %}
  @prompt
    create latest blogs section with carousel for healthy eating with full width section with mobile responsive settings
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-carousel-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-blog-carousel-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 {{ block.settings.desktop_padding }}px;
  }

  .ai-blog-carousel-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-blog-carousel-title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
  }

  .ai-blog-carousel-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
  }

  .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-blog-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .ai-blog-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.slides_per_view_desktop | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.slides_per_view_desktop }});
    min-width: 0;
  }

  .ai-blog-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-blog-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-blog-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-blog-card-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-blog-card-date-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-blog-card-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-blog-card-title-{{ ai_gen_id }} {
    color: {{ block.settings.card_title_color }};
    font-size: {{ block.settings.card_title_size }}px;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .ai-blog-card-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-blog-card-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-card-excerpt-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 16px;
    flex-grow: 1;
  }

  .ai-blog-card-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.3s ease;
  }

  .ai-blog-card-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-carousel-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: {{ block.settings.controls_spacing }}px;
  }

  .ai-blog-carousel-button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    border: 1px solid {{ block.settings.button_border }};
    color: {{ block.settings.button_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-blog-carousel-button-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_color }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-blog-carousel-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-blog-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-blog-carousel-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-blog-carousel-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    width: 24px;
    border-radius: 4px;
  }

  @media screen and (max-width: 989px) {
    .ai-blog-carousel-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.tablet_padding }}px;
    }

    .ai-blog-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_per_view_tablet | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.slides_per_view_tablet }});
    }

    .ai-blog-carousel-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-block-AcGNwanNRbldNdzdEc__ai_gen_block_ea6d2bb_LPrxPM {
      width:100%;
    }

    .ai-blog-carousel-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_padding }}px;
    }

    .ai-blog-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - 0px);
    }

    .ai-blog-carousel-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      
    }

    .ai-blog-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }

    .ai-blog-card-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<blog-carousel-{{ ai_gen_id }} class="ai-blog-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-blog-carousel-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-blog-carousel-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-blog-carousel-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-blog-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-blog-carousel-track-{{ ai_gen_id }}">
        {% if block.settings.blog != blank %}
          {% for article in block.settings.blog.articles limit: block.settings.articles_limit %}
            <div class="ai-blog-carousel-slide-{{ ai_gen_id }}">
              <article class="ai-blog-card-{{ ai_gen_id }}">
                <div class="ai-blog-card-image-wrapper-{{ ai_gen_id }}">
                  {% if article.image %}
                    <img
                      src="{{ article.image | image_url: width: 800 }}"
                      alt="{{ article.image.alt | escape }}"
                      class="ai-blog-card-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="800"
                      height="{{ 800 | divided_by: article.image.aspect_ratio | round }}"
                    >
                  {% else %}
                    <div class="ai-blog-card-image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-blog-card-content-{{ ai_gen_id }}">
                  {% if block.settings.show_date or block.settings.show_author %}
                    <div class="ai-blog-card-meta-{{ ai_gen_id }}">
                      {% if block.settings.show_date %}
                        <span class="ai-blog-card-date-{{ ai_gen_id }}">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                          </svg>
                          {{ article.published_at | date: '%b %d, %Y' }}
                        </span>
                      {% endif %}
                      {% if block.settings.show_author and article.author != blank %}
                        <span class="ai-blog-card-author-{{ ai_gen_id }}">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                          </svg>
                          {{ article.author }}
                        </span>
                      {% endif %}
                    </div>
                  {% endif %}

                  <h3 class="ai-blog-card-title-{{ ai_gen_id }}">
                    <a href="{{ article.url }}">{{ article.title }}</a>
                  </h3>

                  {% if block.settings.show_excerpt %}
                    <div class="ai-blog-card-excerpt-{{ ai_gen_id }}">
                      {% if article.excerpt != blank %}
                        {{ article.excerpt | strip_html | truncate: block.settings.excerpt_length }}
                      {% else %}
                        {{ article.content | strip_html | truncate: block.settings.excerpt_length }}
                      {% endif %}
                    </div>
                  {% endif %}

                  <a href="{{ article.url }}" class="ai-blog-card-link-{{ ai_gen_id }}">
                    {{ block.settings.read_more_text }}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                </div>
              </article>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..6) %}
            <div class="ai-blog-carousel-slide-{{ ai_gen_id }}">
              <article class="ai-blog-card-{{ ai_gen_id }}">
                <div class="ai-blog-card-image-wrapper-{{ ai_gen_id }}">
                  <div class="ai-blog-card-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                </div>
                <div class="ai-blog-card-content-{{ ai_gen_id }}">
                  <div class="ai-blog-card-meta-{{ ai_gen_id }}">
                    <span class="ai-blog-card-date-{{ ai_gen_id }}">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                      </svg>
                      Jan 1, 2025
                    </span>
                  </div>
                  <h3 class="ai-blog-card-title-{{ ai_gen_id }}">
                    <a href="#">Healthy Eating Tips for a Better Lifestyle</a>
                  </h3>
                  <div class="ai-blog-card-excerpt-{{ ai_gen_id }}">
                    Discover the best practices for maintaining a healthy diet and improving your overall wellness.
                  </div>
                  <a href="#" class="ai-blog-card-link-{{ ai_gen_id }}">
                    Read more
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                </div>
              </article>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {% if block.settings.show_controls %}
      <div class="ai-blog-carousel-controls-{{ ai_gen_id }}">
        <button
          class="ai-blog-carousel-button-{{ ai_gen_id }} ai-blog-carousel-prev-{{ ai_gen_id }}"
          aria-label="Previous slide"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="ai-blog-carousel-dots-{{ ai_gen_id }}"></div>

        <button
          class="ai-blog-carousel-button-{{ ai_gen_id }} ai-blog-carousel-next-{{ ai_gen_id }}"
          aria-label="Next slide"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</blog-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-blog-carousel-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-blog-carousel-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-blog-carousel-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-blog-carousel-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-blog-carousel-dots-{{ ai_gen_id }}');

        if (!this.track || this.slides.length === 0) return;

        this.slidesPerView = this.getSlidesPerView();
        this.totalSlides = this.slides.length;
        this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);

        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}

        window.addEventListener('resize', () => {
          this.slidesPerView = this.getSlidesPerView();
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
          this.currentIndex = Math.min(this.currentIndex, this.maxIndex);
          this.updateCarousel();
        });
      }

      getSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          return 1;
        } else if (width <= 989) {
          return {{ block.settings.slides_per_view_tablet }};
        }
        return {{ block.settings.slides_per_view_desktop }};
      }

      createDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';
        const dotsCount = this.maxIndex + 1;
        for (let i = 0; i < dotsCount; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-blog-carousel-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));
        this.track.style.transform = 'translateX(' + offset + 'px)';

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.maxIndex;
        }

        const dots = this.dotsContainer?.querySelectorAll('.ai-blog-carousel-dot-{{ ai_gen_id }}');
        if (dots) {
          dots.forEach((dot, index) => {
            if (index === this.currentIndex) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          if (this.currentIndex >= this.maxIndex) {
            this.currentIndex = 0;
          } else {
            this.currentIndex++;
          }
          this.updateCarousel();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('blog-carousel-{{ ai_gen_id }}', BlogCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Latest blogs carousel",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_limit",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Maximum articles",
      "default": 6
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest Healthy Eating Tips"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover nutrition advice and wellness insights"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Article display"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "min": 50,
      "max": 200,
      "step": 10,
      "label": "Excerpt length",
      "default": 120
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more text",
      "default": "Read more"
    },
    {
      "type": "header",
      "content": "Carousel settings"
    },
    {
      "type": "range",
      "id": "slides_per_view_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Slides per view (desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_per_view_tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Slides per view (tablet)",
      "default": 2
