{% doc %}
  @prompt
    Add ticker with multiple texts and icon images, add 5 more text with image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ticker-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px 0;
  }

  .ai-ticker-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-ticker-scroll-{{ ai_gen_id }} {{ block.settings.speed }}s linear infinite;
  }

  .ai-ticker-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    white-space: nowrap;
    margin-left: 100px;
  }

  .ai-ticker-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_spacing }}px;
  }

  .ai-ticker-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-ticker-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-ticker-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.text_color }};
    opacity: 0.2;
    border-radius: 50%;
  }

  .ai-ticker-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
  }

  @keyframes ai-ticker-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-ticker-wrapper-{{ ai_gen_id }}:hover {
    animation-play-state: {% if block.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  @media screen and (max-width: 749px) {
    .ai-ticker-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-ticker-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-ticker-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ticker-wrapper-{{ ai_gen_id }}">
    <div class="ai-ticker-content-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign text_key = 'text_' | append: i
          assign icon_key = 'icon_' | append: i
          assign text_value = block.settings[text_key]
          assign icon_value = block.settings[icon_key]
        %}

        {% if text_value != blank %}
          <div class="ai-ticker-item-{{ ai_gen_id }}">
            {% if icon_value != blank %}
              <div class="ai-ticker-icon-{{ ai_gen_id }}">
                <img
                  src="{{ icon_value | image_url: width: 100 }}"
                  alt="{{ text_value | escape }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              </div>
            {% elsif block.settings.show_placeholder_icons %}
              <div class="ai-ticker-icon-{{ ai_gen_id }}">
                <div class="ai-ticker-icon-placeholder-{{ ai_gen_id }}"></div>
              </div>
            {% endif %}
            <span class="ai-ticker-text-{{ ai_gen_id }}">{{ text_value }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-ticker-content-{{ ai_gen_id }}" aria-hidden="true">
      {% for i in (1..10) %}
        {% liquid
          assign text_key = 'text_' | append: i
          assign icon_key = 'icon_' | append: i
          assign text_value = block.settings[text_key]
          assign icon_value = block.settings[icon_key]
        %}

        {% if text_value != blank %}
          <div class="ai-ticker-item-{{ ai_gen_id }}">
            {% if icon_value != blank %}
              <div class="ai-ticker-icon-{{ ai_gen_id }}">
                <img
                  src="{{ icon_value | image_url: width: 100 }}"
                  alt="{{ text_value | escape }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              </div>
            {% elsif block.settings.show_placeholder_icons %}
              <div class="ai-ticker-icon-{{ ai_gen_id }}">
                <div class="ai-ticker-icon-placeholder-{{ ai_gen_id }}"></div>
              </div>
            {% endif %}
            <span class="ai-ticker-text-{{ ai_gen_id }}">{{ text_value }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

