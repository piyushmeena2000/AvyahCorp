{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-carousel-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-carousel-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    overflow: hidden;
    position: relative;
  }

  .ai-product-carousel-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 {{ block.settings.horizontal_padding }}px {{ block.settings.wrapper_padding_bottom }}px;
    cursor: grab;
    user-select: none;
  }

  .ai-product-carousel-wrapper-{{ ai_gen_id }}:active {
    cursor: grabbing;
  }

  .ai-product-carousel-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.cards_per_view | minus: 1 }} * {{ block.settings.card_gap }}px) - (2 * {{ block.settings.horizontal_padding }}px)) / {{ block.settings.cards_per_view }});
    min-width: calc((100% - ({{ block.settings.cards_per_view | minus: 1 }} * {{ block.settings.card_gap }}px) - (2 * {{ block.settings.horizontal_padding }}px)) / {{ block.settings.cards_per_view }});
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: visible;
    position: relative;
    padding-bottom: {{ block.settings.button_overlap }}px;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px {{ block.settings.card_border_radius }}px 0 0;
    position: relative;
  }

  .ai-product-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.4;
    min-height: {{ block.settings.title_min_height }}px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.title_line_clamp }};
    -webkit-box-orient: vertical;
  }

  .ai-product-card-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.price_color }};
  }

  .ai-product-card-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-product-card-discount-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.discount_badge_bg }};
    color: {{ block.settings.discount_badge_text }};
    padding: 4px 10px;
    border-radius: {{ block.settings.discount_badge_radius }}px;
    font-size: {{ block.settings.discount_badge_font_size }}px;
    font-weight: 600;
    display: inline-block;
  }

  .ai-product-card-button-{{ ai_gen_id }} {
    position: absolute;
    bottom: calc(-1 * {{ block.settings.button_overlap }}px / 2);
    left: 50%;
    transform: translateX(-50%);
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    padding: 12px 24px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    border: none;
    cursor: pointer;
    white-space: nowrap;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
    z-index: 10;
  }

  .ai-product-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    color: {{ block.settings.button_hover_text }};
    transform: translateX(-50%) translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: {{ block.settings.dots_margin_top }}px;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_view_mobile | minus: 1 }} * {{ block.settings.card_gap }}px) - (2 * {{ block.settings.horizontal_padding }}px)) / {{ block.settings.cards_per_view_mobile }});
      min-width: calc((100% - ({{ block.settings.cards_per_view_mobile | minus: 1 }} * {{ block.settings.card_gap }}px) - (2 * {{ block.settings.horizontal_padding }}px)) / {{ block.settings.cards_per_view_mobile }});
    }

    .ai-product-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-product-card-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_font_size | times: 0.9 }}px;
    }

    .ai-product-card-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: 10px 20px;
    }
  }
{% endstyle %}

<product-carousel-{{ ai_gen_id }} class="ai-product-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-carousel-container-{{ ai_gen_id }}">
    <div class="ai-product-carousel-wrapper-{{ ai_gen_id }}" data-carousel-wrapper>
      {% if block.settings.product_list != blank %}
        {% for product in block.settings.product_list %}
          <div class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-card-image-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="800"
                >
              {% else %}
                <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-product-card-content-{{ ai_gen_id }}">
              <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ product.title }}</h3>

              <div class="ai-product-card-price-wrapper-{{ ai_gen_id }}">
                <span class="ai-product-card-price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </span>

                {% if product.compare_at_price > product.price %}
                  <span class="ai-product-card-compare-price-{{ ai_gen_id }}">
                    {{ product.compare_at_price | money }}
                  </span>

                  {% assign discount_percentage = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <span class="ai-product-card-discount-badge-{{ ai_gen_id }}">
                    -{{ discount_percentage }}%
                  </span>
                {% endif %}
              </div>
            </div>

            <a href="{{ product.url }}" class="ai-product-card-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..8) %}
          <div class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-card-image-{{ ai_gen_id }}">
              <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            </div>

            <div class="ai-product-card-content-{{ ai_gen_id }}">
              <h3 class="ai-product-card-title-{{ ai_gen_id }}">Product title</h3>

              <div class="ai-product-card-price-wrapper-{{ ai_gen_id }}">
                <span class="ai-product-card-price-{{ ai_gen_id }}">₹999</span>
                <span class="ai-product-card-compare-price-{{ ai_gen_id }}">₹1,299</span>
                <span class="ai-product-card-discount-badge-{{ ai_gen_id }}">-23%</span>
              </div>
            </div>

            <a href="#" class="ai-product-card-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="ai-carousel-dots-{{ ai_gen_id }}" data-dots-container></div>
  </div>
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.wrapper = this.querySelector('[data-carousel-wrapper]');
        this.dotsContainer = this.querySelector('[data-dots-container]');
        this.cards = this.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        this.currentIndex = 0;
        this.cardsPerView = {{ block.settings.cards_per_view }};
        this.cardsPerViewMobile = {{ block.settings.cards_per_view_mobile }};
        this.isDragging = false;
        this.startX = 0;
        this.scrollLeft = 0;
      }

      connectedCallback() {
        this.createDots();
        this.setupScrollListener();
        this.setupDragScroll();
        this.updateActiveDot();
      }

      getCardsPerView() {
        return window.innerWidth <= 749 ? this.cardsPerViewMobile : this.cardsPerView;
      }

      createDots() {
        if (!this.dotsContainer || this.cards.length === 0) return;

        const totalDots = Math.ceil(this.cards.length / this.getCardsPerView());
        this.dotsContainer.innerHTML = '';

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-carousel-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          dot.addEventListener('click', () => this.scrollToIndex(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      scrollToIndex(index) {
        const cardsPerView = this.getCardsPerView();
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const scrollPosition = index * cardsPerView * (cardWidth + gap);
        
        this.wrapper.scrollTo({
          left: scrollPosition,
          behavior: 'smooth'
        });
      }

      setupDragScroll() {
        this.wrapper.addEventListener('mousedown', (e) => {
          this.isDragging = true;
          this.startX = e.pageX - this.wrapper.offsetLeft;
          this.scrollLeft = this.wrapper.scrollLeft;
        });

        this.wrapper.addEventListener('mouseleave', () => {
          this.isDragging = false;
        });

        this.wrapper.addEventListener('mouseup', () => {
          this.isDragging = false;
        });

        this.wrapper.addEventListener('mousemove', (e) => {
          if (!this.isDragging) return;
          e.preventDefault();
          const x = e.pageX - this.wrapper.offsetLeft;
          const walk = (x - this.startX) * 2;
          this.wrapper.scrollLeft = this.scrollLeft - walk;
        });

        this.wrapper.addEventListener('touchstart', (e) => {
          this.startX = e.touches[0].pageX - this.wrapper.offsetLeft;
          this.scrollLeft = this.wrapper.scrollLeft;
        }, { passive: true });

        this.wrapper.addEventListener('touchmove', (e) => {
          const x = e.touches[0].pageX - this.wrapper.offsetLeft;
          const walk = (x - this.startX) * 2;
          this.wrapper.scrollLeft = this.scrollLeft - walk;
        }, { passive: true });
      }

      setupScrollListener() {
        let scrollTimeout;
        this.wrapper.addEventListener('scroll', () => {
          clearTimeout(scrollTimeout);
          scrollTimeout = setTimeout(() => {
            this.updateActiveDot();
          }, 100);
        });

        window.addEventListener('resize', () => {
          this.createDots();
          this.updateActiveDot();
        });
      }

      updateActiveDot() {
        const cardsPerView = this.getCardsPerView();
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const scrollLeft = this.wrapper.scrollLeft;
        const index = Math.round(scrollLeft / ((cardWidth + gap) * cardsPerView));

        const dots = this.dotsContainer.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
        dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.currentIndex = index;
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

