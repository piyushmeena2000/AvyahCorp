{% doc %}
  @prompt
    create testimonial carousel with user image and quote with full width section, 3 testimonials to be shown at a time, This needs to be full screen width. Also need stars
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-carousel-{{ ai_gen_id }} {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-testimonial-carousel__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-testimonial-carousel__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-testimonial-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
  }

  .ai-testimonial-carousel__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonial-carousel__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-testimonial-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
    transition: transform 0.5s ease;
  }

  .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 calc(33.333% - 16px);
    min-width: 0;
  }

  .ai-testimonial-carousel__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-testimonial-carousel__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }

  .ai-testimonial-carousel__star-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-carousel__quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 24px;
    flex-grow: 1;
  }

  .ai-testimonial-carousel__author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-testimonial-carousel__image-wrapper-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: #f5f5f5;
  }

  .ai-testimonial-carousel__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-testimonial-carousel__author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-testimonial-carousel__name-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 4px;
  }

  .ai-testimonial-carousel__role-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonial-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 40px;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
    color: {{ block.settings.button_color }};
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-testimonial-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - 12px);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-testimonial-carousel__track-{{ ai_gen_id }} {
      gap: 16px;
    }

    .ai-testimonial-carousel__card-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-testimonial-carousel__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-testimonial-carousel__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<testimonial-carousel-{{ ai_gen_id }}
  class="ai-testimonial-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-testimonial-carousel__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-testimonial-carousel__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-testimonial-carousel__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonial-carousel__track-wrapper-{{ ai_gen_id }}">
      <div class="ai-testimonial-carousel__track-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign testimonial_enabled_key = 'testimonial_' | append: i | append: '_enabled'
            assign testimonial_image_key = 'testimonial_' | append: i | append: '_image'
            assign testimonial_name_key = 'testimonial_' | append: i | append: '_name'
            assign testimonial_role_key = 'testimonial_' | append: i | append: '_role'
            assign testimonial_quote_key = 'testimonial_' | append: i | append: '_quote'
            assign testimonial_rating_key = 'testimonial_' | append: i | append: '_rating'

            assign testimonial_enabled = block.settings[testimonial_enabled_key]
            assign testimonial_image = block.settings[testimonial_image_key]
            assign testimonial_name = block.settings[testimonial_name_key]
            assign testimonial_role = block.settings[testimonial_role_key]
            assign testimonial_quote = block.settings[testimonial_quote_key]
            assign testimonial_rating = block.settings[testimonial_rating_key]
          %}

          {% if testimonial_enabled %}
            <div class="ai-testimonial-carousel__slide-{{ ai_gen_id }}">
              <div class="ai-testimonial-carousel__card-{{ ai_gen_id }}">
                <div class="ai-testimonial-carousel__stars-{{ ai_gen_id }}">
                  {% for star in (1..testimonial_rating) %}
                    <svg
                      class="ai-testimonial-carousel__star-{{ ai_gen_id }}"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  {% endfor %}
                </div>

                <p class="ai-testimonial-carousel__quote-{{ ai_gen_id }}">{{ testimonial_quote }}</p>

                <div class="ai-testimonial-carousel__author-{{ ai_gen_id }}">
                  <div class="ai-testimonial-carousel__image-wrapper-{{ ai_gen_id }}">
                    {% if testimonial_image %}
                      <img
                        src="{{ testimonial_image | image_url: width: 120 }}"
                        alt="{{ testimonial_name | escape }}"
                        class="ai-testimonial-carousel__image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="120"
                        height="120"
                      >
                    {% else %}
                      <div class="ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }}">
                        {{ 'image' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-testimonial-carousel__author-info-{{ ai_gen_id }}">
                    <p class="ai-testimonial-carousel__name-{{ ai_gen_id }}">{{ testimonial_name }}</p>
                    <p class="ai-testimonial-carousel__role-{{ ai_gen_id }}">{{ testimonial_role }}</p>
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-testimonial-carousel__controls-{{ ai_gen_id }}">
      <button
        class="ai-testimonial-carousel__button-{{ ai_gen_id }} ai-testimonial-carousel__prev-{{ ai_gen_id }}"
        aria-label="Previous testimonials"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-testimonial-carousel__dots-{{ ai_gen_id }}"></div>

      <button
        class="ai-testimonial-carousel__button-{{ ai_gen_id }} ai-testimonial-carousel__next-{{ ai_gen_id }}"
        aria-label="Next testimonials"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</testimonial-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = 3;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-testimonial-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-testimonial-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-testimonial-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-testimonial-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-testimonial-carousel__dots-{{ ai_gen_id }}');

        this.updateSlidesPerView();
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.createDots();
          this.updateCarousel();
        });
      }

      updateSlidesPerView() {
        if (window.innerWidth <= 749) {
          this.slidesPerView = 1;
        } else if (window.innerWidth <= 989) {
          this.slidesPerView = 2;
        } else {
          this.slidesPerView = 3;
        }
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        const totalSlides = this.slides.length;
        const totalDots = Math.ceil(totalSlides / this.slidesPerView);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-testimonial-carousel__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === 0) {
            dot.classList.add('active');
          }
          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => {
          this.currentIndex = Math.max(0, this.currentIndex - 1);
          this.updateCarousel();
        });

        this.nextButton.addEventListener('click', () => {
          const maxIndex = Math.ceil(this.slides.length / this.slidesPerView) - 1;
          this.currentIndex = Math.min(maxIndex, this.currentIndex + 1);
          this.updateCarousel();
        });
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = 24;
        const offset = this.currentIndex * (slideWidth + gap) * this.slidesPerView;

        this.track.style.transform = 'translateX(-' + offset + 'px)';

        const maxIndex = Math.ceil(this.slides.length / this.slidesPerView) - 1;
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex === maxIndex;

        const dots = this.dotsContainer.querySelectorAll('.ai-testimonial-carousel__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('testimonial-carousel-{{ ai_gen_id }}', TestimonialCarousel{{ ai_gen_id }});
  })();
</script>

