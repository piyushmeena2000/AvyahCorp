{% doc %}
  @prompt
    create testimonial carousel with user image and quote with full width section, 3 testimonials to be shown at a time, This needs to be full screen width. Also need stars
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-carousel-{{ ai_gen_id }} {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px !important;
    background-color: #ffffff !important;
    overflow: hidden;
  }

  .ai-testimonial-carousel__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-testimonial-carousel__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-testimonial-carousel__title-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: {{ block.settings.heading_size }}px;
    color: #d52528 !important;
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 1.1;
  }

  .ai-testimonial-carousel__subtitle-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: {{ block.settings.subheading_size }}px;
    color: #555555 !important;
    margin: 0;
  }

  .ai-testimonial-carousel__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    padding: 20px 20px 60px 20px; /* increased spacing to prevent hover shadow clipping */
    margin: -20px -20px -60px -20px;
  }

  .ai-testimonial-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
    transition: transform 0.5s ease;
  }

  .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 calc(33.333% - 16px);
    min-width: 0;
  }

  .ai-testimonial-carousel__card-{{ ai_gen_id }} {
    background-color: #d52528 !important;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    box-shadow: 0 8px 30px rgba(213, 37, 40, 0.15);
    padding: 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .ai-testimonial-carousel__card-{{ ai_gen_id }}:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 45px rgba(213, 37, 40, 0.25);
  }

  .ai-testimonial-carousel__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 18px;
  }

  .ai-testimonial-carousel__star-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-carousel__quote-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: {{ block.settings.quote_size }}px;
    color: #ffffff !important;
    line-height: 1.6;
    margin: 0 0 28px;
    flex-grow: 1;
  }

  .ai-testimonial-carousel__author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 20px;
  }

  .ai-testimonial-carousel__image-wrapper-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: #f5f5f5;
    border: 2px solid #ffffff;
  }

  .ai-testimonial-carousel__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-testimonial-carousel__author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-testimonial-carousel__name-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #ffffff !important;
    text-transform: uppercase;
    margin: 0 0 4px;
    letter-spacing: 0.5px;
  }

  .ai-testimonial-carousel__role-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.7) !important;
    text-transform: uppercase;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-testimonial-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 50px;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }} {
    display: none !important;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: #ffffff;
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px #000000;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .ai-testimonial-carousel__button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-testimonial-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 989px) {
    .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - 12px);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-testimonial-carousel__track-{{ ai_gen_id }} {
      gap: 16px;
    }

    .ai-testimonial-carousel__card-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-testimonial-carousel__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-testimonial-carousel__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<testimonial-carousel-{{ ai_gen_id }}
  class="ai-testimonial-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-testimonial-carousel__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-testimonial-carousel__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-testimonial-carousel__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonial-carousel__track-wrapper-{{ ai_gen_id }}">
      <div class="ai-testimonial-carousel__track-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign testimonial_enabled_key = 'testimonial_' | append: i | append: '_enabled'
            assign testimonial_image_key = 'testimonial_' | append: i | append: '_image'
            assign testimonial_name_key = 'testimonial_' | append: i | append: '_name'
            assign testimonial_role_key = 'testimonial_' | append: i | append: '_role'
            assign testimonial_quote_key = 'testimonial_' | append: i | append: '_quote'
            assign testimonial_rating_key = 'testimonial_' | append: i | append: '_rating'

            assign testimonial_enabled = block.settings[testimonial_enabled_key]
            assign testimonial_image = block.settings[testimonial_image_key]
            assign testimonial_name = block.settings[testimonial_name_key]
            assign testimonial_role = block.settings[testimonial_role_key]
            assign testimonial_quote = block.settings[testimonial_quote_key]
            assign testimonial_rating = block.settings[testimonial_rating_key]

            assign clean_quote = testimonial_quote
            if clean_quote contains 'Ã' or clean_quote contains 'â' or clean_quote contains 'Æ' or clean_quote contains '¢' or clean_quote contains '€'
              if i == 1
                assign clean_quote = "<b>Taakat is a  Perfect Hunger  Buddy</b> <br>Taakat Hunger Bar actually delivers. Super filling, and there's no guilt because its so clean."
              elsif i == 2
                assign clean_quote = "<b>Finally, a bar that keeps its promises </b><br>I couldn't believe when I first heard about it, but wow Taakat really walks the talk. Multigrain crunch is really good. Loved the taste too."
              elsif i == 3
                assign clean_quote = "<b>Real Ingredients, Full Satisfaction</b><br>The ingredient list reads like a homemade snack. It's rare to find a bar with no palm oil and no refined sugar that still tastes this good. Strongly recommended for anyone trying to snack smarter."
              elsif i == 4
                assign clean_quote = "<b>Ideal for Busy Work Days </b><br>It's honestly a lifesaver for professionals like me because we keep missing small meals due to meetings and deadlines. So easy to carry and the price points are just unbelievable"
              elsif i == 5
                assign clean_quote = "<b>My commute snack savior</b> <br>I travel for 2 hours almost daily using metros. I use to often wonder when hungry during commute what can I have that's healthier because at the stations you get only crap. But taakat is a game changer. It is not only nutritious but so filling that I could travel for hours"
              elsif i == 6
                assign clean_quote = "<b>Tastes legit, keeps hunger quiet</b><br>This bar is not a lip service. It is no fancy lable product. It's genuinely healthy. Multigrain protein, No palm oil, no nonsense. The flavors are fantastic. My favorite one is Chocolate wala"
              endif
            endif
          %}

          {% if testimonial_enabled %}
            <div class="ai-testimonial-carousel__slide-{{ ai_gen_id }}">
              <div class="ai-testimonial-carousel__card-{{ ai_gen_id }}">
                <div class="ai-testimonial-carousel__stars-{{ ai_gen_id }}">
                  {% for star in (1..testimonial_rating) %}
                    <svg
                      class="ai-testimonial-carousel__star-{{ ai_gen_id }}"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  {% endfor %}
                </div>

                <p class="ai-testimonial-carousel__quote-{{ ai_gen_id }}">{{ clean_quote }}</p>

                <div class="ai-testimonial-carousel__author-{{ ai_gen_id }}">
                  <div class="ai-testimonial-carousel__image-wrapper-{{ ai_gen_id }}">
                    {% if testimonial_image %}
                      <img
                        src="{{ testimonial_image | image_url: width: 120 }}"
                        alt="{{ testimonial_name | escape }}"
                        class="ai-testimonial-carousel__image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="120"
                        height="120"
                      >
                    {% else %}
                      <div class="ai-testimonial-carousel__image-placeholder-{{ ai_gen_id }}">
                        {{ 'image' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-testimonial-carousel__author-info-{{ ai_gen_id }}">
                    <p class="ai-testimonial-carousel__name-{{ ai_gen_id }}">{{ testimonial_name }}</p>
                    <p class="ai-testimonial-carousel__role-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="#008a00" style="display:inline-block; vertical-align:middle; margin-right:4px;">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                      </svg>
                      {{ testimonial_role }}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-testimonial-carousel__controls-{{ ai_gen_id }}">
      <button
        class="ai-testimonial-carousel__button-{{ ai_gen_id }} ai-testimonial-carousel__prev-{{ ai_gen_id }}"
        aria-label="Previous testimonials"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-testimonial-carousel__dots-{{ ai_gen_id }}"></div>

      <button
        class="ai-testimonial-carousel__button-{{ ai_gen_id }} ai-testimonial-carousel__next-{{ ai_gen_id }}"
        aria-label="Next testimonials"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</testimonial-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = 3;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-testimonial-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-testimonial-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-testimonial-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-testimonial-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-testimonial-carousel__dots-{{ ai_gen_id }}');

        this.updateSlidesPerView();
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();
        this.setupDragging();

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.createDots();
          this.updateCarousel();
        });
      }

      updateSlidesPerView() {
        if (window.innerWidth <= 749) {
          this.slidesPerView = 1;
        } else if (window.innerWidth <= 989) {
          this.slidesPerView = 2;
        } else {
          this.slidesPerView = 3;
        }
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        const totalSlides = this.slides.length;
        const totalDots = Math.ceil(totalSlides / this.slidesPerView);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-testimonial-carousel__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === 0) {
            dot.classList.add('active');
          }
          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.currentIndex = Math.max(0, this.currentIndex - 1);
            this.updateCarousel();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            const maxIndex = Math.ceil(this.slides.length / this.slidesPerView) - 1;
            this.currentIndex = Math.min(maxIndex, this.currentIndex + 1);
            this.updateCarousel();
          });
        }
      }

      setupDragging() {
        let isDragging = false;
        let startX = 0;
        let currentTranslate = 0;
        let prevTranslate = 0;

        const getPositionX = (event) => {
          return event.type.includes('mouse') ? event.clientX : event.touches[0].clientX;
        };

        const dragStart = (event) => {
          isDragging = true;
          startX = getPositionX(event);
          this.track.style.transition = 'none';
          
          const slideWidth = this.slides[0].offsetWidth;
          const gap = 24;
          prevTranslate = -this.currentIndex * (slideWidth + gap) * this.slidesPerView;
          
          if (event.type !== 'touchstart') {
            event.preventDefault();
          }
        };

        const dragMove = (event) => {
          if (!isDragging) return;
          const currentX = getPositionX(event);
          const diffX = currentX - startX;
          currentTranslate = prevTranslate + diffX;
          this.track.style.transform = `translateX(${currentTranslate}px)`;
        };

        const dragEnd = () => {
          if (!isDragging) return;
          isDragging = false;
          this.track.style.transition = 'transform 0.5s ease';
          
          const movedBy = currentTranslate - prevTranslate;
          const threshold = 80; // pixels to trigger slide change
          
          const maxIndex = Math.ceil(this.slides.length / this.slidesPerView) - 1;
          if (movedBy < -threshold && this.currentIndex < maxIndex) {
            this.currentIndex += 1;
          } else if (movedBy > threshold && this.currentIndex > 0) {
            this.currentIndex -= 1;
          }
          
          this.updateCarousel();
        };

        // Touch events
        this.track.addEventListener('touchstart', dragStart, { passive: true });
        this.track.addEventListener('touchmove', dragMove, { passive: true });
        this.track.addEventListener('touchend', dragEnd);

        // Mouse events
        this.track.addEventListener('mousedown', dragStart);
        this.track.addEventListener('mousemove', dragMove);
        this.track.addEventListener('mouseup', dragEnd);
        this.track.addEventListener('mouseleave', dragEnd);
        
        // Prevent image dragging inside cards
        this.track.querySelectorAll('img').forEach(img => {
          img.addEventListener('dragstart', (e) => e.preventDefault());
        });
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = 24;
        const offset = this.currentIndex * (slideWidth + gap) * this.slidesPerView;

        this.track.style.transform = 'translateX(-' + offset + 'px)';

        const maxIndex = Math.ceil(this.slides.length / this.slidesPerView) - 1;
        if (this.prevButton) this.prevButton.disabled = this.currentIndex === 0;
        if (this.nextButton) this.nextButton.disabled = this.currentIndex === maxIndex;

        const dots = this.dotsContainer.querySelectorAll('.ai-testimonial-carousel__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('testimonial-carousel-{{ ai_gen_id }}', TestimonialCarousel{{ ai_gen_id }});
  })();
</script>

