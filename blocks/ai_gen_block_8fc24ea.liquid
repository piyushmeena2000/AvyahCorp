{% doc %}
  @prompt
    create latest blogs section with carousel for healthy eating with full width section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-carousel-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-blog-carousel-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-blog-carousel-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-blog-carousel-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
  }

  .ai-blog-carousel-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    padding: 0 60px;
  }

  .ai-blog-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-blog-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
    min-width: 0;
  }

  .ai-blog-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-blog-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-blog-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-blog-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .ai-blog-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-card-content-{{ ai_gen_id }} {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-blog-card-date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-blog-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .ai-blog-card-title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-blog-card-title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-card-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 16px;
    flex-grow: 1;
  }

  .ai-blog-card-link-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 14px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .ai-blog-card-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background-color: {{ block.settings.nav_button_background }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }}:disabled:hover {
    transform: translateY(-50%) scale(1);
  }

  .ai-blog-carousel-nav-prev-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-blog-carousel-nav-next-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.nav_button_icon_color }};
  }

  .ai-blog-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
  }

  .ai-blog-carousel-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-blog-carousel-dot-{{ ai_gen_id }}:hover {
    transform: scale(1.2);
  }

  .ai-blog-carousel-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-blog-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-blog-empty-state-{{ ai_gen_id }} h3 {
    font-size: 20px;
    margin-bottom: 8px;
  }

  .ai-blog-empty-state-{{ ai_gen_id }} p {
    font-size: 14px;
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-blog-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }

    .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
      padding: 0 50px;
    }

    .ai-blog-carousel-nav-{{ ai_gen_id }} {
      width: 36px;
      height: 36px;
    }

    .ai-blog-carousel-nav-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blog-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
      padding: 0 40px;
    }

    .ai-blog-carousel-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-blog-carousel-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-blog-card-content-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<blog-carousel-{{ ai_gen_id }} class="ai-blog-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-blog-carousel-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-blog-carousel-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-blog-carousel-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.blog != blank and block.settings.blog.articles_count > 0 %}
      <div class="ai-blog-carousel-wrapper-{{ ai_gen_id }}">
        <button
          class="ai-blog-carousel-nav-{{ ai_gen_id }} ai-blog-carousel-nav-prev-{{ ai_gen_id }}"
          aria-label="Previous slide"
          data-direction="prev"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
          </svg>
        </button>

        <div class="ai-blog-carousel-track-{{ ai_gen_id }}" data-track>
          {% for article in block.settings.blog.articles limit: block.settings.articles_to_show %}
            <div class="ai-blog-carousel-slide-{{ ai_gen_id }}">
              <article class="ai-blog-card-{{ ai_gen_id }}">
                <a href="{{ article.url }}" class="ai-blog-card-image-wrapper-{{ ai_gen_id }}">
                  {% if article.image %}
                    <img
                      src="{{ article.image | image_url: width: 800 }}"
                      alt="{{ article.image.alt | escape }}"
                      class="ai-blog-card-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="800"
                      height="533"
                    >
                  {% else %}
                    <div class="ai-blog-card-image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </a>

                <div class="ai-blog-card-content-{{ ai_gen_id }}">
                  {% if block.settings.show_date %}
                    <div class="ai-blog-card-date-{{ ai_gen_id }}">
                      {{ article.published_at | date: '%B %d, %Y' }}
                    </div>
                  {% endif %}

                  <h3 class="ai-blog-card-title-{{ ai_gen_id }}">
                    <a href="{{ article.url }}" class="ai-blog-card-title-link-{{ ai_gen_id }}">
                      {{ article.title }}
                    </a>
                  </h3>

                  {% if block.settings.show_excerpt and article.excerpt != blank %}
                    <div class="ai-blog-card-excerpt-{{ ai_gen_id }}">
                      {{ article.excerpt | strip_html | truncate: 120 }}
                    </div>
                  {% endif %}

                  <a href="{{ article.url }}" class="ai-blog-card-link-{{ ai_gen_id }}">
                    {{ block.settings.read_more_text }}
                  </a>
                </div>
              </article>
            </div>
          {% endfor %}
        </div>

        <button
          class="ai-blog-carousel-nav-{{ ai_gen_id }} ai-blog-carousel-nav-next-{{ ai_gen_id }}"
          aria-label="Next slide"
          data-direction="next"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
          </svg>
        </button>
      </div>

      {% if block.settings.show_dots %}
        <div class="ai-blog-carousel-dots-{{ ai_gen_id }}" data-dots></div>
      {% endif %}
    {% else %}
      <div class="ai-blog-empty-state-{{ ai_gen_id }}">
        <h3>No blog selected</h3>
        <p>Select a blog from the block settings to display articles</p>
      </div>
    {% endif %}
  </div>
</blog-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = 3;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.slides = this.querySelectorAll('.ai-blog-carousel-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-direction="prev"]');
        this.nextButton = this.querySelector('[data-direction="next"]');
        this.dotsContainer = this.querySelector('[data-dots]');

        if (!this.track || this.slides.length === 0) return;

        this.updateSlidesPerView();
        this.setupEventListeners();
        this.createDots();
        this.updateCarousel();

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.createDots();
          this.updateCarousel();
        });
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = 1;
        } else if (width <= 989) {
          this.slidesPerView = 2;
        } else {
          this.slidesPerView = 3;
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.navigate('prev'));
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.navigate('next'));
        }
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.dotsContainer.innerHTML = '';
        const totalDots = Math.ceil(this.slides.length / this.slidesPerView);

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-blog-carousel-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          dot.addEventListener('click', () => {
            this.currentIndex = i * this.slidesPerView;
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      navigate(direction) {
        if (direction === 'next') {
          this.currentIndex = Math.min(
            this.currentIndex + this.slidesPerView,
            this.slides.length - this.slidesPerView
          );
        } else {
          this.currentIndex = Math.max(this.currentIndex - this.slidesPerView, 0);
        }
        this.updateCarousel();
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));

        this.track.style.transform = 'translateX(' + offset + 'px)';

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.slides.length - this.slidesPerView;
        }

        this.updateDots();
      }

      updateDots() {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-blog-carousel-dot-{{ ai_gen_id }}');
        const activeDotIndex = Math.floor(this.currentIndex / this.slidesPerView);

        dots.forEach(function(dot, index) {
          if (index === activeDotIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('blog-carousel-{{ ai_gen_id }}', BlogCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Latest blogs carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
