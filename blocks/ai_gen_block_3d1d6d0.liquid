{% doc %}
  @prompt
    full width youtube video with autoplay option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-youtube-video-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    overflow: hidden;
    background-color: #000000;
  }

  .ai-youtube-video-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .ai-youtube-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
    color: #666666;
    font-size: 14px;
  }
{% endstyle %}

<div class="ai-youtube-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.video_url != blank %}
    {% liquid
      assign video_id = ''
      
      if block.settings.video_url contains 'youtube.com/watch?v='
        assign video_id = block.settings.video_url | split: 'watch?v=' | last | split: '&' | first
      elsif block.settings.video_url contains 'youtu.be/'
        assign video_id = block.settings.video_url | split: 'youtu.be/' | last | split: '?' | first
      elsif block.settings.video_url contains 'youtube.com/embed/'
        assign video_id = block.settings.video_url | split: 'embed/' | last | split: '?' | first
      endif

      assign autoplay_param = ''
      if block.settings.autoplay
        assign autoplay_param = '&autoplay=1&mute=1'
      endif

      assign loop_param = ''
      if block.settings.loop
        assign loop_param = '&loop=1&playlist=' | append: video_id
      endif

      assign controls_param = ''
      if block.settings.show_controls == false
        assign controls_param = '&controls=0'
      endif
    %}

    {% if video_id != blank %}
      <iframe
        src="https://www.youtube.com/embed/{{ video_id }}?rel=0{{ autoplay_param }}{{ loop_param }}{{ controls_param }}"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
        title="{{ block.settings.video_title | escape }}"
      ></iframe>
    {% else %}
      <div class="ai-youtube-video-placeholder-{{ ai_gen_id }}">
        Invalid YouTube URL. Please enter a valid YouTube video link.
      </div>
    {% endif %}
  {% else %}
    <div class="ai-youtube-video-placeholder-{{ ai_gen_id }}">
      Next, add a YouTube video URL
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "YouTube video",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube video URL",
      "info": "Paste the full YouTube video URL (e.g., https://www.youtube.com/watch?v=VIDEO_ID)"
    },
    {
      "type": "text",
      "id": "video_title",
      "label": "Video title",
      "default": "YouTube video"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false,
      "info": "Video will be muted when autoplay is enabled"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "YouTube video"
    }
  ]
}
{% endschema %}
