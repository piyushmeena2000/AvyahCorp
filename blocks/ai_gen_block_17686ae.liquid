{% doc %}
  @prompt
    make a rounded rectangle in which at the top left there is logo then headline then subheadline make sure to give enought padding around it, make it in the size where i can put 4 card inline and make the rectangle opacity to 30% , bro make the 4 card like the product one are , good just do one thing only apply the opacity to the card's background the text and icon in the card should be at 100% opacity
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-card-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-card-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 90%;
    height: 40vh;
    padding-left:15%;
  }

  .ai-card-grid__item-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    overflow: hidden;
  }

  .ai-card-grid__item-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.card_background_color }};
    opacity: {{ block.settings.card_opacity | divided_by: 100.0 }};
    z-index: -1;
  }

  .ai-card-grid__logo-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .ai-card-grid__logo-{{ ai_gen_id }} {
    max-width: {{ block.settings.logo_max_width }}px;
    height: auto;
    display: block;
  }

  .ai-card-grid__logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_max_width }}px;
    height: 60px;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-card-grid__logo-placeholder-{{ ai_gen_id }} svg {
    width: 40px;
    height: 40px;
    opacity: 0.3;
  }

  .ai-card-grid__headline-{{ ai_gen_id }} {
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_size }}px;
    margin: 0;
    line-height: 1.2;
    position: relative;
    z-index: 1;
  }

  .ai-card-grid__subheadline-{{ ai_gen_id }} {
    color: {{ block.settings.subheadline_color }};
    font-size: {{ block.settings.subheadline_size }}px;
    margin: 0;
    line-height: 1.4;
    position: relative;
    z-index: 1;
  }

  @media screen and (max-width: 989px) {
    .ai-card-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-card-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-card-grid__item-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-card-grid__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-card-grid__subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<card-grid-{{ ai_gen_id }}
  class="ai-card-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-card-grid__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign logo_key = 'card_' | append: i | append: '_logo'
        assign headline_key = 'card_' | append: i | append: '_headline'
        assign subheadline_key = 'card_' | append: i | append: '_subheadline'
        
        assign card_logo = block.settings[logo_key]
        assign card_headline = block.settings[headline_key]
        assign card_subheadline = block.settings[subheadline_key]
      %}
      
      <div class="ai-card-grid__item-{{ ai_gen_id }}">
        <div class="ai-card-grid__logo-wrapper-{{ ai_gen_id }}">
          {% if card_logo %}
            <img
              src="{{ card_logo | image_url: width: 400 }}"
              alt="{{ card_logo.alt | escape }}"
              class="ai-card-grid__logo-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ card_logo.width }}"
              height="{{ card_logo.height }}"
            >
          {% else %}
            <div class="ai-card-grid__logo-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        {% if card_headline != blank %}
          <h3 class="ai-card-grid__headline-{{ ai_gen_id }}">
            {{ card_headline }}
          </h3>
        {% endif %}

        {% if card_subheadline != blank %}
          <p class="ai-card-grid__subheadline-{{ ai_gen_id }}">
            {{ card_subheadline }}
          </p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</card-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CardGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('card-grid-{{ ai_gen_id }}', CardGrid{{ ai_gen_id }});
  })();
</script>

