{% doc %}
  @prompt
    full width youtube video embedd with autoplay
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-youtube-embed-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    overflow: hidden;
    background-color: #000000;
  }

  .ai-youtube-embed-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
{% endstyle %}

<div class="ai-youtube-embed-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.video_url != blank %}
    {% assign video_id = '' %}
    {% if block.settings.video_url contains 'youtube.com/watch?v=' %}
      {% assign video_id = block.settings.video_url | split: 'watch?v=' | last | split: '&' | first %}
    {% elsif block.settings.video_url contains 'youtu.be/' %}
      {% assign video_id = block.settings.video_url | split: 'youtu.be/' | last | split: '?' | first %}
    {% elsif block.settings.video_url contains 'youtube.com/embed/' %}
      {% assign video_id = block.settings.video_url | split: 'embed/' | last | split: '?' | first %}
    {% endif %}

    {% if video_id != blank %}
      {% assign autoplay_param = '' %}
      {% if block.settings.autoplay %}
        {% assign autoplay_param = '&autoplay=1&mute=1' %}
      {% endif %}

      {% assign loop_param = '' %}
      {% if block.settings.loop %}
        {% assign loop_param = '&loop=1&playlist=' | append: video_id %}
      {% endif %}

      {% assign controls_param = '' %}
      {% if block.settings.hide_controls %}
        {% assign controls_param = '&controls=0' %}
      {% else %}
        {% assign controls_param = '&controls=1' %}
      {% endif %}

      <iframe
        src="https://www.youtube.com/embed/{{ video_id }}?rel=0{{ autoplay_param }}{{ loop_param }}{{ controls_param }}"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    {% else %}
      <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #ffffff; font-size: 14px; text-align: center; padding: 20px;">
        Invalid YouTube URL. Please enter a valid YouTube video link.
      </div>
    {% endif %}
  {% else %}
    <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #ffffff; font-size: 14px; text-align: center; padding: 20px;">
      Next, add a YouTube video URL
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "YouTube video embed",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube video URL",
      "info": "Paste the full YouTube video URL (e.g., https://www.youtube.com/watch?v=VIDEO_ID)"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": true,
      "info": "Video will be muted when autoplay is enabled"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_controls",
      "label": "Hide video controls",
      "default": false
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "56.25",
          "label": "16:9"
        },
        {
          "value": "75",
          "label": "4:3"
        },
        {
          "value": "100",
          "label": "1:1"
        },
        {
          "value": "125",
          "label": "4:5"
        }
      ],
      "default": "56.25"
    }
  ],
  "presets": [
    {
      "name": "YouTube video embed"
    }
  ]
}
{% endschema %}
