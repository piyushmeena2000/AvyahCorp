{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-reel-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.section_padding }}px 0;
    display: block;
  }

  .ai-video-reel-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
  }

  .ai-video-reel-track-wrapper-{{ ai_gen_id }} {
    position: relative;
    cursor: grab;
    user-select: none;
  }

  .ai-video-reel-track-wrapper-{{ ai_gen_id }}:active {
    cursor: grabbing;
  }

  .ai-video-reel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.video_gap }}px;
    will-change: transform;
  }

  .ai-video-reel-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.video_width }}px;
    height: {{ block.settings.video_height }}px;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-video-reel-item-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-video-reel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-reel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-video-reel-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(0, 0, 0, 0.7);
    color: #ffffff;
    font-size: 12px;
    border-radius: 4px;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-video-reel-item-{{ ai_gen_id }} {
      width: {{ block.settings.video_width | times: 0.7 }}px;
      height: {{ block.settings.video_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<video-reel-{{ ai_gen_id }}
  class="ai-video-reel-{{ ai_gen_id }}"
  data-speed="{{ block.settings.scroll_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-reel-container-{{ ai_gen_id }}">
    <div class="ai-video-reel-track-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-reel-track-{{ ai_gen_id }}">
        {% for i in (1..15) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign video = block.settings[video_key]
          %}

          <div class="ai-video-reel-item-{{ ai_gen_id }}">
            {% if video != blank %}
              <video
                src="{{ video.sources[1].url }}"
                playsinline
                muted
                loop
                autoplay
                preload="metadata"
              ></video>
            {% else %}
              <div class="ai-video-reel-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
                <div class="ai-video-reel-empty-state-{{ ai_gen_id }}">
                  Add video {{ i }}
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}

        {% for i in (1..15) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign video = block.settings[video_key]
          %}

          <div class="ai-video-reel-item-{{ ai_gen_id }}">
            {% if video != blank %}
              <video
                src="{{ video.sources[1].url }}"
                playsinline
                muted
                loop
                autoplay
                preload="metadata"
              ></video>
            {% else %}
              <div class="ai-video-reel-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
                <div class="ai-video-reel-empty-state-{{ ai_gen_id }}">
                  Add video {{ i }}
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</video-reel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoReel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.trackWrapper = null;
        this.track = null;
        this.isDragging = false;
        this.startX = 0;
        this.scrollLeft = 0;
        this.animationId = null;
        this.currentTranslate = 0;
        this.speed = 0;
      }

      connectedCallback() {
        this.trackWrapper = this.querySelector('.ai-video-reel-track-wrapper-{{ ai_gen_id }}');
        this.track = this.querySelector('.ai-video-reel-track-{{ ai_gen_id }}');
        this.speed = parseFloat(this.dataset.speed) || 0.5;

        this.setupDragScroll();
        this.startAutoScroll();
      }

      disconnectedCallback() {
        this.stopAutoScroll();
      }

      setupDragScroll() {
        this.trackWrapper.addEventListener('mousedown', this.handleDragStart.bind(this));
        this.trackWrapper.addEventListener('touchstart', this.handleDragStart.bind(this), { passive: true });
        
        document.addEventListener('mousemove', this.handleDragMove.bind(this));
        document.addEventListener('touchmove', this.handleDragMove.bind(this), { passive: true });
        
        document.addEventListener('mouseup', this.handleDragEnd.bind(this));
        document.addEventListener('touchend', this.handleDragEnd.bind(this));
      }

      handleDragStart(e) {
        this.isDragging = true;
        this.stopAutoScroll();
        
        const clientX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
        this.startX = clientX;
        this.scrollLeft = this.currentTranslate;
      }

      handleDragMove(e) {
        if (!this.isDragging) return;
        
        const clientX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
        const diff = clientX - this.startX;
        this.currentTranslate = this.scrollLeft + diff;
        this.updateTrackPosition();
      }

      handleDragEnd() {
        if (!this.isDragging) return;
        this.isDragging = false;
        this.startAutoScroll();
      }

      startAutoScroll() {
        const animate = () => {
          if (!this.isDragging) {
            this.currentTranslate -= this.speed;
            
            const trackWidth = this.track.scrollWidth / 2;
            
            if (Math.abs(this.currentTranslate) >= trackWidth) {
              this.currentTranslate = 0;
            }
            
            this.updateTrackPosition();
          }
          
          this.animationId = requestAnimationFrame(animate);
        };
        
        this.animationId = requestAnimationFrame(animate);
      }

      stopAutoScroll() {
        if (this.animationId) {
          cancelAnimationFrame(this.animationId);
          this.animationId = null;
        }
      }

      updateTrackPosition() {
        this.track.style.transform = `translateX(${this.currentTranslate}px)`;
      }
    }

    customElements.define('video-reel-{{ ai_gen_id }}', VideoReel{{ ai_gen_id }});
  })();
</script>

