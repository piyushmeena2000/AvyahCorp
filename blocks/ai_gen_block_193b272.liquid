{% doc %}
  @prompt
    Add carousel slider with only images for logos, add 2 more images
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-carousel-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: #d52528 !important; /* Brand Crimson Red background */
  }

  .ai-logo-carousel__container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-logo-carousel__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: #ffffff !important; /* White heading text color */
    font-size: {{ block.settings.heading_size }}px;
    font-family: 'Anton', sans-serif !important;
    text-transform: uppercase !important;
  }

  .ai-logo-carousel__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-logo-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    width: max-content;
  }

  .ai-logo-carousel__slide-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: auto !important;
    min-width: 140px !important;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 24px !important;
    background-color: #ffffff !important; /* White pill badge for logo clarity */
    border-radius: 14px !important;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15) !important;
    border: none !important;
  }

  .ai-logo-carousel__image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    {% if block.settings.grayscale %}
      filter: grayscale(100%);
      transition: filter 0.3s ease;
    {% endif %}
  }

  {% if block.settings.grayscale %}
    .ai-logo-carousel__slide-{{ ai_gen_id }}:hover .ai-logo-carousel__image-{{ ai_gen_id }} {
      filter: grayscale(0%);
    }
  {% endif %}

  .ai-logo-carousel__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
    border-radius: {{ block.settings.logo_border_radius }}px;
  }

  .ai-logo-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-carousel__slide-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.8 }}px;
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }

    .ai-logo-carousel__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<logo-carousel-{{ ai_gen_id }} class="ai-logo-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-logo-carousel__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-logo-carousel__track-wrapper-{{ ai_gen_id }}">
      <div class="ai-logo-carousel__track-{{ ai_gen_id }}" data-carousel-track>
        {% for i in (1..9) %}
          {% liquid
            assign logo_key = 'logo_' | append: i
            assign logo = block.settings[logo_key]
          %}

          {% if logo != blank %}
            <div class="ai-logo-carousel__slide-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="{{ logo.width }}"
                height="{{ logo.height }}"
                class="ai-logo-carousel__image-{{ ai_gen_id }}"
              >
            </div>
          {% else %}
            <div class="ai-logo-carousel__slide-{{ ai_gen_id }}">
              <div class="ai-logo-carousel__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endif %}
        {% endfor %}

        {% for i in (1..9) %}
          {% liquid
            assign logo_key = 'logo_' | append: i
            assign logo = block.settings[logo_key]
          %}

          {% if logo != blank %}
            <div class="ai-logo-carousel__slide-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="{{ logo.width }}"
                height="{{ logo.height }}"
                class="ai-logo-carousel__image-{{ ai_gen_id }}"
              >
            </div>
          {% else %}
            <div class="ai-logo-carousel__slide-{{ ai_gen_id }}">
              <div class="ai-logo-carousel__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</logo-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.animationId = null;
        this.speed = {{ block.settings.scroll_speed }};
        this.position = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-carousel-track]');
        if (!this.track) return;

        this.startAutoScroll();

        this.track.addEventListener('mouseenter', () => this.pauseAutoScroll());
        this.track.addEventListener('mouseleave', () => this.startAutoScroll());
      }

      disconnectedCallback() {
        this.pauseAutoScroll();
      }

      startAutoScroll() {
        if (this.animationId) return;

        const animate = () => {
          this.position -= this.speed;

          const slideWidth = this.track.firstElementChild.offsetWidth;
          const gap = {{ block.settings.logo_spacing }};
          const totalSlides = this.track.children.length / 2;
          const resetPoint = -(slideWidth + gap) * totalSlides;

          if (this.position <= resetPoint) {
            this.position = 0;
          }

          this.track.style.transform = `translateX(${this.position}px)`;
          this.animationId = requestAnimationFrame(animate);
        };

        this.animationId = requestAnimationFrame(animate);
      }

      pauseAutoScroll() {
        if (this.animationId) {
          cancelAnimationFrame(this.animationId);
          this.animationId = null;
        }
      }
    }

    customElements.define('logo-carousel-{{ ai_gen_id }}', LogoCarousel{{ ai_gen_id }});
  })();
</script>

