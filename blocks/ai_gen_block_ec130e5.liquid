{% doc %}
  @prompt
    a want a video player with rounded corners and the video has a play icon in the middle and when user click on it the video should start playing i want a responsive for both mobile and desktop , i will upload the video from the shopify itself i dont want link past
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-player-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-video-player-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-player-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-player-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-player-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-video-player-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-player-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.play_button_size }}px;
    height: {{ block.settings.play_button_size }}px;
    background-color: {{ block.settings.play_button_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
    z-index: 2;
    opacity: {{ block.settings.play_button_opacity | divided_by: 100.0 }};
  }

  .ai-video-player-play-button-{{ ai_gen_id }}:hover {
    transform: translate(-50%, -50%) scale(1.1);
    opacity: 1;
  }

  .ai-video-player-play-button-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-player-play-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.play_button_size }}px * 0.4);
    height: calc({{ block.settings.play_button_size }}px * 0.4);
    margin-left: calc({{ block.settings.play_button_size }}px * 0.05);
    fill: {{ block.settings.play_icon_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-player-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-video-player-play-button-{{ ai_gen_id }} {
      width: calc({{ block.settings.play_button_size }}px * 0.8);
      height: calc({{ block.settings.play_button_size }}px * 0.8);
    }

    .ai-video-player-play-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.play_button_size }}px * 0.32);
      height: calc({{ block.settings.play_button_size }}px * 0.32);
      margin-left: calc({{ block.settings.play_button_size }}px * 0.04);
    }
  }
{% endstyle %}

<video-player-{{ ai_gen_id }}
  class="ai-video-player-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-player-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video != blank %}
      <video
        class="ai-video-player-video-{{ ai_gen_id }}"
        {% if block.settings.show_controls %}controls{% endif %}
        {% if block.settings.loop_video %}loop{% endif %}
        {% if block.settings.mute_video %}muted{% endif %}
        playsinline
        preload="metadata"
      >
        {% for source in block.settings.video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
      <button
        class="ai-video-player-play-button-{{ ai_gen_id }}"
        aria-label="Play video"
      >
        <svg
          class="ai-video-player-play-icon-{{ ai_gen_id }}"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M8 5v14l11-7z"/>
        </svg>
      </button>
    {% else %}
      <div class="ai-video-player-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-video-player-empty-state-{{ ai_gen_id }}">
          Next, add a video
        </div>
      </div>
    {% endif %}
  </div>
</video-player-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoPlayer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-video-player-video-{{ ai_gen_id }}');
        this.playButton = this.querySelector('.ai-video-player-play-button-{{ ai_gen_id }}');

        if (this.video && this.playButton) {
          this.setupEventListeners();
        }
      }

      setupEventListeners() {
        this.playButton.addEventListener('click', () => {
          this.playVideo();
        });

        this.video.addEventListener('play', () => {
          this.playButton.classList.add('hidden');
        });

        this.video.addEventListener('pause', () => {
          this.playButton.classList.remove('hidden');
        });

        this.video.addEventListener('ended', () => {
          this.playButton.classList.remove('hidden');
        });

        this.video.addEventListener('click', () => {
          if (this.video.paused) {
            this.playVideo();
          } else {
            this.pauseVideo();
          }
        });
      }

      playVideo() {
        if (this.video.paused) {
          this.video.play();
        }
      }

      pauseVideo() {
        if (!this.video.paused) {
          this.video.pause();
        }
      }
    }

    customElements.define('video-player-{{ ai_gen_id }}', VideoPlayer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video player",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "mute_video",
      "label": "Mute video",
      "default": false
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Play button"
    },
    {
      "type": "range",
      "id": "play_button_size",
      "label": "Size",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "play_button_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "default": 90
    },
    {
      "type": "color",
      "id": "play_button_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "play_icon_color",
      "label": "Icon color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Video player"
    }
  ]
}
{% endschema %}
