{% doc %}
  @prompt
    create owl carousel with full width for featured products, Add to cart button is missing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-carousel-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-carousel-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
  }

  .ai-carousel-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.slides_desktop | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.slides_desktop }});
    min-width: 0;
  }

  .ai-product-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-info-{{ ai_gen_id }} {
    padding: 10px 16px 16px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    background: #FFFEEE;


  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 400;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    line-height: 1.4;
  }

  .ai-product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
    font-family: 'alata' !important;
    font-weight: 600;
  }

  .ai-product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.product_title_hover_color }};
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: 15px;
    font-weight: 400;
    color: {{ block.settings.price_color }};
    margin-bottom: 12px;
  }

  .ai-product-price-compare-{{ ai_gen_id }} {
    font-size: 14px;
    color: #999;
    text-decoration: line-through;
    margin-left: 8px;
  }

  .ai-add-to-cart-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 400;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    margin-top: auto;
  }

  .ai-add-to-cart-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-add-to-cart-btn-{{ ai_gen_id }}:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
    transform: none;
  }

  .ai-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background: {{ block.settings.nav_button_background }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.3s ease, transform 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-carousel-nav-{{ ai_gen_id }}:hover {
    background: {{ block.settings.nav_button_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-carousel-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-nav-{{ ai_gen_id }}:disabled:hover {
    transform: translateY(-50%) scale(1);
  }

  .ai-carousel-nav-prev-{{ ai_gen_id }} {
    left: -24px;
  }

  .ai-carousel-nav-next-{{ ai_gen_id }} {
    right: -24px;
  }

  .ai-carousel-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.nav_button_icon_color }};
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    background: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-empty-state-{{ ai_gen_id }} p {
    font-size: 16px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_tablet | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.slides_tablet }});
    }

    .ai-carousel-nav-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-carousel-nav-next-{{ ai_gen_id }} {
      right: 10px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_mobile | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.slides_mobile }});
    }

    .ai-carousel-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-carousel-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-carousel-nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-carousel-nav-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }
  }
{% endstyle %}

<product-carousel-{{ ai_gen_id }} class="ai-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-carousel-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-carousel-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-carousel-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.product_list != blank %}
      <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
        <button
          class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-prev-{{ ai_gen_id }}"
          aria-label="Previous slide"
          data-direction="prev"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <div class="ai-carousel-track-{{ ai_gen_id }}">
          {% for product in block.settings.product_list %}
            <div class="ai-carousel-slide-{{ ai_gen_id }}">
              <div class="ai-product-card-{{ ai_gen_id }}">
                <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
                  <a href="{{ product.url }}">
                    {% if product.featured_image %}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        class="ai-product-image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="600"
                        height="600"
                      >
                    {% else %}
                      <div class="ai-product-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </a>
                </div>
                <div class="ai-product-info-{{ ai_gen_id }}">
                  <h3 class="ai-product-title-{{ ai_gen_id }}">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>
                  <!-- Start of Judge.me code -->
                      <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
                          {{ product.metafields.judgeme.badge }}
                      </div>
                  <!-- End of Judge.me code -->
                  <div class="ai-product-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-product-price-compare-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span> <br>
                      <span style="background:#990000ff;color:#fff;border-radius:10px;padding:2px 8px;font-size:12px;display: inline-block;">
                       
                        {% assign price_difference = product.compare_at_price | minus: product.price %}
                        {% assign percentage_saved = price_difference | times: 100.0 | divided_by: product.compare_at_price | round %}
                        
                        {{ percentage_saved }}% Off
                      </span><br>
                    {% endif %}
                  </div>
                  {% if product.available %}
                    <button
                      class="ai-add-to-cart-btn-{{ ai_gen_id }}"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    >
                      {{ block.settings.button_text }}
                    </button>
                  {% else %}
                    <button class="ai-add-to-cart-btn-{{ ai_gen_id }}" disabled>
                      Sold Out
                    </button>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <button
          class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-next-{{ ai_gen_id }}"
          aria-label="Next slide"
          data-direction="next"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>

      {% if block.settings.show_dots %}
        <div class="ai-carousel-dots-{{ ai_gen_id }}"></div>
      {% endif %}
    {% else %}
      <div class="ai-empty-state-{{ ai_gen_id }}">
        <p>Next, add products to display in the carousel</p>
      </div>
    {% endif %}
  </div>
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = {{ block.settings.slides_desktop }};
        this.autoplayInterval = null;
        this.isTransitioning = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-nav-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-carousel-dots-{{ ai_gen_id }}');

        if (!this.track || this.slides.length === 0) return;

        this.updateSlidesPerView();
        this.setupEventListeners();
        this.setupAddToCartButtons();
        this.createDots();
        this.updateCarousel();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}

        window.addEventListener('resize', this.handleResize.bind(this));
      }

      disconnectedCallback() {
        this.stopAutoplay();
        window.removeEventListener('resize', this.handleResize.bind(this));
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = {{ block.settings.slides_mobile }};
        } else if (width <= 989) {
          this.slidesPerView = {{ block.settings.slides_tablet }};
        } else {
          this.slidesPerView = {{ block.settings.slides_desktop }};
        }
      }

      handleResize() {
        this.updateSlidesPerView();
        this.currentIndex = Math.min(this.currentIndex, this.getMaxIndex());
        this.updateCarousel();
        this.createDots();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.navigate('prev'));
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.navigate('next'));
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      setupAddToCartButtons() {
        const addToCartButtons = this.querySelectorAll('.ai-add-to-cart-btn-{{ ai_gen_id }}:not([disabled])');
        
        addToCartButtons.forEach(button => {
          button.addEventListener('click', async (e) => {
            e.preventDefault();
            const variantId = button.dataset.variantId;
            
            if (!variantId) return;

            const originalText = button.textContent;
            button.textContent = 'Adding...';
            button.disabled = true;

            try {
              const response = await fetch('/cart/add.js', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                  items: [{
                    id: variantId,
                    quantity: 1
                  }]
                })
              });

              if (response.ok) {
                button.textContent = 'Added!';
                
                document.dispatchEvent(new CustomEvent('cart:refresh'));
                
                setTimeout(() => {
                  button.textContent = originalText;
                  button.disabled = false;
                }, 2000);
              } else {
                throw new Error('Failed to add to cart');
              }
            } catch (error) {
              button.textContent = 'Error';
              setTimeout(() => {
                button.textContent = originalText;
                button.disabled = false;
              }, 2000);
            }
          });
        });
      }

      navigate(direction) {
        if (this.isTransitioning) return;

        this.isTransitioning = true;
        const maxIndex = this.getMaxIndex();

        if (direction === 'next') {
          this.currentIndex = Math.min(this.currentIndex + 1, maxIndex);
        } else {
          this.currentIndex = Math.max(this.currentIndex - 1, 0);
        }

        this.updateCarousel();

        setTimeout(() => {
          this.isTransitioning = false;
        }, 500);
      }

      getMaxIndex() {
        return Math.max(0, this.slides.length - this.slidesPerView);
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.getMaxIndex();
        }

        this.updateDots();
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.dotsContainer.innerHTML = '';
        const maxIndex = this.getMaxIndex();
        const totalDots = maxIndex + 1;

        for (let i = 0; i <= maxIndex; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-carousel-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }

        this.updateDots();
      }

      updateDots() {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          if (this.currentIndex >= this.getMaxIndex()) {
            this.currentIndex = 0;
          } else {
            this.currentIndex++;
          }
          this.updateCarousel();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our best sellers"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Products per row (tablet)",
      "default": 3
    },
    {
      "type": "select",
      "id": "slides_mobile",
      "label": "Products per row (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Gap between products",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 60
    },
    {
      "type": "header",
      "content": "Carousel settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Add to cart button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to Cart"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
