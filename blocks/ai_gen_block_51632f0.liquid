{% doc %}
  @prompt
    create latest blogs section with carousel for healthy eating with full width section but card should not be revealed during scroll
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-carousel-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
    overflow: hidden;
  }

  .ai-blog-carousel-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-blog-carousel-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-blog-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .ai-blog-carousel-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    padding: 0 60px;
  }

  .ai-blog-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 10px 0;
  }

  .ai-blog-carousel-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-blog-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / {{ block.settings.cards_per_view }});
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-blog-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical | plus: 4 }}px {{ block.settings.card_shadow_blur | plus: 8 }}px {{ block.settings.card_shadow_color }};
  }

  .ai-blog-card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-blog-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-blog-card-{{ ai_gen_id }}:hover .ai-blog-card-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-blog-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-blog-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-blog-card-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_size }}px;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-blog-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px 0;
    font-weight: 400;
    line-height: 1.3;
  }

  .ai-blog-card-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.excerpt_color }};
    margin: 0 0 16px 0;
    line-height: 1.6;
    flex-grow: 1;
  }

  .ai-blog-card-author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_size }}px;
    color: {{ block.settings.author_color }};
    font-style: italic;
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background-color: {{ block.settings.nav_button_background }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease, transform 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }}:disabled:hover {
    transform: translateY(-50%) scale(1);
  }

  .ai-blog-carousel-nav-prev-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-blog-carousel-nav-next-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.nav_button_icon_color }};
  }

  .ai-blog-carousel-cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
  }

  .ai-blog-carousel-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-blog-carousel-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .ai-blog-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }

    .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
      padding: 0 50px;
    }

    .ai-blog-carousel-nav-{{ ai_gen_id }} {
      width: 36px;
      height: 36px;
    }

    .ai-blog-carousel-nav-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blog-card-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - 20px);
    }

    .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
      padding: 0 40px;
    }

    .ai-blog-carousel-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-blog-carousel-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-blog-card-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<blog-carousel-{{ ai_gen_id }} class="ai-blog-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-carousel-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subtitle != blank %}
      <div class="ai-blog-carousel-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-blog-carousel-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-blog-carousel-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-blog-carousel-wrapper-{{ ai_gen_id }}">
      <button
        class="ai-blog-carousel-nav-{{ ai_gen_id }} ai-blog-carousel-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous"
        data-direction="prev"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-blog-carousel-track-{{ ai_gen_id }}">
        {% if block.settings.blog != blank %}
          {% for article in block.settings.blog.articles limit: block.settings.articles_limit %}
            <a href="{{ article.url }}" class="ai-blog-card-{{ ai_gen_id }}">
              <div class="ai-blog-card-image-wrapper-{{ ai_gen_id }}">
                {% if article.image %}
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    alt="{{ article.image.alt | escape }}"
                    class="ai-blog-card-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="{{ block.settings.image_height }}"
                  >
                {% else %}
                  <div class="ai-blog-card-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-blog-card-content-{{ ai_gen_id }}">
                {% if block.settings.show_date %}
                  <div class="ai-blog-card-date-{{ ai_gen_id }}">
                    {{ article.published_at | date: '%B %d, %Y' }}
                  </div>
                {% endif %}

                <h3 class="ai-blog-card-title-{{ ai_gen_id }}">{{ article.title }}</h3>

                {% if block.settings.show_excerpt and article.excerpt != blank %}
                  <div class="ai-blog-card-excerpt-{{ ai_gen_id }}">
                    {{ article.excerpt | strip_html | truncate: block.settings.excerpt_length }}
                  </div>
                {% endif %}

                {% if block.settings.show_author and article.author != blank %}
                  <div class="ai-blog-card-author-{{ ai_gen_id }}">
                    By {{ article.author }}
                  </div>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        {% else %}
          {% for i in (1..6) %}
            <div class="ai-blog-card-{{ ai_gen_id }}">
              <div class="ai-blog-card-image-wrapper-{{ ai_gen_id }}">
                <div class="ai-blog-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
              <div class="ai-blog-card-content-{{ ai_gen_id }}">
                {% if block.settings.show_date %}
                  <div class="ai-blog-card-date-{{ ai_gen_id }}">January 1, 2024</div>
                {% endif %}
                <h3 class="ai-blog-card-title-{{ ai_gen_id }}">Healthy Eating Tips for a Better Life</h3>
                {% if block.settings.show_excerpt %}
                  <div class="ai-blog-card-excerpt-{{ ai_gen_id }}">
                    Discover the best practices for maintaining a healthy diet and lifestyle.
                  </div>
                {% endif %}
                {% if block.settings.show_author %}
                  <div class="ai-blog-card-author-{{ ai_gen_id }}">By Nutrition Expert</div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      <button
        class="ai-blog-carousel-nav-{{ ai_gen_id }} ai-blog-carousel-nav-next-{{ ai_gen_id }}"
        aria-label="Next"
        data-direction="next"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    {% if block.settings.show_cta_button and block.settings.cta_button_link != blank %}
      <div class="ai-blog-carousel-cta-{{ ai_gen_id }}">
        <a href="{{ block.settings.cta_button_link }}" class="ai-blog-carousel-button-{{ ai_gen_id }}">
          {{ block.settings.cta_button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</blog-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.prevButton = null;
        this.nextButton = null;
        this.scrollAmount = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-blog-carousel-track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-blog-carousel-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-blog-carousel-nav-next-{{ ai_gen_id }}');

        if (!this.track || !this.prevButton || !this.nextButton) return;

        this.setupEventListeners();
        this.updateButtonStates();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.scroll('prev'));
        this.nextButton.addEventListener('click', () => this.scroll('next'));
        this.track.addEventListener('scroll', () => this.updateButtonStates());

        let resizeTimer;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => {
            this.updateButtonStates();
          }, 250);
        });
      }

      scroll(direction) {
        const card = this.track.querySelector('.ai-blog-card-{{ ai_gen_id }}');
        if (!card) return;

        const cardWidth = card.offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const scrollDistance = cardWidth + gap;

        if (direction === 'next') {
          this.track.scrollLeft += scrollDistance;
        } else {
          this.track.scrollLeft -= scrollDistance;
        }
      }

      updateButtonStates() {
        const isAtStart = this.track.scrollLeft <= 0;
        const isAtEnd = this.track.scrollLeft + this.track.clientWidth >= this.track.scrollWidth - 1;

        this.prevButton.disabled = isAtStart;
        this.nextButton.disabled = isAtEnd;
      }
    }

    customElements.define('blog-carousel-{{ ai_gen_id }}', BlogCarousel{{ ai_gen_id }});
  })();
</script>

