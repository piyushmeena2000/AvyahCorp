{% doc %}
  @prompt
    Add ticker with multiple texts and icon images, add 10 text and also make mobile responsive
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ticker-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    position: relative;
  }

  .ai-ticker-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    animation: ai-ticker-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-ticker-{{ ai_gen_id }}:hover .ai-ticker-wrapper-{{ ai_gen_id }} {
    animation-play-state: {% if block.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  .ai-ticker-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: 0 {{ block.settings.item_spacing }}px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-ticker-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ticker-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-ticker-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.text_color }};
    opacity: 0.2;
    border-radius: 50%;
  }

  .ai-ticker-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    font-family: anton;
    text-transform: {{ block.settings.text_transform }};
  }

  @keyframes ai-ticker-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ticker-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical_mobile }}px 0;
    }

    .ai-ticker-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-ticker-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-ticker-item-{{ ai_gen_id }} {
      gap: {{ block.settings.icon_text_gap_mobile }}px;
      padding: 0 {{ block.settings.item_spacing_mobile }}px;
    }
  }
{% endstyle %}

<ticker-component-{{ ai_gen_id }} class="ai-ticker-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ticker-wrapper-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      {% for j in (1..10) %}
        {% liquid
          assign text_key = 'text_' | append: j
          assign icon_key = 'icon_' | append: j
          assign text_value = block.settings[text_key]
          assign icon_value = block.settings[icon_key]
        %}
        
        {% if text_value != blank %}
          <div class="ai-ticker-item-{{ ai_gen_id }}">
            {% if icon_value != blank %}
              <div class="ai-ticker-icon-{{ ai_gen_id }}">
                <img
                  src="{{ icon_value | image_url: width: 100 }}"
                  alt="{{ text_value | escape }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              </div>
            {% endif %}
            <span class="ai-ticker-text-{{ ai_gen_id }}">{{ text_value }}</span>
          </div>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
</ticker-component-{{ ai_gen_id }}>

<script>
  (function() {
    class TickerComponent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustAnimation();
      }

      adjustAnimation() {
        const wrapper = this.querySelector('.ai-ticker-wrapper-{{ ai_gen_id }}');
        if (!wrapper) return;

        const firstItem = wrapper.querySelector('.ai-ticker-item-{{ ai_gen_id }}');
        if (!firstItem) return;

        const itemCount = wrapper.querySelectorAll('.ai-ticker-item-{{ ai_gen_id }}').length / 2;
        
        if (itemCount === 0) return;
      }
    }

    customElements.define('ticker-component-{{ ai_gen_id }}', TickerComponent{{ ai_gen_id }});
  })();
</script>

