{% comment %}
  Retail Store & Fridge Showcase Block
  Inspired by PerfectSnacks design layout.
{% endcomment %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<style>
  .avyah-store-showcase-block-{{ ai_gen_id }} {
    width: 100% !important;
    background-color: #ffffff !important;
    padding: 60px 24px !important;
    box-sizing: border-box !important;
  }

  .avyah-store-showcase-container-{{ ai_gen_id }} {
    max-width: 1240px !important;
    margin: 0 auto !important;
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 50px !important;
    align-items: center !important;
  }

  .avyah-store-showcase-media-{{ ai_gen_id }} {
    width: 100% !important;
    border-radius: 24px !important;
    overflow: hidden !important;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08) !important;
    line-height: 0 !important;
  }

  .avyah-store-showcase-img-{{ ai_gen_id }} {
    width: 100% !important;
    height: 100% !important;
    max-height: 520px !important;
    object-fit: cover !important;
    object-position: center !important;
    display: block !important;
    border-radius: 24px !important;
  }

  .avyah-store-showcase-content-{{ ai_gen_id }} {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
    padding: 10px 0 !important;
  }

  .avyah-store-showcase-headline-{{ ai_gen_id }} {
    font-family: 'Anton', Arial, sans-serif !important;
    font-size: 52px !important;
    font-weight: 400 !important;
    line-height: 1.1 !important;
    color: #2b1e1b !important;
    text-transform: uppercase !important;
    margin: 0 0 20px 0 !important;
    letter-spacing: 0.2px !important;
  }

  .avyah-store-showcase-tagline-{{ ai_gen_id }} {
    font-family: 'Anton', Arial, sans-serif !important;
    font-size: 18px !important;
    font-weight: 400 !important;
    color: #2b1e1b !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    margin-bottom: 16px !important;
  }

  .avyah-store-showcase-body-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif !important;
    font-size: 16px !important;
    line-height: 1.6 !important;
    color: #4a3e3b !important;
    max-width: 480px !important;
    margin: 0 0 32px 0 !important;
  }

  .avyah-store-showcase-actions-{{ ai_gen_id }} {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 20px !important;
    width: 100% !important;
  }

  .avyah-store-primary-btn-{{ ai_gen_id }} {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 16px 36px !important;
    background-color: #0b5e65 !important; /* Dark teal pill button */
    background: #0b5e65 !important;
    color: #ffffff !important;
    -webkit-text-fill-color: #ffffff !important;
    font-family: 'Anton', Arial, sans-serif !important;
    font-size: 18px !important;
    font-weight: 400 !important;
    letter-spacing: 1px !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    border-radius: 50px !important;
    border: none !important;
    transition: transform 0.2s ease, background-color 0.2s ease !important;
    box-shadow: 0 4px 14px rgba(11, 94, 101, 0.25) !important;
  }

  .avyah-store-primary-btn-{{ ai_gen_id }}:hover {
    background-color: #08484e !important;
    background: #08484e !important;
    color: #ffffff !important;
    transform: translateY(-2px) !important;
  }

  .avyah-store-secondary-link-{{ ai_gen_id }} {
    font-family: 'Anton', Arial, sans-serif !important;
    font-size: 17px !important;
    font-weight: 400 !important;
    letter-spacing: 1px !important;
    text-transform: uppercase !important;
    color: #2b1e1b !important;
    text-decoration: underline !important;
    text-underline-offset: 4px !important;
    text-decoration-thickness: 2px !important;
    transition: color 0.2s ease !important;
  }

  .avyah-store-secondary-link-{{ ai_gen_id }}:hover {
    color: #d52528 !important;
  }

  @media screen and (max-width: 900px) {
    .avyah-store-showcase-block-{{ ai_gen_id }} {
      padding: 40px 16px !important;
    }
    .avyah-store-showcase-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    .avyah-store-showcase-headline-{{ ai_gen_id }} {
      font-size: 36px !important;
    }
    .avyah-store-showcase-tagline-{{ ai_gen_id }} {
      font-size: 16px !important;
    }
    .avyah-store-showcase-body-{{ ai_gen_id }} {
      font-size: 15px !important;
    }
  }
</style>

<div class="avyah-store-showcase-block-{{ ai_gen_id }}">
  <div class="avyah-store-showcase-container-{{ ai_gen_id }}">
    <!-- Left Column: Image -->
    <div class="avyah-store-showcase-media-{{ ai_gen_id }}">
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.headline | escape }}"
          loading="lazy"
          width="1200"
          height="900"
          class="avyah-store-showcase-img-{{ ai_gen_id }}"
        >
      {%- else -%}
        <img
          src="{{ 'contact_page_manufacturing.png' | asset_url }}"
          alt="Avyah Retail Store Showcase"
          width="1200"
          height="900"
          loading="lazy"
          class="avyah-store-showcase-img-{{ ai_gen_id }}"
        >
      {%- endif -%}
    </div>

    <!-- Right Column: Content -->
    <div class="avyah-store-showcase-content-{{ ai_gen_id }}">
      <h2 class="avyah-store-showcase-headline-{{ ai_gen_id }}">
        {{ block.settings.headline | default: "We're Proudly in 50,000+ Homes & Fridges Nationwide" }}
      </h2>

      {%- if block.settings.tagline != blank -%}
        <div class="avyah-store-showcase-tagline-{{ ai_gen_id }}">
          {{ block.settings.tagline }}
        </div>
      {%- endif -%}

      {%- if block.settings.body_text != blank -%}
        <p class="avyah-store-showcase-body-{{ ai_gen_id }}">
          {{ block.settings.body_text }}
        </p>
      {%- endif -%}

      <div class="avyah-store-showcase-actions-{{ ai_gen_id }}">
        {%- if block.settings.primary_button_text != blank -%}
          <a href="{{ block.settings.primary_button_link | default: '/collections/all' }}" class="avyah-store-primary-btn-{{ ai_gen_id }}">
            {{ block.settings.primary_button_text }}
          </a>
        {%- endif -%}

        {%- if block.settings.secondary_button_text != blank -%}
          <a href="{{ block.settings.secondary_button_link | default: '/pages/bulk-order' }}" class="avyah-store-secondary-link-{{ ai_gen_id }}">
            {{ block.settings.secondary_button_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Retail Store Showcase",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Showcase Image"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "We're Proudly in 50,000+ Homes & Fridges Nationwide"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "(WE'RE TOO FRESH FOR THE REGULAR SNACK AISLE)"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Whether you're shopping for your weekly essentials or craving a convenient snack, we have you covered!"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "FIND A STORE NEAR YOU"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "BECOME A RETAILER"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Retail Store Showcase"
    }
  ]
}
{% endschema %}
