{% doc %}
  @prompt
    create latest blogs section with carousel for healthy eating 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-carousel-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-blog-carousel__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-blog-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-blog-carousel__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
  }

  .ai-blog-carousel__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-blog-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-blog-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 10px;
  }

  .ai-blog-carousel__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-blog-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc({{ block.settings.cards_per_view }}% - {{ block.settings.card_gap | times: 2 | divided_by: 3 }}px);
    min-width: 280px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-blog-carousel__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-blog-carousel__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.image_ratio }}%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-blog-carousel__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-carousel__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-blog-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-carousel__content-{{ ai_gen_id }} {
    padding: 24px;
  }

  .ai-blog-carousel__date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-blog-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .ai-blog-carousel__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-blog-carousel__title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-carousel__excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .ai-blog-carousel__read-more-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 14px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .ai-blog-carousel__read-more-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-carousel__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
  }

  .ai-blog-carousel__nav-button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_background }};
    border: 1px solid {{ block.settings.nav_button_border }};
    color: {{ block.settings.nav_button_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-blog-carousel__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
    color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-blog-carousel__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-blog-carousel__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-blog-carousel__empty-state-{{ ai_gen_id }} h3 {
    font-size: 20px;
    margin-bottom: 8px;
  }

  .ai-blog-carousel__empty-state-{{ ai_gen_id }} p {
    font-size: 14px;
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-blog-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - {{ block.settings.card_gap | divided_by: 2 }}px);
    }

    .ai-blog-carousel__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blog-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - 20px);
    }

    .ai-blog-carousel__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-blog-carousel__content-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<blog-carousel-{{ ai_gen_id }} class="ai-blog-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-blog-carousel__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-blog-carousel__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-blog-carousel__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.blog != blank %}
      {% assign articles = block.settings.blog.articles %}
      {% if articles.size > 0 %}
        <div class="ai-blog-carousel__wrapper-{{ ai_gen_id }}">
          <div class="ai-blog-carousel__track-{{ ai_gen_id }}" data-carousel-track>
            {% for article in articles limit: block.settings.articles_limit %}
              <article class="ai-blog-carousel__card-{{ ai_gen_id }}">
                <div class="ai-blog-carousel__image-wrapper-{{ ai_gen_id }}">
                  {% if article.image %}
                    <img
                      src="{{ article.image | image_url: width: 600 }}"
                      alt="{{ article.image.alt | escape }}"
                      class="ai-blog-carousel__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="{{ 600 | times: block.settings.image_ratio | divided_by: 100 }}"
                    >
                  {% else %}
                    <div class="ai-blog-carousel__image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-blog-carousel__content-{{ ai_gen_id }}">
                  {% if block.settings.show_date %}
                    <div class="ai-blog-carousel__date-{{ ai_gen_id }}">
                      {{ article.published_at | date: '%B %d, %Y' }}
                    </div>
                  {% endif %}

                  <h3 class="ai-blog-carousel__title-{{ ai_gen_id }}">
                    <a href="{{ article.url }}" class="ai-blog-carousel__title-link-{{ ai_gen_id }}">
                      {{ article.title }}
                    </a>
                  </h3>

                  {% if block.settings.show_excerpt and article.excerpt != blank %}
                    <div class="ai-blog-carousel__excerpt-{{ ai_gen_id }}">
                      {{ article.excerpt | strip_html | truncate: block.settings.excerpt_length }}
                    </div>
                  {% endif %}

                  {% if block.settings.show_read_more %}
                    <a href="{{ article.url }}" class="ai-blog-carousel__read-more-{{ ai_gen_id }}">
                      {{ block.settings.read_more_text }} →
                    </a>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          </div>

          {% if block.settings.show_navigation %}
            <div class="ai-blog-carousel__nav-{{ ai_gen_id }}">
              <button
                class="ai-blog-carousel__nav-button-{{ ai_gen_id }}"
                data-carousel-prev
                aria-label="Previous"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
              <button
                class="ai-blog-carousel__nav-button-{{ ai_gen_id }}"
                data-carousel-next
                aria-label="Next"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
          {% endif %}
        </div>
      {% else %}
        <div class="ai-blog-carousel__empty-state-{{ ai_gen_id }}">
          <h3>No articles yet</h3>
          <p>Add articles to your blog to see them here</p>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-blog-carousel__empty-state-{{ ai_gen_id }}">
        <h3>Select a blog</h3>
        <p>Choose a blog from the settings to display articles</p>
      </div>
    {% endif %}
  </div>
</blog-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('[data-carousel-track]');
        this.prevButton = this.querySelector('[data-carousel-prev]');
        this.nextButton = this.querySelector('[data-carousel-next]');
      }

      connectedCallback() {
        if (!this.track) return;

        this.setupNavigation();
        this.updateButtonStates();

        this.track.addEventListener('scroll', () => {
          this.updateButtonStates();
        });
      }

      setupNavigation() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.scroll('prev'));
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.scroll('next'));
        }
      }

      scroll(direction) {
        const scrollAmount = this.track.offsetWidth * 0.8;
        const currentScroll = this.track.scrollLeft;

        if (direction === 'prev') {
          this.track.scrollLeft = currentScroll - scrollAmount;
        } else {
          this.track.scrollLeft = currentScroll + scrollAmount;
        }
      }

      updateButtonStates() {
        if (!this.prevButton || !this.nextButton) return;

        const isAtStart = this.track.scrollLeft <= 0;
        const isAtEnd = this.track.scrollLeft + this.track.offsetWidth >= this.track.scrollWidth - 10;

        this.prevButton.disabled = isAtStart;
        this.nextButton.disabled = isAtEnd;
      }
    }

    customElements.define('blog-carousel-{{ ai_gen_id }}', BlogCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Latest blogs carousel",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_limit",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Number of articles",
      "default": 6
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Latest Healthy Eating Tips"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover nutrition advice and wellness insights"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Article display"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "min": 50,
      "max": 200,
      "step": 10,
      "label": "Excerpt length",
      "default": 120
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
