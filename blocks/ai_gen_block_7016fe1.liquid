{% doc %}
  @prompt
    add text responsive block with font size controler with character spacing and linegap, also add font family control , make the character spacing control for also in minus , increase the font size for desktop to 200
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-responsive-text__content-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size_desktop }}px;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    word-wrap: break-word;
  }

  @media screen and (max-width: 749px) {
    .ai-responsive-text__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-responsive-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-text__content-{{ ai_gen_id }}">
    {{ block.settings.text_content }}
  </div>
</div>

{% schema %}
{
  "name": "Responsive text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Text",
      "default": "<p>Add your text content here. Customize font size, spacing, and line height to create the perfect typography.</p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "inter_n4"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Desktop font size",
      "min": 10,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Mobile font size",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Character spacing",
      "min": -5,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line gap",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Responsive text"
    }
  ]
}
{% endschema %}
