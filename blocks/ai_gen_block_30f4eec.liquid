{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: #a72023; /* Crimson Red background */
    padding: 100px 0;
    position: relative;
    overflow: hidden;
    display: block;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  /* Central axis line */
  .ai-timeline-axis-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 20px;
    bottom: 20px;
    width: 4px;
    background-color: #ffffff; /* White timeline axis */
    transform: translateX(-50%);
    z-index: 1;
  }

  .ai-timeline-row-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    margin-bottom: 100px;
    width: 100%;
    opacity: 0;
    transform: translateY(60px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ai-timeline-row-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-timeline-row-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-timeline-col-media-{{ ai_gen_id }} {
    width: 46%;
  }

  .ai-timeline-col-text-{{ ai_gen_id }} {
    width: 46%;
  }

  /* Alternating layout */
  .ai-timeline-row-{{ ai_gen_id }}:nth-child(even) {
    flex-direction: row-reverse;
  }

  /* Node indicator on the axis line */
  .ai-timeline-node-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 20px;
    height: 20px;
    background-color: #ffffff;
    border: 4px solid #ffffff;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    z-index: 2;
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), background-color 0.5s ease;
    box-shadow: 0 0 0 4px #a72023;
  }

  .ai-timeline-row-{{ ai_gen_id }}.visible .ai-timeline-node-{{ ai_gen_id }} {
    background-color: #ffffff;
    transform: translate(-50%, -50%) scale(1.3);
  }

  /* Card styling */
  .ai-timeline-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    border: 1px solid #eae6df;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }

  .ai-timeline-badge-{{ ai_gen_id }} {
    display: inline-block;
    align-self: flex-start;
    background-color: #a72023;
    color: #ffffff;
    padding: 4px 14px;
    border-radius: 100px;
    font-family: 'Anton', sans-serif;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }

  .ai-timeline-heading-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 32px;
    color: #2b1f1d;
    margin: 0;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .ai-timeline-subheading-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: #5a4e4c;
    margin: 0;
    line-height: 1.6;
  }

  .ai-timeline-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background-color: #e9e5db;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  }

  .ai-timeline-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .ai-timeline-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-timeline-image-placeholder-{{ ai_gen_id }} svg {
    width: 40%;
    height: 40%;
    fill: #b5b0a4;
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-section-{{ ai_gen_id }} {
      padding: 60px 0;
    }

    .ai-timeline-axis-{{ ai_gen_id }} {
      left: 20px;
      transform: none;
      background-color: #ffffff;
    }

    .ai-timeline-row-{{ ai_gen_id }} {
      flex-direction: column !important;
      align-items: flex-start;
      margin-bottom: 50px;
      padding-left: 45px;
      width: auto;
    }

    .ai-timeline-col-media-{{ ai_gen_id }},
    .ai-timeline-col-text-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-timeline-col-media-{{ ai_gen_id }} {
      margin-top: 16px;
      order: 2;
    }

    .ai-timeline-col-text-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-timeline-node-{{ ai_gen_id }} {
      left: 20px;
      top: 30px;
      transform: translate(-50%, -50%) scale(0.8);
      background-color: #ffffff;
      box-shadow: 0 0 0 4px #a72023;
    }

    .ai-timeline-row-{{ ai_gen_id }}.visible .ai-timeline-node-{{ ai_gen_id }} {
      transform: translate(-50%, -50%) scale(1.2);
    }

    .ai-timeline-card-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-timeline-heading-{{ ai_gen_id }} {
      font-size: 24px;
    }
  }
{% endstyle %}

<timeline-section-{{ ai_gen_id }} class="ai-timeline-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-axis-{{ ai_gen_id }}"></div>

    {% for i in (1..8) %}
      {% liquid
        assign heading_key = 'slide_' | append: i | append: '_heading'
        assign subheading_key = 'slide_' | append: i | append: '_subheading'
        assign image_key = 'slide_' | append: i | append: '_image'

        assign heading_raw = block.settings[heading_key]
        assign subheading = block.settings[subheading_key]
        assign image = block.settings[image_key]

        # Parse Tag/Badge and clean heading
        assign badge = "MILESTONE"
        assign heading = heading_raw
        if heading_raw contains "|"
          assign parts = heading_raw | split: "|"
          assign badge = parts[0] | strip
          assign heading = parts[1] | strip
        endif
      %}

      {% if heading_raw != blank or subheading != blank %}
        <div class="ai-timeline-row-{{ ai_gen_id }}" data-timeline-row>
          <div class="ai-timeline-node-{{ ai_gen_id }}"></div>
          
          <div class="ai-timeline-col-text-{{ ai_gen_id }}">
            <div class="ai-timeline-card-{{ ai_gen_id }}">
              <span class="ai-timeline-badge-{{ ai_gen_id }}">{{ badge }}</span>
              <h3 class="ai-timeline-heading-{{ ai_gen_id }}">{{ heading }}</h3>
              {% if subheading != blank %}
                <p class="ai-timeline-subheading-{{ ai_gen_id }}">{{ subheading }}</p>
              {% endif %}
            </div>
          </div>

          <div class="ai-timeline-col-media-{{ ai_gen_id }}">
            <div class="ai-timeline-image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-timeline-image-{{ ai_gen_id }}"
                >
              {% else %}
                {% liquid
                  # Beautiful Unsplash Fallbacks based on loop index
                  assign index_mod = i | modulo: 4
                  if index_mod == 1
                    assign fallback_url = "https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=800&q=80"
                  elsif index_mod == 2
                    assign fallback_url = "https://images.unsplash.com/photo-1607349913338-fca88bfc6711?auto=format&fit=crop&w=800&q=80"
                  elsif index_mod == 3
                    assign fallback_url = "https://images.unsplash.com/photo-1584269600464-37b1b58a9fe7?auto=format&fit=crop&w=800&q=80"
                  else
                    assign fallback_url = "https://images.unsplash.com/photo-1490645935967-10de6ba17061?auto=format&fit=crop&w=800&q=80"
                  endif
                %}
                <img
                  src="{{ fallback_url }}"
                  alt="Avyah Milestone {{ i }}"
                  loading="lazy"
                  width="800"
                  height="600"
                  class="ai-timeline-image-{{ ai_gen_id }}"
                >
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</timeline-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TimelineSection{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        const rows = this.querySelectorAll('[data-timeline-row]');
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -120px 0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, observerOptions);

        rows.forEach(row => {
          observer.observe(row);
        });
      }
    }

    if (!customElements.get('timeline-section-{{ ai_gen_id }}')) {
      customElements.define('timeline-section-{{ ai_gen_id }}', TimelineSection{{ ai_gen_id }});
    }
  })();
</script>

