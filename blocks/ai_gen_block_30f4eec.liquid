{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-slideshow-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    min-width: 100%;
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.slide_padding }}px;
    background-color: {{ block.settings.slide_background_color }};
    border-radius: {{ block.settings.slide_border_radius }}px;
  }

  .ai-slideshow-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width_percent }}%;
    max-width: {{ block.settings.image_width_percent }}%;
  }

  .ai-slideshow-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-slideshow-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slideshow-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-slideshow-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-slideshow-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-slideshow-subheading-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-slideshow-nav-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_icon_color }};
    border: none;
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease;
  }

  .ai-slideshow-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
  }

  .ai-slideshow-nav-button-{{ ai_gen_id }}--prev {
    left: {{ block.settings.button_offset }}px;
  }

  .ai-slideshow-nav-button-{{ ai_gen_id }}--next {
    right: {{ block.settings.button_offset }}px;
  }

  .ai-slideshow-nav-button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-slideshow-image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-slideshow-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-slideshow-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<slideshow-carousel-{{ ai_gen_id }}
  class="ai-slideshow-container-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-slideshow-wrapper-{{ ai_gen_id }}">
    <div class="ai-slideshow-track-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign subheading_key = 'slide_' | append: i | append: '_subheading'
          assign image_key = 'slide_' | append: i | append: '_image'

          assign heading = block.settings[heading_key]
          assign subheading = block.settings[subheading_key]
          assign image = block.settings[image_key]
        %}

        {% if heading != blank or subheading != blank %}
          <div class="ai-slideshow-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
            <div class="ai-slideshow-image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-slideshow-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-slideshow-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-slideshow-content-{{ ai_gen_id }}">
              {% if heading != blank %}
                <h3 class="ai-slideshow-heading-{{ ai_gen_id }}">{{ heading }}</h3>
              {% endif %}
              {% if subheading != blank %}
                <p class="ai-slideshow-subheading-{{ ai_gen_id }}">{{ subheading }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <button
      class="ai-slideshow-nav-button-{{ ai_gen_id }} ai-slideshow-nav-button-{{ ai_gen_id }}--prev"
      aria-label="Previous slide"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-slideshow-nav-button-{{ ai_gen_id }} ai-slideshow-nav-button-{{ ai_gen_id }}--next"
      aria-label="Next slide"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</slideshow-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class SlideshowCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-slideshow-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-slideshow-nav-button-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-slideshow-nav-button-{{ ai_gen_id }}--next');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 5000;

        if (this.slides.length === 0) {
          return;
        }

        this.setupEventListeners();
        this.updateSlidePosition();

        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => {
          this.goToPrevSlide();
          if (this.autoplay) {
            this.resetAutoplay();
          }
        });

        this.nextButton.addEventListener('click', () => {
          this.goToNextSlide();
          if (this.autoplay) {
            this.resetAutoplay();
          }
        });
      }

      goToPrevSlide() {
        this.currentIndex = (this.currentIndex - 1 + this.slides.length) % this.slides.length;
        this.updateSlidePosition();
      }

      goToNextSlide() {
        this.currentIndex = (this.currentIndex + 1) % this.slides.length;
        this.updateSlidePosition();
      }

      updateSlidePosition() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, this.autoplaySpeed);
      }

      resetAutoplay() {
        clearInterval(this.autoplayInterval);
        this.startAutoplay();
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('slideshow-carousel-{{ ai_gen_id }}', SlideshowCarousel{{ ai_gen_id }});
  })();
</script>

