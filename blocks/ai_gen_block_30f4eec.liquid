{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* Force parent Shopify section wrappers to stretch full-width without any gaps or borders */
  .shopify-section:has(.ai-categories-section-{{ ai_gen_id }}) {
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    box-shadow: none !important;
    max-width: 100% !important;
    width: 100% !important;
  }

  .shopify-section:has(.ai-categories-section-{{ ai_gen_id }}) .section {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
    display: block !important;
  }

  .shopify-section:has(.ai-categories-section-{{ ai_gen_id }}) .custom-section-content {
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    max-width: 100% !important;
    width: 100% !important;
  }

  .shopify-section:has(.ai-categories-section-{{ ai_gen_id }}) .section-content-wrapper {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
    min-height: auto !important;
  }

  .ai-categories-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: #ffffff; /* Clean white background */
    padding: 80px 0;
    position: relative;
    overflow: hidden;
    display: block;
  }

  .ai-categories-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }

  .ai-categories-title-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 48px;
    color: #a72023; /* Bold crimson heading */
    margin: 0 0 50px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-align: center;
  }

  .ai-categories-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    justify-content: center;
  }

  /* Category card wrapper */
  .ai-cat-card-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
  }

  /* Colored category card shape */
  .ai-cat-card-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 0.85; /* Portrait layout */
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 20px;
  }

  .ai-cat-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
  }

  /* Preset background colors based on index */
  .ai-cat-card-{{ ai_gen_id }}--1 { background-color: #f7ca44; } /* Yellow/Orange */
  .ai-cat-card-{{ ai_gen_id }}--2 { background-color: #a72023; } /* Crimson Red */
  .ai-cat-card-{{ ai_gen_id }}--3 { background-color: #40a058; } /* Green */
  .ai-cat-card-{{ ai_gen_id }}--4 { background-color: #6e6f72; } /* Grey */
  .ai-cat-card-{{ ai_gen_id }}--5 { background-color: #3b91d6; } /* Blue */
  .ai-cat-card-{{ ai_gen_id }}--6 { background-color: #a72023; }
  .ai-cat-card-{{ ai_gen_id }}--7 { background-color: #f7ca44; }
  .ai-cat-card-{{ ai_gen_id }}--8 { background-color: #40a058; }

  /* Product package image styling */
  .ai-cat-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ai-cat-card-{{ ai_gen_id }}:hover .ai-cat-image-wrapper-{{ ai_gen_id }} {
    transform: scale(1.06) rotate(2deg);
  }

  .ai-cat-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.15));
  }

  /* Category title text underneath */
  .ai-cat-label-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 22px;
    color: #a72023;
    margin-top: 15px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-align: center;
    transition: color 0.3s ease;
  }

  .ai-cat-card-wrapper-{{ ai_gen_id }}:hover .ai-cat-label-{{ ai_gen_id }} {
    color: #2b1f1d;
  }

  /* Responsive styling */
  @media screen and (max-width: 1023px) {
    .ai-categories-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-categories-title-{{ ai_gen_id }} {
      font-size: 32px;
      margin-bottom: 30px;
    }

    .ai-categories-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .ai-cat-card-{{ ai_gen_id }} {
      padding: 12px;
      border-radius: 16px;
    }

    .ai-cat-label-{{ ai_gen_id }} {
      font-size: 18px;
      margin-top: 10px;
    }
  }

  @media screen and (max-width: 479px) {
    .ai-categories-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}

<div class="ai-categories-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-categories-container-{{ ai_gen_id }}">
    <h2 class="ai-categories-title-{{ ai_gen_id }}">
      {% if block.settings.section_title != blank %}
        {{ block.settings.section_title }}
      {% else %}
        AVYAH GOT MAAAAD TASTY!
      {% endif %}
    </h2>

    <div class="ai-categories-grid-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign image_key = 'slide_' | append: i | append: '_image'
          assign link_key = 'slide_' | append: i | append: '_link'

          assign heading_raw = block.settings[heading_key]
          assign image = block.settings[image_key]
          assign link = block.settings[link_key]

          # Parse/clean heading
          assign heading = heading_raw
          if heading_raw contains "|"
            assign parts = heading_raw | split: "|"
            assign heading = parts[1] | strip
          endif
        %}

        {% if heading != blank %}
          <a href="{% if link != blank %}{{ link }}{% else %}#{% endif %}" class="ai-cat-card-wrapper-{{ ai_gen_id }}">
            <div class="ai-cat-card-{{ ai_gen_id }} ai-cat-card-{{ ai_gen_id }}--{{ i }}">
              <div class="ai-cat-image-wrapper-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 600 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                    class="ai-cat-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  {% liquid
                    # Premium Local and stock image fallbacks
                    if i == 1
                      assign fallback_url = 'cart_taakat_hunger_bar.png' | asset_url
                    elsif i == 2
                      assign fallback_url = 'cart_mast_mix.png' | asset_url
                    elsif i == 3
                      assign fallback_url = 'cart_king.png' | asset_url
                    elsif i == 4
                      assign fallback_url = 'https://images.unsplash.com/photo-1584269600464-37b1b58a9fe7?auto=format&fit=crop&w=600&q=80'
                    elsif i == 5
                      assign fallback_url = 'https://images.unsplash.com/photo-1607349913338-fca88bfc6711?auto=format&fit=crop&w=600&q=80'
                    else
                      assign fallback_url = 'https://images.unsplash.com/photo-1490645935967-10de6ba17061?auto=format&fit=crop&w=600&q=80'
                    endif
                  %}
                  <img
                    src="{{ fallback_url }}"
                    alt="Avyah Category {{ i }}"
                    loading="lazy"
                    width="400"
                    height="500"
                    class="ai-cat-image-{{ ai_gen_id }}"
                  >
                {% endif %}
              </div>
            </div>
            <span class="ai-cat-label-{{ ai_gen_id }}">{{ heading }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    class TimelineSection{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        const rows = this.querySelectorAll('[data-timeline-row]');
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -120px 0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, observerOptions);

        rows.forEach(row => {
          observer.observe(row);
        });
      }
    }

    if (!customElements.get('timeline-section-{{ ai_gen_id }}')) {
      customElements.define('timeline-section-{{ ai_gen_id }}', TimelineSection{{ ai_gen_id }});
    }
  })();
</script>

