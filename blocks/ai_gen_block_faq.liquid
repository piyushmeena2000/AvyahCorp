{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    display: flex;
    justify-content: center;
    box-sizing: border-box;
  }

  .ai-faq-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-faq-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-faq-title-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: {{ block.settings.title_size_desktop }}px;
    line-height: 1.1;
    color: {{ block.settings.title_color }};
    text-transform: uppercase;
    margin: 0 0 12px 0;
    letter-spacing: -1px;
  }

  .ai-faq-subtitle-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #555555;
    margin: 0;
    line-height: 1.5;
  }

  .ai-faq-accordion-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Branded Rounded Card Style matching Product Cards */
  .ai-faq-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-left: 4px solid transparent;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    padding: 20px 24px;
    cursor: pointer;
    box-sizing: border-box;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
  }

  .ai-faq-card-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.1);
  }

  .ai-faq-card-{{ ai_gen_id }}.active {
    border-left-color: {{ block.settings.accent_color }};
    background-color: #ffffff;
  }

  .ai-faq-question-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }

  .ai-faq-question-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #111111;
    margin: 0;
    line-height: 1.4;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: #444444;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    transition: transform 0.3s ease;
  }

  .ai-faq-card-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
    color: {{ block.settings.accent_color }};
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0, 1, 0, 1), padding-top 0.3s ease;
    padding-top: 0;
  }

  .ai-faq-answer-inner-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #444444;
  }

  .ai-faq-answer-inner-{{ ai_gen_id }} p {
    margin: 0 0 10px 0;
  }
  .ai-faq-answer-inner-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  /* Branded Action Button matching Add to Cart */
  .ai-faq-btn-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: 'Anton', sans-serif;
    font-size: 16px;
    text-transform: uppercase;
    padding: 14px 32px;
    text-decoration: none;
    border-radius: 8px;
    transition: background-color 0.2s ease, transform 0.2s ease;
    letter-spacing: 1px;
    border: none;
  }

  .ai-faq-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    transform: translateY(-1px);
  }

  @media screen and (max-width: 767px) {
    .ai-faq-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 15px {{ block.settings.padding_bottom_mobile }}px;
    }
    .ai-faq-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }
    .ai-faq-card-{{ ai_gen_id }} {
      padding: 16px 20px;
    }
    .ai-faq-question-{{ ai_gen_id }} {
      font-size: 15px;
    }
  }
{% endstyle %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;700&display=swap" rel="stylesheet">

<div class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    <div class="ai-faq-header-{{ ai_gen_id }}">
      <h2 class="ai-faq-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% if block.settings.subheading != blank %}
        <p class="ai-faq-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
    
    <faq-branded-accordion class="ai-faq-accordion-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign q_key = 'faq_' | append: i | append: '_question'
          assign a_key = 'faq_' | append: i | append: '_answer'
          assign question = block.settings[q_key]
          assign answer = block.settings[a_key]
        %}
        
        {% if question != blank %}
          <div class="ai-faq-card-{{ ai_gen_id }} ai-faq-card">
            <div class="ai-faq-question-row-{{ ai_gen_id }} ai-faq-question-row">
              <h3 class="ai-faq-question-{{ ai_gen_id }}">{{ question }}</h3>
              <div class="ai-faq-icon-{{ ai_gen_id }} ai-faq-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </div>
            </div>
            <div class="ai-faq-answer-{{ ai_gen_id }} ai-faq-answer">
              <div class="ai-faq-answer-inner-{{ ai_gen_id }}">
                {{ answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </faq-branded-accordion>
    
    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-faq-btn-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    class FAQBrandedAccordion extends HTMLElement {
      connectedCallback() {
        const cards = this.querySelectorAll('.ai-faq-card');
        cards.forEach(card => {
          const row = card.querySelector('.ai-faq-question-row');
          row.addEventListener('click', () => {
            const isActive = card.classList.contains('active');
            
            // Close all cards
            cards.forEach(c => {
              c.classList.remove('active');
              const ans = c.querySelector('.ai-faq-answer');
              ans.style.maxHeight = null;
              ans.style.paddingTop = '0px';
            });

            // Open current card if not active
            if (!isActive) {
              card.classList.add('active');
              const answer = card.querySelector('.ai-faq-answer');
              answer.style.paddingTop = '16px';
              answer.style.maxHeight = (answer.scrollHeight + 16) + 'px';
            }
          });
        });
      }
    }
    
    if (!customElements.get('faq-branded-accordion')) {
      customElements.define('faq-branded-accordion', FAQBrandedAccordion);
    }
  })();
</script>

{% schema %}
{
  "name": "Custom Branded FAQ",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "color",
