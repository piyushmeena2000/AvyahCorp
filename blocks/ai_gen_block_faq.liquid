{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-split-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    min-height: 700px;
    background-color: {{ block.settings.left_bg_color }};
    overflow: hidden;
  }

  .ai-faq-left-{{ ai_gen_id }} {
    flex: 1 1 50%;
    box-sizing: border-box;
    padding: 80px 8%;
    background-color: {{ block.settings.left_bg_color }};
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-faq-right-{{ ai_gen_id }} {
    flex: 1 1 50%;
    box-sizing: border-box;
    padding: 80px 5% 0 8%;
    background-color: {{ block.settings.right_bg_color }};
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: 1.1;
    color: {{ block.settings.heading_color }};
    text-transform: uppercase;
    margin: 0 0 40px 0;
    letter-spacing: -1px;
  }

  .ai-faq-accordion-{{ ai_gen_id }} {
    margin-bottom: 40px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding: 24px 0;
    cursor: pointer;
  }

  .ai-faq-question-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .ai-faq-question-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: #000000;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.3;
    letter-spacing: 0.5px;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 14px;
    height: 14px;
    fill: #ffffff;
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0, 1, 0, 1), padding-top 0.3s ease;
    padding-top: 0;
  }

  .ai-faq-answer-inner-{{ ai_gen_id }} {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #444444;
  }

  /* Neobrutalist Button Styling */
  .ai-faq-btn-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: 'Anton', sans-serif;
    font-size: 16px;
    text-transform: uppercase;
    padding: 14px 32px;
    text-decoration: none;
    border: 2px solid #000000;
    box-shadow: 4px 4px 0px #000000;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
    align-self: flex-start;
    letter-spacing: 1px;
  }

  .ai-faq-btn-{{ ai_gen_id }}:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px #000000;
  }

  /* Right column styles */
  .ai-faq-right-content-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
  }

  .ai-faq-right-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 32px;
    color: #ffffff;
    padding-bottom: 60px;
    z-index: 10;
    flex: 1 1 50%;
  }

  .ai-faq-right-title-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 52px;
    line-height: 1.05;
    color: #ffffff;
    text-transform: uppercase;
    margin: 0;
    letter-spacing: -1px;
  }

  .ai-faq-right-badge-{{ ai_gen_id }} {
    border: 3px solid #ffffff;
    padding: 10px 20px;
    font-family: 'Anton', sans-serif;
    font-size: 32px;
    color: #ffffff;
    width: fit-content;
    text-align: center;
    line-height: 1;
    text-transform: uppercase;
    position: relative;
    letter-spacing: 0.5px;
  }

  .ai-faq-right-badge-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -5px;
    left: -5px;
    right: -5px;
    bottom: -5px;
    border: 1px solid #ffffff;
    pointer-events: none;
  }

  .ai-faq-right-subtitle-{{ ai_gen_id }} {
    font-family: 'Anton', sans-serif;
    font-size: 36px;
    line-height: 1.1;
    color: #ffffff;
    text-transform: uppercase;
    margin: 0;
  }

  .ai-faq-right-image-container-{{ ai_gen_id }} {
    flex: 1 1 50%;
    height: 100%;
    align-self: flex-end;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    position: relative;
  }

  .ai-faq-right-image-container-{{ ai_gen_id }} img {
    max-height: 580px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    z-index: 5;
    margin-bottom: -4px; /* Hide any minor alignment gaps */
  }

  @media screen and (max-width: 1024px) {
    .ai-faq-right-title-{{ ai_gen_id }} {
      font-size: 40px;
    }
    .ai-faq-right-badge-{{ ai_gen_id }} {
      font-size: 26px;
    }
    .ai-faq-right-subtitle-{{ ai_gen_id }} {
      font-size: 28px;
    }
  }

  @media screen and (max-width: 767px) {
    .ai-faq-split-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-faq-left-{{ ai_gen_id }},
    .ai-faq-right-{{ ai_gen_id }} {
      flex: 1 1 100%;
      width: 100%;
    }

    .ai-faq-left-{{ ai_gen_id }} {
      padding: 50px 24px;
    }

    .ai-faq-right-{{ ai_gen_id }} {
      padding: 60px 24px 0 24px;
    }

    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: 40px;
      margin-bottom: 30px;
    }

    .ai-faq-right-content-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .ai-faq-right-text-{{ ai_gen_id }} {
      align-items: center;
      padding-bottom: 40px;
      flex: 1 1 auto;
    }

    .ai-faq-right-badge-{{ ai_gen_id }} {
      margin: 0 auto;
    }

    .ai-faq-right-image-container-{{ ai_gen_id }} {
      width: 100%;
      flex: 1 1 auto;
      justify-content: center;
    }

    .ai-faq-right-image-container-{{ ai_gen_id }} img {
      max-height: 380px;
    }
  }
{% endstyle %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;700&display=swap" rel="stylesheet">

<faq-split-{{ ai_gen_id }} class="ai-faq-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-left-{{ ai_gen_id }}">
    <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    
    <faq-accordion class="ai-faq-accordion-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign q_key = 'faq_' | append: i | append: '_question'
          assign a_key = 'faq_' | append: i | append: '_answer'
          assign question = block.settings[q_key]
          assign answer = block.settings[a_key]
        %}
        
        {% if question != blank %}
          <div class="ai-faq-item-{{ ai_gen_id }} ai-faq-item">
            <div class="ai-faq-question-row-{{ ai_gen_id }} ai-faq-question-row">
              <h3 class="ai-faq-question-{{ ai_gen_id }}">{{ question }}</h3>
              <div class="ai-faq-icon-{{ ai_gen_id }} ai-faq-icon">
                <svg viewBox="0 0 24 24" width="24" height="24">
                  <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" fill="#ffffff"/>
                </svg>
              </div>
            </div>
            <div class="ai-faq-answer-{{ ai_gen_id }} ai-faq-answer">
              <div class="ai-faq-answer-inner-{{ ai_gen_id }}">
                {{ answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </faq-accordion>
    
    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-faq-btn-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>

  <div class="ai-faq-right-{{ ai_gen_id }}">
    <div class="ai-faq-right-content-{{ ai_gen_id }}">
      <div class="ai-faq-right-text-{{ ai_gen_id }}">
        {% if block.settings.right_title != blank %}
          <h3 class="ai-faq-right-title-{{ ai_gen_id }}">{{ block.settings.right_title }}</h3>
        {% endif %}
        
        {% if block.settings.right_badge != blank %}
          <div class="ai-faq-right-badge-{{ ai_gen_id }}">{{ block.settings.right_badge }}</div>
        {% endif %}
        
        {% if block.settings.right_subtitle != blank %}
          <div class="ai-faq-right-subtitle-{{ ai_gen_id }}">{{ block.settings.right_subtitle }}</div>
        {% endif %}
      </div>
      
      <div class="ai-faq-right-image-container-{{ ai_gen_id }}">
        {% if block.settings.right_image != blank %}
          <img
            src="{{ block.settings.right_image | image_url: width: 800 }}"
            alt="{{ block.settings.right_title | default: 'FAQ illustration' | escape }}"
            loading="lazy"
            width="600"
            height="800"
          >
        {% else %}
          <img
            src="{{ 'faq_model_image.png' | asset_url }}"
            alt="{{ block.settings.right_title | default: 'FAQ illustration' | escape }}"
            loading="lazy"
            width="600"
            height="800"
          >
        {% endif %}
      </div>
    </div>
  </div>
</faq-split-{{ ai_gen_id }}>

<script>
  (function() {
    class FAQAccordion extends HTMLElement {
      connectedCallback() {
        const items = this.querySelectorAll('.ai-faq-item');
        items.forEach(item => {
          const header = item.querySelector('.ai-faq-question-row');
          header.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            // Close all items
            items.forEach(i => {
              i.classList.remove('active');
              i.querySelector('.ai-faq-answer').style.maxHeight = null;
              i.querySelector('.ai-faq-answer').style.paddingTop = '0px';
              const svgPath = i.querySelector('.ai-faq-icon svg path');
              if (svgPath) svgPath.setAttribute('d', 'M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z'); // Plus icon
            });

            // Open current item if not active
            if (!isActive) {
              item.classList.add('active');
              const answer = item.querySelector('.ai-faq-answer');
              answer.style.paddingTop = '16px';
              answer.style.maxHeight = (answer.scrollHeight + 16) + 'px';
              const svgPath = item.querySelector('.ai-faq-icon svg path');
              if (svgPath) svgPath.setAttribute('d', 'M19 13H5v-2h14v2z'); // Minus icon
            }
          });
        });
      }
    }
    
    if (!customElements.get('faq-accordion')) {
      customElements.define('faq-accordion', FAQAccordion);
    }
  })();
</script>

