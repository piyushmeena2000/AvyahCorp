    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button BG Color",
      "default": "#d52528"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button Hover BG Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "FAQ Items (Real Store Content)"
    },
    {
      "type": "text",
      "id": "faq_1_question",
      "label": "Q1 Question",
      "default": "Are any purchases final sale?"
