<style>
  .custom-footer {
    background-color: #ffffff;
    padding: 60px 40px 40px;
    font-family: 'Inter', sans-serif;
    color: #333333;
    border-top: 1px solid #eaeaea;
  }

  .custom-footer-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto 60px;
    gap: 40px;
  }

  .custom-footer-column {
    flex: 1;
    min-width: 150px;
  }

  .custom-footer-column.wide {
    flex: 2;
    min-width: 250px;
  }

  .custom-footer-heading {
    font-family: 'Anton', sans-serif;
    font-size: 18px;
    text-transform: uppercase;
    color: #000000;
    margin-bottom: 24px;
    letter-spacing: 0.5px;
  }

  .custom-footer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .custom-footer-menu li {
    margin-bottom: 16px;
  }

  .custom-footer-menu a, .custom-footer-text {
    text-decoration: none;
    color: #4a4a4a;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .custom-footer-menu a:hover {
    color: #d52528;
  }

  .custom-footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid #eaeaea;
    padding-top: 40px;
  }

  .custom-footer-socials {
    display: flex;
    gap: 20px;
    margin-bottom: 24px;
  }

  .custom-footer-socials a {
    color: #000000;
    font-size: 20px;
    transition: color 0.2s, transform 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-footer-socials a:hover {
    color: #d52528;
    transform: translateY(-2px);
  }

  .custom-footer-socials svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  .custom-footer-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    font-size: 12px;
    color: #666666;
    margin-bottom: 12px;
  }

  .custom-footer-meta a {
    color: #666666;
    text-decoration: none;
    font-weight: 500;
  }

  .custom-footer-meta a:hover {
    color: #d52528;
  }

  .custom-footer-meta span {
    color: #999999;
  }

  .custom-footer-fineprint {
    font-size: 10px;
    color: #999999;
    line-height: 1.5;
    max-width: 1000px;
  }

  @media screen and (max-width: 768px) {
    .custom-footer {
      padding: 40px 20px 20px;
    }
    .custom-footer-top {
      flex-direction: column;
      gap: 30px;
    }
    .custom-footer-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .custom-footer-meta span {
      display: none;
    }
  }
</style>

<footer class="custom-footer">
  <div class="custom-footer-top">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'menu' %}
          <div class="custom-footer-column">
            <h4 class="custom-footer-heading">{{ block.settings.title }}</h4>
            {% if block.settings.menu != blank %}
              <ul class="custom-footer-menu">
                {% for link in linklists[block.settings.menu].links %}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {% endfor %}
              </ul>
            {% else %}
              <ul class="custom-footer-menu">
                <li><a href="#">Link 1</a></li>
                <li><a href="#">Link 2</a></li>
                <li><a href="#">Link 3</a></li>
              </ul>
            {% endif %}
          </div>
        {% when 'text' %}
          <div class="custom-footer-column wide">
            <h4 class="custom-footer-heading">{{ block.settings.title }}</h4>
            <div class="custom-footer-text">
              {{ block.settings.text }}
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>

  <div class="custom-footer-bottom">
    <div class="custom-footer-socials">
      {% if section.settings.tiktok_link != blank %}
        <a href="{{ section.settings.tiktok_link }}" target="_blank">
          <svg viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.01.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.12-3.44-3.17-3.43-5.59.03-3.33 2.72-5.98 6.06-5.99.25 0 .5 0 .75.03v4.06c-1.32-.23-2.67.62-3.03 1.91-.32 1.05.02 2.14.88 2.79 1.25.96 3.19.78 4.13-.53.58-.8.8-1.78.8-2.75V.02z"/></svg>
        </a>
      {% endif %}
      {% if section.settings.instagram_link != blank %}
        <a href="{{ section.settings.instagram_link }}" target="_blank">
          <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      {% endif %}
      {% if section.settings.pinterest_link != blank %}
        <a href="{{ section.settings.pinterest_link }}" target="_blank">
          <svg viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.198 0 7.458 2.99 7.458 6.982 0 4.175-2.631 7.531-6.284 7.531-1.226 0-2.378-.637-2.772-1.39l-.754 2.874c-.273 1.043-1.015 2.348-1.512 3.143 1.258.388 2.593.604 3.987.604 6.621 0 11.988-5.368 11.988-11.988C24.005 5.367 18.638 0 12.017 0z"/></svg>
        </a>
      {% endif %}
      {% if section.settings.facebook_link != blank %}
        <a href="{{ section.settings.facebook_link }}" target="_blank">
          <svg viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
        </a>
      {% endif %}
    </div>

    <div class="custom-footer-meta">
      <a href="{{ shop.url }}">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}</a>
      {% if section.settings.privacy_link != blank %}
        <span>&bull;</span>
        <a href="{{ section.settings.privacy_link }}">Privacy Policy</a>
      {% endif %}
      {% if section.settings.terms_link != blank %}
        <span>&bull;</span>
        <a href="{{ section.settings.terms_link }}">Terms And Conditions</a>
      {% endif %}
      {% if section.settings.accessibility_link != blank %}
        <span>&bull;</span>
        <a href="{{ section.settings.accessibility_link }}">Accessibility</a>
      {% endif %}
    </div>

    {% if section.settings.fineprint != blank %}
      <div class="custom-footer-fineprint">
        {{ section.settings.fineprint }}
      </div>
    {% endif %}
  </div>
</footer>

