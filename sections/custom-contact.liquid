{% schema %}
{
  "name": "Image & Text Contact",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Column Image"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Contact Us"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Introductory Text",
      "default": "<p>Our customer service team is all about you. Just as we strive for every bite to be delicious, we want to ensure every interaction is Perfect.</p>"
    },
    {
      "type": "richtext",
      "id": "links_text",
      "label": "Secondary Links Text",
      "default": "<p>Check out our <a href=\"/pages/faq\">FAQ page</a> for common questions.</p>"
    },
    {
      "type": "text",
      "id": "action_heading",
      "label": "Action Heading",
      "default": "Want to chat?"
    },
    {
      "type": "text",
      "id": "office_hours",
      "label": "Office Hours",
      "default": "Office Hours: Mon-Fri. 9AM-5PM IST"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "Phone: +91 98765 43210"
    },
    {
      "type": "text",
      "id": "email_link_text",
      "label": "Email Link Text",
      "default": "SEND US AN EMAIL"
    },
    {
      "type": "url",
      "id": "email_url",
      "label": "Email URL",
      "info": "To link directly to an email client, enter mailto:your@email.com"
    },
    {
      "type": "text",
      "id": "chat_link_text",
      "label": "Chat Link Text",
      "default": "CHAT WITH AN AGENT"
    },
    {
      "type": "url",
      "id": "chat_url",
      "label": "Chat URL (optional)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Image & Text Contact"
    }
  ]
}
{% endschema %}

<style>
  .split-contact-wrapper {
    display: flex;
    flex-wrap: wrap;
    width: 100vw;
    margin-left: calc(50% - 50vw); /* Forces 100% viewport width reliably */
    min-height: 85vh;
  }

  /* Left Half: Image */
  .split-contact-image-col {
    flex: 1 1 50%;
    min-height: 500px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: transparent;
  }

  /* Right Half: Content */
  .split-contact-content-col {
    flex: 1 1 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 8% 10%;
    font-family: 'Inter', sans-serif;
    color: {{ section.settings.text_color }};
    background-color: transparent; /* Merges with theme background */
  }

  /* Typography */
  .split-contact-content-col h1,
  .split-contact-content-col h2 {
    font-family: 'Anton', sans-serif;
    text-transform: uppercase;
    font-size: 72px;
    font-weight: 400; /* Anton is naturally thick */
    margin-bottom: 24px;
    color: {{ section.settings.text_color }};
    letter-spacing: 1px;
    line-height: 1.1;
  }

  .split-contact-intro {
    font-size: 20px;
    line-height: 1.6;
    margin-bottom: 24px;
    font-weight: 500;
  }

  .split-contact-links {
    font-size: 18px;
    line-height: 1.5;
    font-weight: 500;
  }

  .split-contact-content-col a {
    color: {{ section.settings.text_color }};
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: opacity 0.2s;
  }
  .split-contact-content-col a:hover {
    opacity: 0.7;
  }

  /* Action Section */
  .split-contact-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding-top: 40px;
    margin-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.2);
  }

  .split-contact-action .info-line {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .split-contact-action .action-link {
    display: block;
    margin-top: 24px;
    font-size: 18px;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    letter-spacing: 1px;
    transition: opacity 0.2s;
  }

  /* Responsive Design */
  @media screen and (max-width: 900px) {
    .split-contact-image-col {
      flex: 1 1 100%;
      min-height: 400px;
    }
    .split-contact-content-col {
      flex: 1 1 100%;
      padding: 60px 20px;
    }
    .split-contact-content-col h1,
    .split-contact-content-col h2 {
      font-size: 52px;
    }
    .split-contact-intro {
      font-size: 18px;
    }
  }
</style>

<div class="split-contact-wrapper">
  
  {%- liquid 
    assign bg_image_url = 'contact_page_bar.png' | asset_url
    if section.settings.image != blank
      assign bg_image_url = section.settings.image | img_url: 'master'
    endif
  -%}
  
  <!-- Left Side: Image -->
  <div class="split-contact-image-col" style="background-image: url('{{ bg_image_url }}');">
  </div>

  <!-- Right Side: Content -->
  <div class="split-contact-content-col">
    {%- if section.settings.main_heading != blank -%}
      <h1>{{ section.settings.main_heading }}</h1>
    {%- endif -%}
    
    {%- if section.settings.intro_text != blank -%}
      <div class="split-contact-intro">
        {{ section.settings.intro_text }}
      </div>
    {%- endif -%}

    {%- if section.settings.links_text != blank -%}
      <div class="split-contact-links">
        {{ section.settings.links_text }}
      </div>
    {%- endif -%}

    <div class="split-contact-action">
      {%- if section.settings.action_heading != blank -%}
        <h2>{{ section.settings.action_heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.office_hours != blank -%}
        <div class="info-line">{{ section.settings.office_hours }}</div>
      {%- endif -%}

      {%- if section.settings.phone_number != blank -%}
        <div class="info-line">{{ section.settings.phone_number }}</div>
      {%- endif -%}

      {%- if section.settings.email_link_text != blank -%}
        <a href="{{ section.settings.email_url | default: '#' }}" class="action-link">
          {{ section.settings.email_link_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.chat_link_text != blank -%}
        <a href="{{ section.settings.chat_url | default: '#' }}" class="action-link">
          {{ section.settings.chat_link_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>
