{% schema %}
{
  "name": "Centered Contact Page",
  "settings": [
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Contact Us"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Introductory Text",
      "default": "<p>Our customer service team is all about you. Just as we strive for every bite to be delicious, we want to ensure every interaction is Perfect.</p>"
    },
    {
      "type": "richtext",
      "id": "links_text",
      "label": "Secondary Links Text",
      "default": "<p>Check out our <a href=\"/pages/faq\">FAQ page</a> for common questions.</p>"
    },
    {
      "type": "header",
      "content": "Action Section"
    },
    {
      "type": "text",
      "id": "action_heading",
      "label": "Action Heading",
      "default": "Want to chat?"
    },
    {
      "type": "text",
      "id": "office_hours",
      "label": "Office Hours",
      "default": "Office Hours: Mon-Fri. 9AM-5PM IST"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "Phone: +91 98765 43210"
    },
    {
      "type": "text",
      "id": "email_link_text",
      "label": "Email Link Text",
      "default": "SEND US AN EMAIL"
    },
    {
      "type": "url",
      "id": "email_url",
      "label": "Email URL",
      "info": "To link directly to an email client, enter mailto:your@email.com"
    },
    {
      "type": "text",
      "id": "chat_link_text",
      "label": "Chat Link Text",
      "default": "CHAT WITH AN AGENT"
    },
    {
      "type": "url",
      "id": "chat_url",
      "label": "Chat URL (optional)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Centered Contact Page"
    }
  ]
}
{% endschema %}

<style>
  .centered-contact-wrapper {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    width: 100%;
    min-height: 75vh;
    padding: 80px 20px;
    background-color: transparent; /* Merges with theme background */
    font-family: 'Inter', sans-serif;
    color: {{ section.settings.text_color }};
  }

  .centered-contact-container {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 60px;
  }

  /* Typography */
  .centered-contact-wrapper h1,
  .centered-contact-wrapper h2 {
    font-size: 64px;
    font-weight: 800;
    margin-bottom: 24px;
    color: {{ section.settings.text_color }};
    letter-spacing: -1px;
    line-height: 1.1;
  }

  .centered-contact-intro p {
    font-size: 20px;
    line-height: 1.6;
    margin-bottom: 24px;
    font-weight: 500;
  }

  .centered-contact-links p {
    font-size: 18px;
    line-height: 1.5;
    font-weight: 500;
  }

  .centered-contact-wrapper a {
    color: {{ section.settings.text_color }};
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: opacity 0.2s;
  }
  .centered-contact-wrapper a:hover {
    opacity: 0.7;
  }

  /* Action Section */
  .centered-contact-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.2);
  }

  .centered-contact-action .info-line {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .centered-contact-action .action-link {
    display: block;
    margin-top: 24px;
    font-size: 18px;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    letter-spacing: 1px;
    transition: opacity 0.2s;
  }
  .centered-contact-action .action-link:hover {
    opacity: 0.7;
  }

  /* Responsive Design */
  @media screen and (max-width: 768px) {
    .centered-contact-wrapper {
      padding: 60px 20px;
    }
    .centered-contact-wrapper h1,
    .centered-contact-wrapper h2 {
      font-size: 48px;
    }
    .centered-contact-intro p {
      font-size: 18px;
    }
  }
</style>

<div class="centered-contact-wrapper">
  <div class="centered-contact-container">
    
    <!-- Top Content -->
    <div class="centered-contact-top">
      {%- if section.settings.main_heading != blank -%}
        <h1>{{ section.settings.main_heading }}</h1>
      {%- endif -%}
      
      {%- if section.settings.intro_text != blank -%}
        <div class="centered-contact-intro">
          {{ section.settings.intro_text }}
        </div>
      {%- endif -%}

      {%- if section.settings.links_text != blank -%}
        <div class="centered-contact-links">
          {{ section.settings.links_text }}
        </div>
      {%- endif -%}
    </div>

    <!-- Bottom Action Content -->
    <div class="centered-contact-action">
      {%- if section.settings.action_heading != blank -%}
        <h2>{{ section.settings.action_heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.office_hours != blank -%}
        <div class="info-line">{{ section.settings.office_hours }}</div>
      {%- endif -%}

      {%- if section.settings.phone_number != blank -%}
        <div class="info-line">{{ section.settings.phone_number }}</div>
      {%- endif -%}

      {%- if section.settings.email_link_text != blank -%}
        <a href="{{ section.settings.email_url | default: '#' }}" class="action-link">
          {{ section.settings.email_link_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.chat_link_text != blank -%}
        <a href="{{ section.settings.chat_url | default: '#' }}" class="action-link">
          {{ section.settings.chat_link_text }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>
