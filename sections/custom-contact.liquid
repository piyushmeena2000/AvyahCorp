{% schema %}
{
  "name": "Split Contact Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Column Image"
    },
    {
      "type": "header",
      "content": "Top Right Section"
    },
    {
      "type": "color",
      "id": "top_bg_color",
      "label": "Background Color",
      "default": "#fdf7ee"
    },
    {
      "type": "text",
      "id": "top_heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "richtext",
      "id": "top_text",
      "label": "Body Text",
      "default": "<p>Our customer service team is all about you. Just as we strive for every bite to be delicious, we want to ensure every interaction is Perfect.</p>"
    },
    {
      "type": "richtext",
      "id": "top_links_text",
      "label": "Links Text",
      "default": "<p>Check out our <a href=\"/pages/faq\">FAQ page</a> for common questions.</p>"
    },
    {
      "type": "header",
      "content": "Bottom Right Section"
    },
    {
      "type": "color",
      "id": "bottom_bg_color",
      "label": "Background Color",
      "default": "#daf1ee"
    },
    {
      "type": "text",
      "id": "bottom_heading",
      "label": "Heading",
      "default": "Want to chat?"
    },
    {
      "type": "text",
      "id": "office_hours",
      "label": "Office Hours",
      "default": "Office Hours: Mon-Fri. 9AM-5PM IST"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "Phone: +91 98765 43210"
    },
    {
      "type": "text",
      "id": "email_link_text",
      "label": "Email Link Text",
      "default": "SEND US AN EMAIL"
    },
    {
      "type": "url",
      "id": "email_url",
      "label": "Email URL",
      "info": "To link directly to an email client, enter mailto:your@email.com"
    },
    {
      "type": "text",
      "id": "chat_link_text",
      "label": "Chat Link Text",
      "default": "CHAT WITH AN AGENT"
    },
    {
      "type": "url",
      "id": "chat_url",
      "label": "Chat URL (optional)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#39302c"
    }
  ],
  "presets": [
    {
      "name": "Split Contact Page"
    }
  ]
}
{% endschema %}

<style>
  .split-contact-wrapper {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    min-height: 85vh; /* Gives that full-screen immersive feel */
    font-family: 'Inter', sans-serif;
    color: {{ section.settings.text_color }};
  }

  /* Left Half: Image */
  .split-contact-image-col {
    flex: 1 1 50%;
    min-height: 500px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: #e5e5e5;
  }

  /* Right Half: Stacked Content */
  .split-contact-content-col {
    flex: 1 1 50%;
    display: flex;
    flex-direction: column;
  }

  .split-contact-block {
    flex: 1; /* Both top and bottom take 50% of the right column */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 10% 12%;
  }

  .split-contact-top {
    background-color: {{ section.settings.top_bg_color }};
  }
  
  .split-contact-bottom {
    background-color: {{ section.settings.bottom_bg_color }};
  }

  /* Typography */
  .split-contact-block h1,
  .split-contact-block h2 {
    font-size: 56px;
    font-weight: 800;
    margin-bottom: 24px;
    color: {{ section.settings.text_color }};
    letter-spacing: -1px;
    line-height: 1.1;
  }

  .split-contact-top .top-body-text p {
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 24px;
    font-weight: 500;
  }

  .split-contact-top .top-links-text p {
    font-size: 16px;
    line-height: 1.5;
    font-weight: 500;
  }

  .split-contact-top a {
    color: {{ section.settings.text_color }};
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: opacity 0.2s;
  }
  .split-contact-top a:hover {
    opacity: 0.7;
  }

  .split-contact-bottom .info-line {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .split-contact-bottom .action-link {
    display: block;
    margin-top: 16px;
    font-size: 16px;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    text-decoration: underline;
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
    letter-spacing: 1px;
    transition: opacity 0.2s;
  }
  .split-contact-bottom .action-link:hover {
    opacity: 0.7;
  }

  /* Responsive Design */
  @media screen and (max-width: 900px) {
    .split-contact-image-col {
      flex: 1 1 100%;
      min-height: 400px;
    }
    .split-contact-content-col {
      flex: 1 1 100%;
    }
    .split-contact-block {
      padding: 60px 20px;
    }
    .split-contact-block h1,
    .split-contact-block h2 {
      font-size: 42px;
    }
  }
</style>

<div class="split-contact-wrapper">
  
  {%- liquid 
    assign bg_image_url = ''
    if section.settings.image != blank
      assign bg_image_url = section.settings.image | img_url: 'master'
    endif
  -%}
  
  <div class="split-contact-image-col" style="background-image: url('{{ bg_image_url }}');">
    {%- if section.settings.image == blank -%}
      <!-- Placeholder if no image uploaded -->
      <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; opacity:0.3;">
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>

  <div class="split-contact-content-col">
    <!-- Top Block -->
    <div class="split-contact-block split-contact-top">
      {%- if section.settings.top_heading != blank -%}
        <h1>{{ section.settings.top_heading }}</h1>
      {%- endif -%}
      
      {%- if section.settings.top_text != blank -%}
        <div class="top-body-text">
          {{ section.settings.top_text }}
        </div>
      {%- endif -%}

      {%- if section.settings.top_links_text != blank -%}
        <div class="top-links-text">
          {{ section.settings.top_links_text }}
        </div>
      {%- endif -%}
    </div>

    <!-- Bottom Block -->
    <div class="split-contact-block split-contact-bottom">
      {%- if section.settings.bottom_heading != blank -%}
        <h2>{{ section.settings.bottom_heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.office_hours != blank -%}
        <div class="info-line">{{ section.settings.office_hours }}</div>
      {%- endif -%}

      {%- if section.settings.phone_number != blank -%}
        <div class="info-line">{{ section.settings.phone_number }}</div>
      {%- endif -%}

      {%- if section.settings.email_link_text != blank -%}
        <a href="{{ section.settings.email_url | default: '#' }}" class="action-link">
          {{ section.settings.email_link_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.chat_link_text != blank -%}
        <a href="{{ section.settings.chat_url | default: '#' }}" class="action-link">
          {{ section.settings.chat_link_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>
