{% schema %}
{
  "name": "Custom Ingredients Page",
  "settings": [
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Hero Badge Text",
      "default": "100% CLEAN & HONEST FORMULATION"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Main Heading",
      "default": "REAL INGREDIENTS. ZERO NONSENSE."
    },
    {
      "type": "richtext",
      "id": "hero_subtext",
      "label": "Hero Subtext",
      "default": "<p>At Avyah, we believe food should fuel you, not slow you down. Every Hunger Bar is packed with whole grains, slow-roasted nuts, natural seeds, and unrefined sweeteners. No palm oil, zero artificial flavor enhancers, and 0% chemical preservatives.</p>"
    }
  ],
  "presets": [
    {
      "name": "Custom Ingredients Page"
    }
  ]
}
{% endschema %}

<style>
  #MainContent[data-template="page.how-its-made"],
  #MainContent[data-template="page.ingredients"] {
    display: block !important;
    padding: 0 !important;
    gap: 0 !important;
  }

  .ingredients-page-wrapper {
    background-color: #fdf7ee; /* Warm Cream Background */
    color: #3d2b27;
    font-family: 'Inter', sans-serif;
    width: 100%;
    overflow-x: hidden;
  }

  /* 1. HERO SECTION */
  .ingredients-hero {
    background-color: #d52528; /* Primary Crimson Red Header Match */
    color: #ffffff;
    padding: 90px 20px 80px;
    text-align: center;
    position: relative;
  }

  .ingredients-hero-inner {
    max-width: 920px;
    margin: 0 auto;
  }

  .ingredients-badge {
    display: inline-block;
    background-color: #ffffff;
    color: #d52528;
    font-family: 'Anton', sans-serif;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 22px;
    border-radius: 4px;
    margin-bottom: 24px;
    font-weight: 400;
  }

  .ingredients-hero h1 {
    font-family: 'Anton', sans-serif;
    font-size: 64px;
    text-transform: uppercase;
    line-height: 1.05;
    margin: 0 0 22px;
    letter-spacing: 1px;
    color: #ffffff;
  }

  .ingredients-hero-subtext {
    font-size: 19px;
    line-height: 1.6;
    margin: 0 auto 40px;
    max-width: 780px;
    opacity: 0.95;
    font-weight: 400;
  }

  .ingredients-hero-subtext p {
    margin: 0;
    color: #ffffff;
  }

  /* Quick Stats Bar */
  .ingredients-stats-bar {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 35px;
    margin-top: 20px;
  }

  .ingredients-stat-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(0, 0, 0, 0.18);
    padding: 12px 24px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .ingredients-stat-icon {
    font-size: 20px;
  }

  .ingredients-stat-text {
    font-family: 'Anton', sans-serif;
    font-size: 15px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #ffffff;
  }

  /* 2. CORE INGREDIENT GRID SECTION */
  .ingredients-grid-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 90px 20px;
  }

  .ingredients-section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .ingredients-section-header h2 {
    font-family: 'Anton', sans-serif;
    font-size: 46px;
    text-transform: uppercase;
    color: #3d2b27;
    margin: 0 0 14px;
    letter-spacing: 1px;
  }

  .ingredients-section-header p {
    font-size: 18px;
    color: #6a5e5c;
    margin: 0;
    font-weight: 500;
  }

  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .ingredient-card {
    background-color: #ffffff;
    border-radius: 16px;
    padding: 36px 30px;
    box-shadow: 0 4px 20px rgba(61, 43, 39, 0.06);
    border: 1px solid #efe6d9;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .ingredient-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(213, 37, 40, 0.12);
  }

  .ingredient-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .ingredient-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background-color: #fff5f5;
    color: #d52528;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
  }

  .ingredient-tag {
    font-family: 'Anton', sans-serif;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #2e5a3c;
    background-color: #eaf4ed;
    padding: 6px 12px;
    border-radius: 4px;
  }

  .ingredient-card h3 {
    font-family: 'Anton', sans-serif;
    font-size: 26px;
    text-transform: uppercase;
    color: #3d2b27;
    margin: 0 0 12px;
    line-height: 1.1;
  }

  .ingredient-card p {
    font-size: 15px;
    line-height: 1.6;
    color: #6a5e5c;
    margin: 0;
    font-weight: 400;
  }

  /* 3. WHAT WE SAY NO TO (TRANSPARENCY SECTION) */
  .ingredients-no-section {
    background-color: #3d2b27; /* Dark Charcoal Brown */
    color: #ffffff;
    padding: 90px 20px;
  }

  .ingredients-no-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ingredients-no-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .ingredients-no-header h2 {
    font-family: 'Anton', sans-serif;
    font-size: 48px;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 12px;
    letter-spacing: 1px;
  }

  .ingredients-no-header p {
    font-size: 17px;
    color: #d1c5b8;
    margin: 0;
  }

  .ingredients-no-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ingredients-no-item {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 32px 24px;
    text-align: center;
    transition: transform 0.2s ease;
  }

  .ingredients-no-item:hover {
    transform: translateY(-4px);
    background-color: rgba(255, 255, 255, 0.08);
  }

  .ingredients-no-cross {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background-color: rgba(213, 37, 40, 0.25);
    color: #ff5256;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 18px;
    font-size: 22px;
    font-weight: 700;
  }

  .ingredients-no-item h4 {
    font-family: 'Anton', sans-serif;
    font-size: 20px;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 8px;
    letter-spacing: 0.5px;
  }

  .ingredients-no-item p {
    font-size: 14px;
    line-height: 1.5;
    color: #d1c5b8;
    margin: 0;
  }

  /* 4. COMPARISON TABLE SECTION */
  .ingredients-compare-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 90px 20px;
  }

  .ingredients-compare-table {
    width: 100%;
    border-collapse: collapse;
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    border: 1px solid #efe6d9;
  }

  .ingredients-compare-table th,
  .ingredients-compare-table td {
    padding: 20px 24px;
    text-align: left;
    font-size: 15px;
    border-bottom: 1px solid #efe6d9;
  }

  .ingredients-compare-table th {
    font-family: 'Anton', sans-serif;
    font-size: 18px;
    letter-spacing: 1px;
    text-transform: uppercase;
    background-color: #f8f1e5;
    color: #3d2b27;
  }

  .ingredients-compare-table th.brand-col {
    background-color: #d52528;
    color: #ffffff;
    text-align: center;
  }

  .ingredients-compare-table td.brand-col {
    background-color: #fff5f5;
    color: #d52528;
    font-weight: 600;
    text-align: center;
  }

  /* 5. PROCESS STEPS */
  .ingredients-process-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 90px 20px;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 50px;
  }

  .process-card {
    background-color: #ffffff;
    border-radius: 16px;
    padding: 32px 24px;
    border: 1px solid #efe6d9;
    text-align: center;
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }

  .process-num {
    font-family: 'Anton', sans-serif;
    font-size: 44px;
    color: #d52528;
    line-height: 1;
    margin-bottom: 16px;
  }

  .process-card h3 {
    font-family: 'Anton', sans-serif;
    font-size: 22px;
    text-transform: uppercase;
    color: #3d2b27;
    margin: 0 0 10px;
  }

  .process-card p {
    font-size: 14px;
    line-height: 1.5;
    color: #6a5e5c;
    margin: 0;
  }

  /* 6. CTA BANNER */
  .ingredients-cta {
    background-color: #d52528;
    color: #ffffff;
    text-align: center;
    padding: 80px 20px;
  }

  .ingredients-cta h2 {
    font-family: 'Anton', sans-serif;
    font-size: 52px;
    text-transform: uppercase;
    margin: 0 0 16px;
    color: #ffffff;
    letter-spacing: 1px;
  }

  .ingredients-cta p {
    font-size: 19px;
    margin: 0 0 36px;
    color: #ffffff;
    opacity: 0.95;
  }

  .ingredients-cta-buttons {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .ingredients-cta-btn {
    display: inline-block;
    padding: 16px 40px;
    font-family: 'Anton', sans-serif;
    font-size: 18px;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 1px;
    border-radius: 6px;
    transition: background-color 0.2s, transform 0.2s;
  }

  .ingredients-cta-primary {
    background-color: #ffffff;
    color: #d52528;
  }

  .ingredients-cta-primary:hover {
    background-color: #f5f5f5;
    transform: translateY(-2px);
  }

  .ingredients-cta-secondary {
    background-color: transparent;
    color: #ffffff;
    border: 2px solid #ffffff;
  }

  .ingredients-cta-secondary:hover {
    background-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  /* Responsive Design */
  @media screen and (max-width: 992px) {
    .ingredients-grid,
    .process-grid,
    .ingredients-no-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .ingredients-hero h1 {
      font-size: 48px;
    }
    .ingredients-cta h2 {
      font-size: 38px;
    }
  }

  @media screen and (max-width: 600px) {
    .ingredients-grid,
    .process-grid,
    .ingredients-no-grid {
      grid-template-columns: 1fr;
    }
    .ingredients-hero h1 {
      font-size: 36px;
    }
    .ingredients-stats-bar {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<!-- MAIN INGREDIENTS PAGE LAYOUT CONTAINER -->
<div class="ingredients-page-wrapper" id="avyah-ingredients-page-root">
  <!-- 1. HERO SECTION -->
  <section class="ingredients-hero">
    <div class="ingredients-hero-inner">
      <span class="ingredients-badge">{{ section.settings.hero_badge }}</span>
      <h1>{{ section.settings.hero_heading }}</h1>
      <div class="ingredients-hero-subtext">
        {{ section.settings.hero_subtext }}
      </div>

      <div class="ingredients-stats-bar">
        <div class="ingredients-stat-item">
          <span class="ingredients-stat-icon">🥜</span>
          <span class="ingredients-stat-text">WHOLE NUTS & SEEDS</span>
        </div>
        <div class="ingredients-stat-item">
          <span class="ingredients-stat-icon">🌾</span>
          <span class="ingredients-stat-text">100% WHOLE GRAINS</span>
        </div>
        <div class="ingredients-stat-item">
          <span class="ingredients-stat-icon">🍯</span>
          <span class="ingredients-stat-text">UNREFINED SWEETENERS</span>
        </div>
        <div class="ingredients-stat-item">
          <span class="ingredients-stat-icon">🚫</span>
          <span class="ingredients-stat-text">ZERO PALM OIL</span>
        </div>
