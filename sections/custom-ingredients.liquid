      <a href="/collections/all" class="ingredients-cta-btn ingredients-cta-primary">EXPLORE CATALOG</a>
      <a href="/pages/bulk-order" class="ingredients-cta-btn ingredients-cta-secondary">BUILD YOUR BUNDLE</a>
    </div>
  </section>
</div>

<!-- CLIENT-SIDE AUTOMATIC RENDER ENGINE FOR INGREDIENTS PAGE (Catches 404 & loads interface directly) -->
<script>
(function() {
  function forceRenderIngredientsPage() {
    const path = window.location.pathname.toLowerCase();
    if (!path.includes('ingredient')) return;

    const main = document.querySelector('#MainContent') || document.querySelector('main') || document.body;
    if (!main) return;

    const pageRoot = document.getElementById('avyah-ingredients-page-root');
    
    // Check if 404 block is currently displayed
    const is404 = document.querySelector('.main-404') || 
                  document.title.toLowerCase().includes('404') || 
                  document.querySelector('h1')?.textContent.toLowerCase().includes('page not found') ||
                  document.body.classList.contains('template-404');

    if (is404) {
      document.title = "Ingredients | Avyah Clean Hunger Bars";
      // Hide 404 child elements
      const elementsToHide = main.querySelectorAll('.section, .section-wrapper, .main-404, div[class*="section"]');
      elementsToHide.forEach(el => {
        if (el.id !== 'avyah-ingredients-page-root' && !el.contains(pageRoot)) {
          el.style.display = 'none';
        }
      });

      if (pageRoot) {
        pageRoot.style.display = 'block';
        if (pageRoot.parentElement !== main) {
          main.appendChild(pageRoot);
        }
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', forceRenderIngredientsPage);
  } else {
    forceRenderIngredientsPage();
  }
  setTimeout(forceRenderIngredientsPage, 300);
})();
</script>
