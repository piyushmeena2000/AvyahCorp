    background-color: #fdf7ee !important;
    padding: 80px 24px !important;
    margin-top: 80px !important;
    border-top: 1px solid #f0e6d8 !important;
    box-sizing: border-box !important;
  }

  .avyah-collection-faq-container {
    max-width: 900px !important;
    margin: 0 auto !important;
  }

  .avyah-collection-faq-header {
    text-align: center !important;
    margin-bottom: 48px !important;
  }

  .avyah-faq-tag {
    display: inline-block !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 12px !important;
    font-weight: 800 !important;
    color: #d52528 !important;
    text-transform: uppercase !important;
    letter-spacing: 1.5px !important;
    margin-bottom: 8px !important;
  }

  .avyah-faq-title {
    font-family: 'Anton', Arial, sans-serif !important;
    font-size: 38px !important;
    font-weight: 400 !important;
    color: #3d2b27 !important;
    text-transform: uppercase !important;
    margin: 0 0 12px 0 !important;
    letter-spacing: 0.5px !important;
  }

  .avyah-faq-subtitle {
    font-family: 'Inter', sans-serif !important;
    font-size: 15px !important;
    color: #665550 !important;
    margin: 0 !important;
  }

  .avyah-faq-accordion-list {
    display: flex !important;
    flex-direction: column !important;
    gap: 16px !important;
  }

  .avyah-faq-item {
    background: #ffffff !important;
    border: 1.5px solid #e8dfd1 !important;
    border-radius: 12px !important;
    overflow: hidden !important;
    transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
  }

  .avyah-faq-item.active {
    border-color: #d52528 !important;
    box-shadow: 0 4px 16px rgba(213, 37, 40, 0.08) !important;
  }

  .avyah-faq-question {
    width: 100% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 20px 24px !important;
    background: transparent !important;
    border: none !important;
    cursor: pointer !important;
    text-align: left !important;
    font-family: 'Anton', Arial, sans-serif !important;
    font-size: 18px !important;
    font-weight: 400 !important;
