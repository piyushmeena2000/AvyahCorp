<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: 0px; padding-top: 0 !important; margin-top: 0 !important; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <!-- PerfectSnacks Collection Sub-Navigation Bar (Range Collections) -->
  <div class="perfect-collection-subnav">
    <a href="/collections/taakat" class="{% if collection.handle == 'taakat' or collection.handle == 'range' %}active{% endif %}">TAAKAT HUNGER BAR</a>
    <a href="/collections/mast-mix" class="{% if collection.handle == 'mast-mix' or collection.handle == 'mastmix' %}active{% endif %}">MAST MIX</a>
    <a href="/collections/king" class="{% if collection.handle == 'king' %}active{% endif %}">KING</a>
    <a href="/collections/combos" class="{% if collection.handle == 'combos' or collection.handle == 'combo' %}active{% endif %}">COMBOS</a>
    <a href="/collections/snackbox" class="{% if collection.handle == 'snackbox' or collection.handle == 'snack-box' %}active{% endif %}">SNACKBOX</a>
  </div>

  <div
    class="collection-wrapper grid gap-style"
  >

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% assign display_products = collection.products %}
    {% if collection.handle == 'snackbox' and display_products.size == 0 %}
      {% assign snack_items = '' | split: '' %}
      {% for prod in collections['all'].products %}
        {% assign title_low = prod.title | downcase %}
        {% if title_low contains 'snack box' or title_low contains 'snackbox' or title_low contains 'great indian' %}
          {% assign single_prod = prod | slice: 0, 1 %}
          {% assign snack_items = snack_items | concat: single_prod %}
        {% endif %}
      {% endfor %}
      {% if snack_items.size > 0 %}
        {% assign display_products = snack_items %}
      {% else %}
        {% assign display_products = collections['all'].products %}
      {% endif %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% for product in display_products %}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item avyah-perfect-card"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            ref="cards[]"
          >
            <div class="avyah-card-inner">
              <a href="{{ product.url }}" class="avyah-card-media-link">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy" width="500" height="500">
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag }}
                {% endif %}
              </a>

              <!-- Star Rating -->
              <div class="avyah-card-rating">
                <span class="stars">★★★★★</span>
                <span class="count">(39)</span>
              </div>

              <!-- Product Title -->
              <a href="{{ product.url }}" class="avyah-card-title-link">
                <h3 class="avyah-card-title">{{ product.title | upcase }}</h3>
              </a>

              <!-- Pack Subtitle -->
              <div class="avyah-card-subtitle">
                {% assign title_low = product.title | downcase %}
                {% if title_low contains 'combos' or title_low contains 'combo' %}
                  PACK OF 3 NAMKEENS
                {% elsif title_low contains 'namkeen' or title_low contains 'mast mix' %}
                  PACK OF 1 NAMKEEN
                {% elsif title_low contains '20' or title_low contains '2 pack' %}
                  PACK OF 2 • 20 BARS
                {% elsif title_low contains '60' %}
                  PACK OF 6 • 60 BARS
                {% else %}
                  PACK OF 1 • 10 BARS
                {% endif %}
              </div>

              <!-- Price & Discount Badge Row -->
              <div class="avyah-card-price-row">
                <div class="avyah-card-price">
                  Rs. {{ product.price | money_without_currency }}
                </div>
                {% if product.compare_at_price > product.price %}
                  {% assign discount_percent = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <div class="avyah-card-discount-badge">-{{ discount_percent }}% OFF</div>
                {% else %}
                  <div class="avyah-card-discount-badge">-8% OFF</div>
                {% endif %}
              </div>

              <!-- ADD TO CART Button -->
              <form action="/cart/add" method="post" enctype="multipart/form-data" class="avyah-card-quick-add-form">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button
                  type="submit"
                  class="avyah-card-add-to-cart-btn"
                  {% unless product.available %}disabled{% endunless %}
                >
                  {% if product.available %}ADD TO CART{% else %}OUT OF STOCK{% endif %}
                </button>
              </form>
            </div>
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: display_products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}
  </div>
</results-list>

<!-- Bespoke Collection FAQ Section (Below Listing) -->
<div class="avyah-collection-faq-section">
  <div class="avyah-collection-faq-container">
    <div class="avyah-collection-faq-header">
      <span class="avyah-faq-tag">HELP & INFORMATION</span>
      <h2 class="avyah-faq-title">FREQUENTLY ASKED QUESTIONS</h2>
      <p class="avyah-faq-subtitle">Got questions about our healthy multigrain snacks? We've got answers.</p>
    </div>

    <div class="avyah-faq-accordion-list">
      <div class="avyah-faq-item">
        <button class="avyah-faq-question" type="button" aria-expanded="false">
          <span>What makes Avyah snacks healthier than regular commercial snacks?</span>
          <svg class="avyah-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="avyah-faq-answer">
          <p>Avyah snacks are 100% roasted (never deep-fried), made with real multigrain ingredients (oats, ragi, jowar, bajra), rich in dietary fiber, packed with plant protein, free from palm oil, zero trans fat, and prepared without artificial preservatives or flavor enhancers.</p>
        </div>
      </div>

      <div class="avyah-faq-item">
        <button class="avyah-faq-question" type="button" aria-expanded="false">
          <span>Are Taakat Hunger Bars suitable for diabetics or fitness enthusiasts?</span>
          <svg class="avyah-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="avyah-faq-answer">
          <p>Yes! Our Taakat Hunger Bars feature sugar-free and low-glycemic options packed with up to 5g+ of clean plant protein and multigrain fiber, making them an ideal guilt-free snack for pre/post workout energy, office hunger pangs, and diabetic-friendly nutrition.</p>
        </div>
      </div>

      <div class="avyah-faq-item">
        <button class="avyah-faq-question" type="button" aria-expanded="false">
          <span>What is Mast Mix and how is it prepared?</span>
          <svg class="avyah-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="avyah-faq-answer">
          <p>Mast Mix is our signature roasted Indian & Asian blend namkeen. It is slow-roasted to crisp perfection with zero palm oil, zero deep-frying, and seasoned with authentic Indian spices, crunchy nuts, and wholesome seeds for maximum crunch and taste.</p>
        </div>
      </div>

      <div class="avyah-faq-item">
        <button class="avyah-faq-question" type="button" aria-expanded="false">
          <span>Do you offer free shipping on bulk orders and combo packs?</span>
          <svg class="avyah-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="avyah-faq-answer">
          <p>Yes, we offer Free Shipping across India on Range Saver Packs, Maha Masti Packs, and all orders over ₹499! Plus, enjoy an extra 3% Prepaid Bonus discount when you complete payment online at checkout.</p>
        </div>
      </div>

      <div class="avyah-faq-item">
        <button class="avyah-faq-question" type="button" aria-expanded="false">
          <span>How long do Avyah snacks stay fresh?</span>
          <svg class="avyah-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="avyah-faq-answer">
          <p>All Avyah products come sealed in premium airtight barrier foil packaging that locks in crisp freshness for up to 6 to 9 months from the date of manufacturing. Store in a cool, dry place after opening.</p>
        </div>
      </div>

      <div class="avyah-faq-item">
        <button class="avyah-faq-question" type="button" aria-expanded="false">
          <span>Can I customize a Bulk Order or corporate gift hamper?</span>
          <svg class="avyah-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="avyah-faq-answer">
          <p>Absolutely! Visit our <a href="/pages/bulk-order" style="color:#d52528; text-decoration:underline;">Bulk Order Page</a> to build your custom snack box or reach out directly to our support team for bespoke corporate gifting packages.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
