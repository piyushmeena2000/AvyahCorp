{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-haspopup="dialog"
    aria-label="{{ 'accessibility.cart' | t }}"
    aria-describedby="cart-bubble-text"
    data-testid="cart-drawer-trigger"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header" style="background-color: #ffffff !important;">
            <h2 class="cart-drawer__heading h3" id="cart-drawer-heading-empty" style="color: #111111 !important;">
              Your Cart (0)
            </h2>
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
              style="color: #111111 !important;"
            >
              <span class="svg-wrapper" style="color: #111111 !important;">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="background-color: #ffffff !important; display: flex !important; flex-direction: column !important; justify-content: center !important; align-items: center !important;"
          >
            <div class="empty-cart-custom" style="padding: 60px 20px !important; text-align: center !important; background-color: #ffffff !important; width: 100% !important;">
              <div class="empty-cart-custom__icon-wrapper" style="margin-bottom: 20px !important; display: flex !important; justify-content: center !important;">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#111111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle>
                  <circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
              </div>
              <h3 style="font-family: 'Anton', sans-serif !important; font-weight: 400 !important; font-size: 22px !important; color: #111111 !important; text-transform: uppercase !important; margin: 0 0 8px 0 !important; letter-spacing: 0.5px !important;">Your Cart is Empty</h3>
              <p style="font-family: 'Inter', sans-serif !important; font-size: 14px !important; color: #666666 !important; margin: 0 0 24px 0 !important;">Looks like you haven't added anything to your cart yet.</p>
              <a href="/collections/all" style="display: inline-block !important; padding: 12px 28px !important; background-color: #d52528 !important; color: #ffffff !important; border-radius: 10px !important; font-family: 'Anton', sans-serif !important; font-weight: 400 !important; font-size: 15px !important; text-transform: uppercase !important; text-decoration: none !important;">Start Shopping</a>
            </div>
          </div>
        {%- else -%}
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <h2
              class="cart-drawer__heading h3"
              id="cart-drawer-heading"
              style="color: #111111 !important;"
            >
              Your Cart ({{ cart.item_count }})
            </h2>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
            <scroll-hint
              class="cart-drawer__items"
            >
              {% render 'cart-products' %}

              <!-- Upsell recommendations -->
              {% render 'cart-drawer-upsell' %}
            </scroll-hint>

            <div
              class="cart-drawer__summary"
            >
              {% render 'cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 26px;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer--empty .cart-drawer__header {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    border-bottom: 1px solid #f0f0f0 !important;
    padding-bottom: var(--padding-md) !important;
  }

  .cart-drawer--empty .cart-drawer__heading {
    text-align: left !important;
    margin-bottom: 0 !important;
  }

  /* PerfectSnacks Pure White Cart Drawer Dialog */
  .cart-drawer__dialog.cart-drawer__dialog {
    --color-background: #ffffff !important;
    --color-foreground: #111111 !important;
    --color-foreground-rgb: 17 17 17 !important;
    --color-heading: #111111 !important;
    --color-heading-rgb: 17 17 17 !important;
    --color-border: #f0f0f0 !important;
    --color-primary: #111111 !important;
    --color-primary-hover: #333333 !important;
    background-color: #ffffff !important;
    background: #ffffff !important;
    color: #111111 !important;
    width: min(520px, 100vw) !important;
    max-width: 100vw !important;
  }

  .cart-drawer__header {
    background-color: #ffffff !important;
    background: #ffffff !important;
    border-bottom: 1px solid #f0f0f0 !important;
  }

  .cart-drawer__heading.h3 {
    font-family: 'Anton', sans-serif !important;
    font-weight: 400 !important;
    text-transform: capitalize;
    font-size: 24px !important;
    color: #111111 !important;
  }

  .cart-drawer__close-button {
    color: #111111 !important;
  }

  .cart-drawer__close-button svg {
    fill: #111111 !important;
    stroke: #111111 !important;
    color: #111111 !important;
  }

  .empty-cart-custom {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--padding-md);
    text-align: center;
    width: 100%;
    height: 100%;
    justify-content: center;
    box-sizing: border-box;
    background-color: #ffffff !important;
  }

  .empty-cart-custom__text {
    font-family: 'Inter', sans-serif !important;
    font-size: 16px !important;
    font-weight: 500 !important;
    color: #666666 !important;
    margin-top: 15px !important;
  }

  .empty-cart-custom__icon-wrapper {
    color: #cccccc;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .empty-cart-custom__icon-wrapper svg {
    width: 100%;
    height: 100%;
    fill: #cccccc !important;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
    background-color: #ffffff !important;
  }
 
  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
    background-color: #ffffff !important;
  }
 
  .cart-drawer__summary {
    background-color: #ffffff !important;
    background: #ffffff !important;
    position: sticky;
    bottom: 0;
    z-index: 1;
    border-top: 1px solid #f0f0f0 !important;
  }

  /* PerfectSnacks White Flexbox Cart Items */
  .perfect-cart-items-wrapper {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
    background-color: #ffffff !important;
  }

  .perfect-cart-item-row {
    display: flex !important;
    align-items: flex-start !important;
    gap: 16px !important;
    padding: 18px 20px !important;
    border-bottom: 1px solid #f0f0f0 !important;
    background-color: #ffffff !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  .perfect-cart-item-image-box {
    width: 96px !important;
    height: 96px !important;
    min-width: 96px !important;
    border-radius: 16px !important;
    overflow: hidden !important;
    padding: 8px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-sizing: border-box !important;
  }

  /* Pastel Background Cycle for Images */
  .perfect-cart-item-row:nth-child(5n+1) .perfect-cart-item-image-box { background-color: #fef3d6 !important; }
  .perfect-cart-item-row:nth-child(5n+2) .perfect-cart-item-image-box { background-color: #e5e4f4 !important; }
  .perfect-cart-item-row:nth-child(5n+3) .perfect-cart-item-image-box { background-color: #d8f2f2 !important; }
  .perfect-cart-item-row:nth-child(5n+4) .perfect-cart-item-image-box { background-color: #e0f2e7 !important; }
  .perfect-cart-item-row:nth-child(5n+5) .perfect-cart-item-image-box { background-color: #f7e6e7 !important; }

  .perfect-cart-item-image-box img {
    max-width: 100% !important;
    max-height: 100% !important;
    object-fit: contain !important;
  }

  .perfect-cart-item-info {
    flex: 1 !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 2px !important;
    min-width: 0 !important;
  }

  .perfect-cart-item-header {
    display: flex !important;
    justify-content: space-between !important;
    align-items: flex-start !important;
    gap: 10px !important;
    width: 100% !important;
  }

  .perfect-cart-item-title {
    font-family: 'Anton', sans-serif !important;
    font-size: 16px !important;
    font-weight: 700 !important;
    color: #111111 !important;
    text-decoration: none !important;
    line-height: 1.25 !important;
    margin: 0 !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 2 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
    word-break: break-word !important;
  }

  .perfect-cart-item-prices {
    text-align: right !important;
    white-space: nowrap !important;
    flex-shrink: 0 !important;
  }

  .perfect-price-sale {
    font-family: 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    color: #111111 !important;
  }

  .perfect-price-compare {
    font-family: 'Inter', sans-serif !important;
    font-weight: 500 !important;
    font-size: 13px !important;
    color: #888888 !important;
    text-decoration: line-through !important;
    margin-left: 6px !important;
  }

  .perfect-cart-item-subtitle {
    font-family: 'Inter', sans-serif !important;
    font-size: 12px !important;
    font-weight: 500 !important;
    color: #555555 !important;
  }

  .perfect-cart-item-offer {
    font-family: 'Inter', sans-serif !important;
    font-size: 11px !important;
    font-weight: 800 !important;
    letter-spacing: 0.5px !important;
    color: #333333 !important;
    text-transform: uppercase !important;
    margin-top: 2px !important;
  }

  .perfect-cart-item-controls {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: 12px !important;
    margin-top: 6px !important;
    width: 100% !important;
  }

  .perfect-quantity-stepper {
    display: inline-flex !important;
    align-items: center !important;
    border: 1px solid #d5d5d5 !important;
    border-radius: 50px !important;
    height: 32px !important;
    width: 90px !important;
    background-color: #ffffff !important;
    overflow: hidden !important;
    box-sizing: border-box !important;
  }

  .perfect-quantity-stepper button {
    width: 28px !important;
    height: 100% !important;
    border: none !important;
    background: transparent !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    color: #111111 !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .perfect-quantity-stepper button:hover {
    background-color: #f5f5f5 !important;
  }

  .perfect-quantity-stepper button svg {
    width: 10px !important;
    height: 10px !important;
    color: #111111 !important;
    stroke: #111111 !important;
  }

  .perfect-quantity-stepper input {
    width: 34px !important;
    height: 100% !important;
    border: none !important;
    background: transparent !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 13px !important;
    font-weight: 700 !important;
    color: #111111 !important;
    text-align: center !important;
    padding: 0 !important;
    margin: 0 !important;
    appearance: textfield !important;
  }

  .perfect-quantity-stepper input::-webkit-outer-spin-button,
  .perfect-quantity-stepper input::-webkit-inner-spin-button {
    -webkit-appearance: none !important;
    margin: 0 !important;
  }

  .perfect-remove-btn {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    color: #111111 !important;
    text-decoration: underline !important;
    cursor: pointer !important;
    margin-top: 2px !important;
  }

  .perfect-remove-btn:hover {
    color: #d52528 !important;
  }
  }

  .cart-drawer .cart-items__price {
    grid-area: price !important;
    font-family: 'Inter', sans-serif !important;
    font-weight: 800 !important;
    font-size: 17px !important;
    color: #111111 !important;
    text-align: right !important;
  }

  .cart-drawer .cart-items__remove svg {
    color: #666666 !important;
    fill: #666666 !important;
    stroke: #666666 !important;
  }

  /* Style cart summary in drawer */
  .cart-drawer .cart__summary-container {
    background-color: #ffffff !important;
    background: #ffffff !important;
    border-top: 1px solid #f0f0f0 !important;
    padding: 20px !important;
    box-shadow: none !important;
  }

  .cart-drawer .cart__summary-totals {
    border: none !important;
    padding: 0 !important;
    margin-bottom: 15px !important;
  }

  .cart-drawer .cart__total-label {
    font-family: 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: 14px !important;
    color: #111111 !important;
  }

  .cart-drawer .cart__total-value,
  .cart-drawer [data-cart-subtotal] {
    font-family: 'Inter', sans-serif !important;
    font-weight: 800 !important;
    font-size: 22px !important;
    color: #111111 !important;
  }

  .cart-drawer .tax-note,
  .cart-drawer .tax-note * {
    color: #666666 !important;
  }

  /* Checkout Button - CRIMSON RED CTA BUTTON WITH WHITE TEXT */
  .cart-drawer .cart__checkout-button,
  .cart-drawer button#checkout {
    background-color: #d52528 !important;
    background: #d52528 !important;
    color: #ffffff !important;
    border-radius: 50px !important;
    height: 52px !important;
    font-family: 'Anton', sans-serif !important;
    font-size: 19px !important;
    font-weight: 400 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.8px !important;
    box-shadow: 0 4px 15px rgba(213, 37, 40, 0.25) !important;
    border: none !important;
    transition: all 0.25s ease !important;
    width: 100% !important;
  }

  .cart-drawer .cart__checkout-button *,
  .cart-drawer button#checkout * {
    color: #ffffff !important;
  }

  .cart-drawer .cart__checkout-button:hover,
  .cart-drawer button#checkout:hover {
    background-color: #c01b1e !important;
    background: #c01b1e !important;
    color: #ffffff !important;
    box-shadow: 0 6px 20px rgba(213, 37, 40, 0.4) !important;
  }
{% endstylesheet %}
