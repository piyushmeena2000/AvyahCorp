{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-haspopup="dialog"
    aria-label="{{ 'accessibility.cart' | t }}"
    aria-describedby="cart-bubble-text"
    data-testid="cart-drawer-trigger"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header">
            <h2 class="cart-drawer__heading h3" id="cart-drawer-heading-empty">
              Your Cart (0)
            </h2>
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
          >
            <div class="empty-cart-custom">
              <div class="empty-cart-custom__icon-wrapper">
                {{- 'icon-cart.svg' | inline_asset_content -}}
              </div>
              <p class="empty-cart-custom__text">Your cart is currently empty.</p>
            </div>
          </div>
        {%- else -%}
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <h2
              class="cart-drawer__heading h3"
              id="cart-drawer-heading"
            >
              Your Cart ({{ cart.item_count }})
            </h2>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          {% render 'cart-progress-bar' %}

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
            <scroll-hint
              class="cart-drawer__items"
            >
              {% render 'cart-products' %}

              <!-- Upsell recommendations -->
              {% render 'cart-drawer-upsell' %}
            </scroll-hint>

            <div
              class="cart-drawer__summary"
            >
              {% render 'cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 26px;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer--empty .cart-drawer__header {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    border-bottom: 1px solid #e6e6e6 !important;
    padding-bottom: var(--padding-md) !important;
  }

  .cart-drawer--empty .cart-drawer__heading {
    text-align: left !important;
    margin-bottom: 0 !important;
  }

  .cart-drawer__dialog.cart-drawer__dialog {
    --color-background: #ffffff !important;
    --color-foreground: #111111 !important;
    --color-foreground-rgb: 17 17 17 !important;
    --color-heading: #111111 !important;
    --color-heading-rgb: 17 17 17 !important;
    --color-border: #e6e6e6 !important;
    --color-primary: #111111 !important;
    --color-primary-hover: #333333 !important;
    background-color: #ffffff !important;
    background: #ffffff !important;
    color: #111111 !important;
    width: min(520px, 100vw) !important;
    max-width: 100vw !important;
  }

  .cart-drawer__header {
    background-color: #ffffff !important;
    background: #ffffff !important;
    border-bottom: 1px solid #f0f0f0 !important;
  }

  .cart-drawer__heading.h3 {
    font-family: 'Anton', sans-serif !important;
    font-weight: 400 !important;
    text-transform: capitalize;
    font-size: 24px !important;
    color: #111111 !important;
  }

  .cart-drawer__close-button {
    color: #111111 !important;
  }

  .cart-drawer__close-button svg {
    fill: #111111 !important;
    color: #111111 !important;
  }

  .empty-cart-custom {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--padding-md);
    text-align: center;
    width: 100%;
    height: 100%;
    justify-content: center;
    box-sizing: border-box;
    background-color: #ffffff !important;
  }

  .empty-cart-custom__text {
    font-family: 'Inter', sans-serif !important;
    font-size: 16px !important;
    font-weight: 500 !important;
    color: #666666 !important;
    margin-top: 15px !important;
  }

  .empty-cart-custom__icon-wrapper {
    color: #cccccc;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .empty-cart-custom__icon-wrapper svg {
    width: 100%;
    height: 100%;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
    background-color: #ffffff !important;
  }
 
  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
    background-color: #ffffff !important;
  }
 
  .cart-drawer__summary {
    background-color: #ffffff !important;
    position: sticky;
    bottom: 0;
    z-index: 1;
    border-top: 1px solid #f0f0f0 !important;
  }

  /* Force table layout to blocks to prevent horizontal table scrolling */
  .cart-drawer .cart-items__table {
    display: block !important;
    width: 100% !important;
  }
  .cart-drawer .cart-items__table tbody {
    display: block !important;
    width: 100% !important;
  }

  /* PerfectSnacks Cart Drawer Items Redesign */
  .cart-drawer .cart-items__table-row {
    display: grid !important;
    grid-template-columns: 100px 1fr auto !important;
    grid-template-rows: auto auto !important;
    grid-template-areas:
      'media details price'
      'media quantity price' !important;
    align-items: center !important;
    column-gap: 16px !important;
    padding: 18px 20px !important;
    margin-bottom: 0 !important;
    border-bottom: 1px solid #f0f0f0 !important;
    width: 100% !important;
    box-sizing: border-box !important;
    overflow: hidden !important;
    background-color: #ffffff !important;
  }

  .cart-drawer .cart-items__media {
    grid-area: media !important;
    width: 100px !important;
    height: 100px !important;
    border-radius: 16px !important;
    overflow: hidden !important;
    padding: 8px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-sizing: border-box !important;
  }

  /* Cycling Pastel Backgrounds for Cart Item Images */
  .cart-drawer .cart-items__table-row:nth-child(5n+1) .cart-items__media { background-color: #fef3d6 !important; }
  .cart-drawer .cart-items__table-row:nth-child(5n+2) .cart-items__media { background-color: #e5e4f4 !important; }
  .cart-drawer .cart-items__table-row:nth-child(5n+3) .cart-items__media { background-color: #d8f2f2 !important; }
  .cart-drawer .cart-items__table-row:nth-child(5n+4) .cart-items__media { background-color: #e0f2e7 !important; }
  .cart-drawer .cart-items__table-row:nth-child(5n+5) .cart-items__media { background-color: #f7e6e7 !important; }

  .cart-drawer .cart-items__media-container,
  .cart-drawer .cart-items__media img {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important;
    border-radius: 10px !important;
  }

  .cart-drawer .cart-items__details {
    grid-area: details !important;
    padding: 0 !important;
    color: #111111 !important;
  }

  .cart-drawer .cart-items__title {
    font-family: 'Anton', sans-serif !important;
    font-size: 18px !important;
    text-transform: capitalize !important;
    color: #111111 !important;
    text-decoration: none !important;
    line-height: 1.25 !important;
    display: block !important;
    margin-bottom: 4px !important;
    white-space: normal !important;
    word-break: break-word !important;
  }

  .cart-drawer .cart-items__variants {
    font-family: 'Inter', sans-serif !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    color: #666666 !important;
    margin-bottom: 6px !important;
  }

  /* Style cart drawer quantity and remove button */
  .cart-drawer .cart-items__quantity {
    grid-area: quantity !important;
    margin-top: 6px !important;
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
  }

  .cart-drawer .quantity-selector {
    border: 1px solid #d5d5d5 !important;
    border-radius: 50px !important;
    height: 32px !important;
    width: 88px !important;
    background-color: #ffffff !important;
  }

  .cart-drawer .quantity-selector button {
    width: 26px !important;
    height: 100% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 13px !important;
    font-weight: 700 !important;
    color: #111111 !important;
    background-color: transparent !important;
    border: none !important;
  }

  .cart-drawer .quantity-selector input {
    font-size: 13px !important;
    font-weight: 700 !important;
    color: #111111 !important;
    background-color: transparent !important;
  }

  .cart-drawer .cart-items__price {
    grid-area: price !important;
    font-family: 'Inter', sans-serif !important;
    font-weight: 800 !important;
    font-size: 17px !important;
    color: #111111 !important;
    text-align: right !important;
  }

  /* Style cart summary in drawer */
  .cart-drawer .cart__summary-container {
    background-color: #ffffff !important;
    border-top: 1px solid #f0f0f0 !important;
    padding: 20px !important;
    box-shadow: none !important;
  }

  .cart-drawer .cart__summary-totals {
    border: none !important;
    padding: 0 !important;
    margin-bottom: 15px !important;
  }

  .cart-drawer .cart__total-label {
    font-family: 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: 14px !important;
    color: #111111 !important;
  }

  .cart-drawer .cart__total-value,
  .cart-drawer [data-cart-subtotal] {
    font-family: 'Inter', sans-serif !important;
    font-weight: 800 !important;
    font-size: 22px !important;
    color: #111111 !important;
  }

  .cart-drawer .tax-note,
  .cart-drawer .tax-note * {
    color: #666666 !important;
  }

  /* Redesigned Checkout Button matching PerfectSnacks */
  .cart-drawer .cart__checkout-button,
  .cart-drawer button#checkout {
    background-color: #d52528 !important;
    background: #d52528 !important;
    color: #ffffff !important;
    border-radius: 50px !important;
    height: 52px !important;
    font-family: 'Anton', sans-serif !important;
    font-size: 19px !important;
    font-weight: 400 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.8px !important;
    box-shadow: 0 4px 15px rgba(213, 37, 40, 0.25) !important;
    border: none !important;
    transition: all 0.25s ease !important;
    width: 100% !important;
  }

  .cart-drawer .cart__checkout-button:hover,
  .cart-drawer button#checkout:hover {
    background-color: #c01b1e !important;
    background: #c01b1e !important;
    box-shadow: 0 6px 20px rgba(213, 37, 40, 0.4) !important;
  }
{% endstylesheet %}
