{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-haspopup="dialog"
    aria-label="{{ 'accessibility.cart' | t }}"
    aria-describedby="cart-bubble-text"
    data-testid="cart-drawer-trigger"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header">
            <h2 class="cart-drawer__heading h3" id="cart-drawer-heading-empty">
              Your Cart (0)
            </h2>
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
          >
            <div class="empty-cart-custom">
              <h3 class="empty-cart-custom__title">An Empty Cart<br>Full Of Cravings</h3>
              
              <div class="empty-cart-custom__grid">
                <a href="/collections/taakat-hunger-bar" class="empty-cart-custom__item">
                  <div class="empty-cart-custom__image-wrapper">
                    <img src="{{ 'cart_taakat_hunger_bar.png' | asset_url }}" alt="Taakat Hunger Bar" loading="lazy">
                  </div>
                  <span class="empty-cart-custom__item-title">TAAKAT HUNGER BAR</span>
                </a>
                
                <a href="/collections/mast-mix" class="empty-cart-custom__item">
                  <div class="empty-cart-custom__image-wrapper">
                    <img src="{{ 'cart_mast_mix.png' | asset_url }}" alt="Mast Mix" loading="lazy">
                  </div>
                  <span class="empty-cart-custom__item-title">MAST MIX</span>
                </a>
                
                <a href="/collections/king" class="empty-cart-custom__item">
                  <div class="empty-cart-custom__image-wrapper">
                    <img src="{{ 'cart_king.png' | asset_url }}" alt="King" loading="lazy">
                  </div>
                  <span class="empty-cart-custom__item-title">KING</span>
                </a>
              </div>
              
              <a href="{{ routes.all_products_collection_url }}" class="empty-cart-custom__shop-all-btn button">
                SHOP ALL
              </a>
            </div>
          </div>
        {%- else -%}
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <h2
              class="cart-drawer__heading h3"
              id="cart-drawer-heading"
            >
              {{ 'content.cart_title' | t }}
              {% render 'cart-bubble' %}
            </h2>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
            <scroll-hint
              class="cart-drawer__items"
            >
              {% render 'cart-products' %}
            </scroll-hint>

            <div
              class="cart-drawer__summary"
            >
              {% render 'cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 26px;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer--empty .cart-drawer__header {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    border-bottom: 1px solid #e6e6e6 !important;
    padding-bottom: var(--padding-md) !important;
  }

  .cart-drawer--empty .cart-drawer__heading {
    text-align: left !important;
    margin-bottom: 0 !important;
  }

  .cart-drawer__dialog.cart-drawer__dialog {
    --color-background: #ffffff;
    --color-foreground: #000000;
    --color-foreground-rgb: 0 0 0;
    --color-heading: #000000;
    --color-heading-rgb: 0 0 0;
    --color-border: #e6e6e6;
    --color-primary: #000000;
    --color-primary-hover: #333333;
    background-color: #ffffff;
  }

  .cart-drawer__heading.h3 {
    font-family: var(--font-h3--family), 'Anton', sans-serif !important;
    font-weight: 400 !important;
    text-transform: capitalize;
    font-size: 1.8rem;
    color: #000000;
  }

  .empty-cart-custom {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--padding-md);
    text-align: center;
    width: 100%;
    height: 100%;
    justify-content: center;
    box-sizing: border-box;
  }

  .empty-cart-custom__title {
    font-family: var(--font-h2--family), 'Anton', sans-serif !important;
    font-size: 2.2rem;
    line-height: 1.2;
    margin-block: 0 var(--margin-lg);
    color: #333333;
    font-weight: 400 !important;
    max-width: 90%;
  }

  .empty-cart-custom__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap-md);
    width: 100%;
    margin-bottom: var(--margin-xl);
  }

  .empty-cart-custom__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .empty-cart-custom__item:hover {
    transform: scale(1.02);
  }

  .empty-cart-custom__item:last-child {
    grid-column: span 2;
    width: calc(50% - var(--gap-md) / 2);
    margin-inline: auto;
  }

  .empty-cart-custom__image-wrapper {
    width: 100%;
    aspect-ratio: 1.2;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: var(--margin-xs);
    background-color: #f7f7f7;
  }

  .empty-cart-custom__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .empty-cart-custom__item-title {
    font-family: var(--font-paragraph--family), 'Inter', sans-serif !important;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #2b2b2b;
    text-transform: uppercase;
  }

  .empty-cart-custom__shop-all-btn.button {
    font-family: var(--font-h2--family), 'Anton', sans-serif !important;
    font-weight: 400 !important;
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    background-color: #d52528 !important;
    color: #ffffff !important;
    border-radius: 50px !important;
    width: 90% !important;
    padding-block: var(--padding-md) !important;
    text-transform: uppercase;
    text-align: center;
    display: block;
    margin-inline: auto;
    transition: background-color 0.2s ease;
    box-shadow: none !important;
  }

  .empty-cart-custom__shop-all-btn.button:hover {
    background-color: #a72023 !important;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__summary {
    background-color: var(--color-background);
    position: sticky;
    bottom: 0;
    z-index: 1;
  }
{% endstylesheet %}
