{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-haspopup="dialog"
    aria-label="{{ 'accessibility.cart' | t }}"
    aria-describedby="cart-bubble-text"
    data-testid="cart-drawer-trigger"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header">
            <h2 class="cart-drawer__heading h3" id="cart-drawer-heading-empty">
              Your Cart (0)
            </h2>
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
          >
            <div class="empty-cart-custom">
              <div class="empty-cart-custom__icon-wrapper">
                {{- 'icon-cart.svg' | inline_asset_content -}}
              </div>
            </div>
          </div>
        {%- else -%}
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <h2
              class="cart-drawer__heading h3"
              id="cart-drawer-heading"
            >
              Your Cart ({{ cart.item_count }})
            </h2>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <!-- Bundle Progress Tracker -->
          {%- liquid
            assign total_boxes = cart.item_count
            assign pct = 0
            if total_boxes == 1
              assign pct = 0
            elsif total_boxes == 2
              assign pct = 33
            elsif total_boxes == 3
              assign pct = 66
            elsif total_boxes >= 4
              assign pct = 100
            endif
          -%}
          <div class="cart-drawer-progress-container">
            <div class="cart-drawer-progress-line-bg"></div>
            <div class="cart-drawer-progress-line-fill" style="width: {{ pct }}%;"></div>
            
            <div class="cart-drawer-progress-steps">
              <div class="cart-drawer-step {% if total_boxes >= 1 %}active{% endif %}" style="left: 0%;">
                <div class="step-dot">{% if total_boxes >= 1 %}✓{% endif %}</div>
                <div class="step-label">1 Box</div>
              </div>
              <div class="cart-drawer-step {% if total_boxes >= 2 %}active{% endif %}" style="left: 33%;">
                <div class="step-discount">10% OFF</div>
                <div class="step-dot">{% if total_boxes >= 2 %}✓{% endif %}</div>
                <div class="step-label">2 Boxes</div>
              </div>
              <div class="cart-drawer-step {% if total_boxes >= 3 %}active{% endif %}" style="left: 66%;">
                <div class="step-discount">20% OFF</div>
                <div class="step-dot">{% if total_boxes >= 3 %}✓{% endif %}</div>
                <div class="step-label">3 Boxes</div>
              </div>
              <div class="cart-drawer-step {% if total_boxes >= 4 %}active{% endif %}" style="left: 100%;">
                <div class="step-discount-wrap">
                  <div class="step-badge">Best Value</div>
                  <div class="step-discount">30% OFF</div>
                </div>
                <div class="step-dot">{% if total_boxes >= 4 %}✓{% endif %}</div>
                <div class="step-label">4 Boxes</div>
              </div>
            </div>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
            <scroll-hint
              class="cart-drawer__items"
            >
              {% render 'cart-products' %}
            </scroll-hint>

            <div
              class="cart-drawer__summary"
            >
              {% render 'cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 26px;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer--empty .cart-drawer__header {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    border-bottom: 1px solid #e6e6e6 !important;
    padding-bottom: var(--padding-md) !important;
  }

  .cart-drawer--empty .cart-drawer__heading {
    text-align: left !important;
    margin-bottom: 0 !important;
  }

  .cart-drawer__dialog.cart-drawer__dialog {
    --color-background: #ffffff;
    --color-foreground: #000000;
    --color-foreground-rgb: 0 0 0;
    --color-heading: #000000;
    --color-heading-rgb: 0 0 0;
    --color-border: #e6e6e6;
    --color-primary: #000000;
    --color-primary-hover: #333333;
    background-color: #ffffff;
  }

  .cart-drawer__heading.h3 {
    font-family: var(--font-h3--family), 'Anton', sans-serif !important;
    font-weight: 400 !important;
    text-transform: capitalize;
    font-size: 1.8rem;
    color: #000000;
  }

  .empty-cart-custom {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--padding-md);
    text-align: center;
    width: 100%;
    height: 100%;
    justify-content: center;
    box-sizing: border-box;
  }

  .empty-cart-custom__icon-wrapper {
    color: #cccccc;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .empty-cart-custom__icon-wrapper svg {
    width: 100%;
    height: 100%;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }
 
  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
  }
 
  .cart-drawer__summary {
    background-color: var(--color-background);
    position: sticky;
    bottom: 0;
    z-index: 1;
  }

  /* Bundle Progress Tracker styles */
  .cart-drawer-progress-container {
    padding: 35px 30px 20px;
    background-color: #ffffff;
    position: relative;
    border-bottom: 1px solid #f0f0f0;
  }
  .cart-drawer-progress-line-bg {
    position: absolute;
    top: 55px; /* aligned with center of dot */
    left: 45px;
    right: 45px;
    height: 3px;
    background-color: #e6e6e6;
    z-index: 1;
  }
  .cart-drawer-progress-line-fill {
    position: absolute;
    top: 55px;
    left: 45px;
    right: 45px;
    height: 3px;
    background-color: #a72023; /* Brand Red */
    z-index: 2;
    transition: width 0.4s ease;
  }
  .cart-drawer-progress-steps {
    position: relative;
    height: 65px;
    z-index: 3;
  }
  .cart-drawer-step {
    position: absolute;
    top: 20px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 80px;
  }
  .step-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: #ffffff;
    border: 2px solid #e6e6e6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: bold;
    color: transparent;
    transition: all 0.3s ease;
    margin-bottom: 8px;
  }
  .cart-drawer-step.active .step-dot {
    background-color: #a72023;
    border-color: #a72023;
    color: #ffffff;
  }
  .step-label {
    font-size: 11px;
    font-weight: 700;
    color: #888888;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .cart-drawer-step.active .step-label {
    color: #333333;
  }
  .step-discount {
    font-size: 11px;
    font-weight: 800;
    color: #888888;
    position: absolute;
    bottom: 35px; /* Above the dot */
    white-space: nowrap;
    text-transform: uppercase;
  }
  .cart-drawer-step.active .step-discount {
    color: #a72023;
  }
  .step-discount-wrap {
    position: absolute;
    bottom: 35px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .step-badge {
    background-color: #2e8b57; /* sea green */
    color: #ffffff;
    font-size: 8px;
    font-weight: 800;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 3px;
    letter-spacing: 0.5px;
    line-height: 1;
    white-space: nowrap;
  }

  /* Cart Drawer Items Redesign */
  .cart-drawer .cart-items__table-row {
    display: grid !important;
    grid-template-columns: 80px 1fr auto !important;
    grid-template-rows: auto auto !important;
    grid-template-areas:
      'media details price'
      'media quantity price' !important;
    align-items: center !important;
    column-gap: 15px !important;
    padding: 15px 20px !important;
    margin-bottom: 0 !important;
    border-bottom: 1px solid #f0f0f0 !important;
  }

  .cart-drawer .cart-items__media {
    grid-area: media !important;
    width: 80px !important;
    border-radius: 8px !important;
    overflow: hidden !important;
    background-color: #f7f7f7 !important;
  }

  .cart-drawer .cart-items__details {
    grid-area: details !important;
    padding: 0 !important;
  }

  .cart-drawer .cart-items__title {
    font-family: 'Anton', sans-serif !important;
    font-size: 16px !important;
    text-transform: uppercase !important;
    color: #333333 !important;
    text-decoration: none !important;
    line-height: 1.2 !important;
    display: block !important;
    margin-bottom: 4px !important;
  }

  .cart-drawer .cart-items__variants {
    font-size: 12px !important;
    color: #666666 !important;
    margin-bottom: 4px !important;
  }

  /* Style cart drawer quantity and remove button */
  .cart-drawer .cart-items__quantity {
    grid-area: quantity !important;
    margin-top: 5px !important;
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
  }

  .cart-drawer .quantity-selector {
    border: 1px solid #e6e6e6 !important;
    border-radius: 50px !important;
    height: 32px !important;
    width: 90px !important;
    background-color: #f9f9f9 !important;
  }

  .cart-drawer .quantity-selector button {
    width: 28px !important;
    height: 100% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 14px !important;
  }

  .cart-drawer .quantity-selector input {
    font-size: 13px !important;
  }

  /* CSS Hack to turn Delete Icon into 'Remove' Text link */
  .cart-drawer .cart-items__remove {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    width: auto !important;
    height: auto !important;
    box-shadow: none !important;
    cursor: pointer !important;
    display: inline-block !important;
    margin: 0 !important;
  }

  .cart-drawer .cart-items__remove svg {
    display: none !important;
  }

  .cart-drawer .cart-items__remove::after {
    content: 'Remove' !important;
    font-family: 'Inter', sans-serif !important;
    font-size: 13px !important;
    color: #888888 !important;
    text-decoration: underline !important;
    font-weight: 500 !important;
    display: inline-block !important;
  }

  .cart-drawer .cart-items__remove:hover::after {
    color: #a72023 !important;
  }

  .cart-drawer .cart-items__price {
    grid-area: price !important;
    font-family: 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: 16px !important;
    color: #333333 !important;
    text-align: right !important;
  }

  /* Style cart summary in drawer */
  .cart-drawer .cart__summary-container {
    background-color: #ffffff !important;
    border-top: 1px solid #f0f0f0 !important;
    padding: 20px !important;
    box-shadow: none !important;
  }

  .cart-drawer .cart__summary-totals {
    border: none !important;
    padding: 0 !important;
    margin-bottom: 15px !important;
  }

  .cart-drawer .cart__total-label {
    font-family: 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: 14px !important;
    color: #666666 !important;
  }

  .cart-drawer .cart__total-value {
    font-family: 'Inter', sans-serif !important;
    font-weight: 800 !important;
    font-size: 22px !important;
    color: #a72023 !important;
  }

  .cart-drawer .cart__checkout-button {
    background-color: #a72023 !important;
    color: #ffffff !important;
    border-radius: 50px !important;
    height: 48px !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    box-shadow: 0 4px 15px rgba(167, 32, 35, 0.15) !important;
  }

  .cart-drawer .cart__checkout-button:hover {
    background-color: #8f1b1e !important;
  }
{% endstylesheet %}
