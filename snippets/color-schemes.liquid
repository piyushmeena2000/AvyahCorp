{% style %}
  :root,
  body.template-index,
  body.template-index #MainContent,
  body.template-index main,
  body.template-index .content-for-layout,
  body.template-index .shopify-section,
  body.template-index .shopify-section > div,
  body.template-index section,
  body.template-index .section,
  body.template-index [class*="section"],
  body.template-index .section-background,
  body.template-index [class*="color-scheme"],
  body.template-index [class*="color-scheme"] > div,
  body.template-index [class*="scheme-"],
  body.template-index [class*="ai_gen_block"],
  body.template-index .text-block,
  body.template-index .rich-text {
    --color-background: 213, 37, 40 !important;
    --color-background-rgb: 213, 37, 40 !important;
    --gradient-background: #d52528 !important;
    background-color: #d52528 !important;
    background: #d52528 !important;
  }

  body.template-index h1:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index h2:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index h3:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index h4:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index h5:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index h6:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index p:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index span:not(.jdgm-prev-badge__text):not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index .rte:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *),
  body.template-index .rte *:not(dialog *):not(.cart-drawer *):not(cart-drawer-component *) {
    color: #ffffff !important;
  }

  body.template-index [class*="ai_gen_block_200d848"] [class*="card"],
  body.template-index [class*="ai_gen_block_200d848"] div[class*="item"],
  body.template-index [class*="ai_gen_block_200d848"] > div > div {
    background-color: #a72023 !important;
    background: #a72023 !important;
    color: #ffffff !important;
    transition: background-color 0.3s ease, color 0.3s ease !important;
  }

  body.template-index [class*="ai_gen_block_200d848"] [class*="card"]:hover,
  body.template-index [class*="ai_gen_block_200d848"] div[class*="item"]:hover,
  body.template-index [class*="ai_gen_block_200d848"] > div > div:hover {
    background-color: #ffffff !important;
    background: #ffffff !important;
  }

  body.template-index [class*="ai_gen_block_200d848"] [class*="card"]:hover::before,
  body.template-index [class*="ai_gen_block_200d848"] div[class*="item"]:hover::before,
  body.template-index [class*="ai_gen_block_200d848"] > div > div:hover::before {
    background-color: #ffffff !important;
    opacity: 1 !important;
  }

  body.template-index [class*="ai_gen_block_200d848"] [class*="card"]:hover *,
  body.template-index [class*="ai_gen_block_200d848"] div[class*="item"]:hover *,
  body.template-index [class*="ai_gen_block_200d848"] > div > div:hover *,
  body.template-index [class*="ai_gen_block_200d848"] [class*="card"]:hover h3,
  body.template-index [class*="ai_gen_block_200d848"] [class*="card"]:hover p {
    color: #d52528 !important;
    background: transparent !important;
    background-color: transparent !important;
  }

  body.template-index [class*="ai_gen_block_200d848"] [class*="card"]:hover img,
  body.template-index [class*="ai_gen_block_200d848"] div[class*="item"]:hover img,
  body.template-index [class*="ai_gen_block_200d848"] > div > div:hover img {
    filter: brightness(0) saturate(100%) invert(21%) sepia(85%) saturate(2462%) hue-rotate(345deg) brightness(91%) contrast(92%) !important;
  }

/* ==========================================================================
   CUSTOMER REVIEWS SECTION - RED SECTION BG, SOLID PURE WHITE CARDS
   ========================================================================== */
  body.template-index #shopify-section-blocks_zFCw9K,
  body.template-index .shopify-section:has([class*="c24781f"]),
  body.template-index .section:has([class*="c24781f"]),
  body.template-index [class*="c24781f"],
  body.template-index [class*="c24781f"] [class*="container"],
  body.template-index [class*="c24781f"] [class*="header"],
  body.template-index [class*="c24781f"] [class*="track-wrapper"] {
    background-color: #d52528 !important;
    background: #d52528 !important;
  }

  /* Section Title & Subtitle - WHITE text */
  body.template-index [class*="c24781f"] [class*="title"],
  body.template-index [class*="c24781f"] [class*="subtitle"],
  body.template-index [class*="c24781f"] h2,
  body.template-index [class*="c24781f"] [class*="header"] * {
    color: #ffffff !important;
    background: transparent !important;
    background-color: transparent !important;
  }

  /* ONLY Review Cards & all elements inside them - 100% SOLID WHITE BACKGROUND */
  body.template-index [class*="c24781f"] [class*="card"],
  body.template-index [class*="c24781f"] [class*="card"] *,
  body.template-index [class*="c24781f"] [class*="slide"] > div,
  body.template-index [class*="c24781f"] [class*="slide"] > div * {
    background-color: #ffffff !important;
    background: #ffffff !important;
  }

  /* Text colors inside cards */
  body.template-index [class*="c24781f"] [class*="card"] p,
  body.template-index [class*="c24781f"] [class*="card"] span,
  body.template-index [class*="c24781f"] [class*="card"] b,
  body.template-index [class*="c24781f"] [class*="card"] strong,
  body.template-index [class*="c24781f"] [class*="card"] div,
  body.template-index [class*="c24781f"] [class*="quote"],
  body.template-index [class*="c24781f"] [class*="quote"] * {
    color: #333333 !important;
  }

  body.template-index [class*="c24781f"] [class*="card"] [class*="name"] {
    color: #d52528 !important;
  }

  body.template-index [class*="partner"],
  body.template-index [class*="available"],
  body.template-index [class*="logo-list"],
  body.template-index [class*="logos"],
  body.template-index [class*="193b272"],
  body.template-index [class*="ai-logo-carousel"],
  body.template-index .shopify-section:has([class*="193b272"]),
  body.template-index .section:has([class*="193b272"]) {
    background-color: #ffffff !important;
    background: #ffffff !important;
  }

  /* Product Card Star Rating & Reviews above title */
  body.template-index [class*="ai-product-card-reviews"] .stars,
  body.template-index [class*="product-card-reviews"] .stars {
    color: #ffb800 !important;
    font-size: 18px !important;
  }

  body.template-index [class*="ai-product-card-reviews"] .rating-num,
  body.template-index [class*="product-card-reviews"] .rating-num {
    color: #111111 !important;
    font-size: 14px !important;
  }

  body.template-index [class*="ai-product-card-reviews"] .count,
  body.template-index [class*="product-card-reviews"] .count {
    color: #666666 !important;
    font-size: 14px !important;
  }

  /* Product listing price font color - BLACK (#111111) */
  body.template-index [class*="product-card"] .current-price,
  body.template-index [class*="product-card"] [class*="price-row"] span.current-price,
  body.template-index [class*="ai-product-card"] .current-price,
  body.template-index [class*="ai-product-card"] [class*="price-row"] span.current-price,
  body.template-index [class*="product-card"] [class*="price"] *,
  body.template-index [class*="ai-product-card"] [class*="price"] * {
    color: #111111 !important;
  }

  body.template-index [class*="product-card"] .compare-price,
  body.template-index [class*="ai-product-card"] .compare-price {
    color: #888888 !important;
    text-decoration: line-through !important;
  }

  /* Discount Badge - Crimson Red (#d52528) with White Text */
  body.template-index [class*="discount-badge"],
  body.template-index [class*="discount"],
  body.template-index [class*="badge--sale"],
  body.template-index [class*="price__badge-sale"],
  body.template-index [class*="product-card"] [class*="discount"],
  body.template-index [class*="ai-product-card"] [class*="discount-badge"],
  body.template-index [class*="product-card"] .discount-badge,
  body.template-index [class*="ai-product-card"] .discount-badge {
    background-color: #d52528 !important;
    background: #d52528 !important;
    color: #ffffff !important;
  }

  body.template-index [class*="discount-badge"] *,
  body.template-index [class*="discount"] *,
  body.template-index [class*="product-card"] .discount-badge *,
  body.template-index [class*="ai-product-card"] .discount-badge * {
    color: #ffffff !important;
  }

  /* ADD TO CART Button - BLACK naturally, Crimson Red (#d52528) on hover */
  body.template-index [class*="product-card"] button,
  body.template-index [class*="ai-product-card-button"] {
    background-color: #000000 !important;
    background: #000000 !important;
    color: #ffffff !important;
  }

  body.template-index [class*="product-card"] button:hover,
  body.template-index [class*="ai-product-card-button"]:hover {
    background-color: #d52528 !important;
    background: #d52528 !important;
    color: #ffffff !important;
  }

  /* Header Cart Trigger Button - NO white background */
  body.template-index cart-drawer-component:not(dialog *),
  body.template-index .cart-drawer:not(dialog *),
  body.template-index [data-testid="cart-drawer-trigger"],
  body.template-index .header-actions__action {
    background: transparent !important;
    background-color: transparent !important;
    box-shadow: none !important;
    border: none !important;
  }

  body.template-index cart-drawer-component:not(dialog *) svg,
  body.template-index .cart-drawer:not(dialog *) svg,
  body.template-index [data-testid="cart-drawer-trigger"] svg {
    color: #ffffff !important;
    stroke: #ffffff !important;
    fill: none !important;
  }

  /* Slide-Out Cart Drawer Modal Only - PURE WHITE BACKGROUND & BLACK FONT */
  body.template-index dialog.cart-drawer__dialog,
  body.template-index .cart-drawer__dialog {
    background-color: #ffffff !important;
    background: #ffffff !important;
    color: #111111 !important;
  }

  body.template-index dialog.cart-drawer__dialog * {
    --color-background: #ffffff !important;
  }

  /* Product Filter Category Tabs (RANGE, SNACKBOX, COMBO) */
  body.template-index [class*="ai-product-tab-btn"] {
    background-color: #a72023 !important;
    background: #a72023 !important;
    color: #ffffff !important;
    border: none !important;
  }

  body.template-index [class*="ai-product-tab-btn"]:hover {
    background-color: #921b1e !important;
    background: #921b1e !important;
    color: #ffffff !important;
  }

  body.template-index [class*="ai-product-tab-btn"].active {
    background-color: #ffffff !important;
    background: #ffffff !important;
    color: #000000 !important;
    border: none !important;
  }

  {% for scheme in settings.color_schemes -%}
    {% assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id %}
    {% if forloop.index == 1 %}
      :root,
    {% endif %}
    {% assign background_brightness = scheme.settings.background | color_brightness %}
    {% if background_brightness < 64 %}
      {% assign opacity_5_15 = 0.15 %}
      {% assign opacity_10_25 = 0.25 %}
      {% assign opacity_35_55 = 0.55 %}
      {% assign opacity_40_60 = 0.60 %}
      {% assign opacity_30_60 = 0.60 %}
    {% else %}
      {% assign opacity_5_15 = 0.05 %}
      {% assign opacity_10_25 = 0.1 %}
      {% assign opacity_35_55 = 0.35 %}
      {% assign opacity_40_60 = 0.40 %}
      {% assign opacity_30_60 = 0.30 %}
    {% endif %}
    .color-{{ scheme.id }} {
        --color-background: 213, 37, 40;
        --color-background-rgb: 213, 37, 40;
        --gradient-background: #d52528;
        --opacity-5-15: {{ opacity_5_15 }};
        --opacity-10-25: {{ opacity_10_25 }};
        --opacity-35-55: {{ opacity_35_55 }};
        --opacity-40-60: {{ opacity_40_60 }};
        --opacity-30-60: {{ opacity_30_60 }};
        --color-foreground: 255, 255, 255;
        --color-foreground-rgb: 255, 255, 255;
        --color-foreground-heading: 255, 255, 255;
        --color-foreground-heading-rgb: 255, 255, 255;
        --color-primary: rgb({{ scheme.settings.primary.rgba }});
        --color-primary-rgb: {{ scheme.settings.primary.rgb }};
        --color-primary-hover: rgb({{ scheme.settings.primary_hover.rgba }});
        --color-primary-hover-rgb: {{ scheme.settings.primary_hover.rgb }};
        --color-border: rgb({{ scheme.settings.border.rgba }});
        --color-border-rgb: {{ scheme.settings.border.rgb }};
        --color-shadow: rgb({{ scheme.settings.shadow.rgba }});
        --color-shadow-rgb: {{ scheme.settings.shadow.rgb }};
        --color-primary-button-text: rgb({{ scheme.settings.primary_button_text.rgba }});
        --color-primary-button-background: rgb({{ scheme.settings.primary_button_background.rgba }});
        --color-primary-button-border: rgb({{ scheme.settings.primary_button_border.rgba }});
        --color-primary-button-hover-text: rgb({{ scheme.settings.primary_button_hover_text.rgba }});
        --color-primary-button-hover-background: rgb({{ scheme.settings.primary_button_hover_background.rgba }});
        --color-primary-button-hover-border: rgb({{ scheme.settings.primary_button_hover_border.rgba }});
        --color-secondary-button-text: rgb({{ scheme.settings.secondary_button_text.rgba }});
        --color-secondary-button-background: rgb({{ scheme.settings.secondary_button_background.rgba }});
        --color-secondary-button-border: rgb({{ scheme.settings.secondary_button_border.rgba }});
        --color-secondary-button-hover-text: rgb({{ scheme.settings.secondary_button_hover_text.rgba }});
        --color-secondary-button-hover-background: rgb({{ scheme.settings.secondary_button_hover_background.rgba }});
        --color-secondary-button-hover-border: rgb({{ scheme.settings.secondary_button_hover_border.rgba }});
        --color-input-background: rgb({{ scheme.settings.input_background.rgba }});
        --color-input-text: rgb({{ scheme.settings.input_text_color.rgba }});
        --color-input-text-rgb: {{ scheme.settings.input_text_color.rgb }};
        --color-input-border: rgb({{ scheme.settings.input_border_color.rgba }});
        --color-input-hover-background: rgb({{ scheme.settings.input_hover_background.rgba }});
        --color-variant-background: rgb({{ scheme.settings.variant_background_color.rgba }});
        --color-variant-border: rgb({{ scheme.settings.variant_border_color.rgba }});
        --color-variant-text: rgb({{ scheme.settings.variant_text_color.rgba }});
        --color-variant-text-rgb: {{ scheme.settings.variant_text_color.rgb }};
        --color-variant-hover-background: rgb({{ scheme.settings.variant_hover_background_color.rgba }});
        --color-variant-hover-text: rgb({{ scheme.settings.variant_hover_text_color.rgba }});
        --color-variant-hover-border: rgb({{ scheme.settings.variant_hover_border_color.rgba }});
        --color-selected-variant-background: rgb({{ scheme.settings.selected_variant_background_color.rgba }});
        --color-selected-variant-border: rgb({{ scheme.settings.selected_variant_border_color.rgba }});
        --color-selected-variant-text: rgb({{ scheme.settings.selected_variant_text_color.rgba }});
        --color-selected-variant-hover-background: rgb({{ scheme.settings.selected_variant_hover_background_color.rgba }});
        --color-selected-variant-hover-text: rgb({{ scheme.settings.selected_variant_hover_text_color.rgba }});
        --color-selected-variant-hover-border: rgb({{ scheme.settings.selected_variant_hover_border_color.rgba }});

        --input-disabled-background-color: rgb(var(--color-foreground-rgb) / var(--opacity-10));
        --input-disabled-border-color: rgb(var(--color-foreground-rgb) / var(--opacity-5-15));
        --input-disabled-text-color: rgb(var(--color-foreground-rgb) / var(--opacity-50));
        --color-foreground-muted: rgb(var(--color-foreground-rgb) / var(--opacity-60));
        --font-h1--color: var(--color-foreground-heading);
        --font-h2--color: var(--color-foreground-heading);
        --font-h3--color: var(--color-foreground-heading);
        --font-h4--color: var(--color-foreground-heading);
        --font-h5--color: var(--color-foreground-heading);
        --font-h6--color: var(--color-foreground-heading);

        /* Shadows */
        {% if settings.drawer_drop_shadow %}
          --shadow-drawer: 0px 4px 20px rgb(var(--color-shadow-rgb) / var(--opacity-15));
        {% endif %}
        {% if settings.popover_drop_shadow %}
          --shadow-blur: 20px;
          --shadow-popover: 0px 4px 20px rgb(var(--color-shadow-rgb) / var(--opacity-15));
        {% endif %}
      }
  {% endfor %}

  {{ scheme_classes | prepend: 'body' }} {
    color: var(--color-foreground);
    background-color: var(--color-background);
  }
{% endstyle %}
